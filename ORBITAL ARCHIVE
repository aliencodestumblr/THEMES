<script>
(function(){
  var audio = document.getElementById('audio');
  if(!audio) return;

  var wrap = document.querySelector('#sidebar .sb-playerline');
  if(!wrap) return;

  var playBtn = wrap.querySelector('.sb-play');
  var pauseBtn = wrap.querySelector('.sb-pause');

  function setState(playing){
    if(playBtn) playBtn.style.display = playing ? 'none' : 'inline-flex';
    if(pauseBtn) pauseBtn.style.display = playing ? 'inline-flex' : 'none';
  }

  if(playBtn){
    playBtn.addEventListener('click', function(e){
      e.preventDefault();
      audio.play();
    });
  }

  if(pauseBtn){
    pauseBtn.addEventListener('click', function(e){
      e.preventDefault();
      audio.pause();
    });
  }

  audio.addEventListener('play', function(){ setState(true); });
  audio.addEventListener('pause', function(){ setState(false); });
  audio.addEventListener('ended', function(){ setState(false); });

  setState(!audio.paused);
})();
</script>

<script>
  (function(){
    const sb = document.getElementById('sidebar');
    if(!sb) return;

    const btn = sb.querySelector('.sb-plus');
    const drop = sb.querySelector('.sb-drop');

    function setState(open){
      sb.classList.toggle('is-open', open);
      if(btn) btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      if(drop) drop.setAttribute('aria-hidden', open ? 'false' : 'true');
    }

    setState(false);

    if(btn){
      btn.addEventListener('click', function(e){
        e.preventDefault();
        e.stopPropagation();
        setState(!sb.classList.contains('is-open'));
      });
    }

    document.addEventListener('click', function(e){
      if(!sb.classList.contains('is-open')) return;
      if(sb.contains(e.target)) return;
      setState(false);
    });

    document.addEventListener('keydown', function(e){
      if(e.key === 'Escape') setState(false);
    });
  })();
</script>

