<script>
(function(){

  const tip = document.createElement('div');
  tip.id = 'uni-tip';
  document.body.appendChild(tip);

  const IGNORE_SELECTOR = '.tmblr-iframe, #sidebar, audio, video, iframe';

  function show(text){
    if(!text) return;
    tip.textContent = text;
    tip.classList.add('show');
  }

  function hide(){
    tip.classList.remove('show');
  }

  function move(e){
    const pad = 14;
    let x = e.clientX + pad;
    let y = e.clientY + pad;

    const r = tip.getBoundingClientRect();
    const vw = window.innerWidth;
    const vh = window.innerHeight;

    if (x + r.width + 10 > vw) x = vw - r.width - 10;
    if (y + r.height + 10 > vh) y = vh - r.height - 10;

    tip.style.left = x + 'px';
    tip.style.top  = y + 'px';
  }

  document.addEventListener('mouseenter', (e) => {
    const el = e.target.closest?.('[title]');
    if(!el) return;

    if(el.closest(IGNORE_SELECTOR)) return;

    const title = el.getAttribute('title');
    if(!title) return;

    el.setAttribute('data-old-title', title);
    el.removeAttribute('title');

    show(title);
  }, true);

  document.addEventListener('mouseleave', (e) => {
    const el = e.target.closest?.('[data-old-title]');
    if(!el) return;

    const t = el.getAttribute('data-old-title');
    if(t) el.setAttribute('title', t);
    el.removeAttribute('data-old-title');

    hide();
  }, true);

  {block:IndexPage}
  document.addEventListener('mouseenter', (e) => {
    const post = e.target.closest?.('.posts[data-tip]');
    if(!post) return;
    if(post.closest(IGNORE_SELECTOR)) return;

    const txt = post.getAttribute('data-tip');
    if(!txt) return;
    show(txt);
  }, true);

  document.addEventListener('mouseleave', (e) => {
    const post = e.target.closest?.('.posts[data-tip]');
    if(!post) return;
    hide();
  }, true);
  {/block:IndexPage}

  document.addEventListener('mousemove', (e) => {
    if(!tip.classList.contains('show')) return;
    move(e);
  }, {passive:true});

})();
</script>
</body>
</html>
