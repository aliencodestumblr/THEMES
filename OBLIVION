<script>
document.addEventListener("DOMContentLoaded", function(){

  var audio = document.getElementById("acMiniAudio");
  var toggle = document.getElementById("acMiniToggle");
  var icon = document.getElementById("acMiniIcon");
  var next = document.getElementById("sbNext");
  var title = document.getElementById("sbTrackName");
  var artist = document.getElementById("sbTrackArtist");
  var songs = [].slice.call(document.querySelectorAll("#sbPlaylist .sb-song"));

  if(!audio || !toggle || !icon || !songs.length) return;

  var index = 0;

  function loadSong(i){
    index = i;
    var song = songs[index];

    audio.src = song.dataset.src;

    if(title) title.textContent = song.dataset.title || "Untitled";
    if(artist) artist.textContent = song.dataset.artist || "Unknown";
  }

  // Updates layout to show the outlined square pause icon
  function showPlaying(){
    icon.textContent = "▢";
    icon.classList.remove("play-state");
    icon.classList.add("pause-state");
    toggle.classList.add("is-playing");
  }

  // Updates layout to show the single play triangle
  function showPaused(){
    icon.textContent = "▷";
    icon.classList.remove("pause-state");
    icon.classList.add("play-state");
    toggle.classList.remove("is-playing");
  }

  toggle.addEventListener("click", function(e){
    e.preventDefault();
    e.stopPropagation();

    if(!audio.src) loadSong(index);

    if(audio.paused){
      audio.play();
    } else {
      audio.pause();
    }
  });

  if(next){
    next.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      index = (index + 1) % songs.length;
      loadSong(index);
      audio.play();
    });
  }

  audio.addEventListener("play", showPlaying);
  audio.addEventListener("pause", showPaused);
  audio.addEventListener("ended", function(){
    index = (index + 1) % songs.length;
    loadSong(index);
    audio.play();
  });

  // Init track data safely without fighting styles
  loadSong(0);

});
</script>

