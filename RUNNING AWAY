/* ------------- HOVER DO PERMALINK EM FOTO/VÍDEO ------------- */
{block:IndexPage}

.notsi {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 99;
}

.notsi .inf {
  display: none !important;
}

.notsi .npf-box {
  position: absolute;
  bottom: 14px;
  right: 14px;
  z-index: 5;
  pointer-events: none;
}

.notsi .inf2 {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  border: 1px solid #e2e2e2;
  border-radius: 0px; 
  padding: 4px;
  gap: 4px;
  
  box-shadow: 
    0 4px 10px rgba(0, 0, 0, 0.02),
    0 8px 20px rgba(0, 0, 0, 0.03);
  
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.25s ease, transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  pointer-events: auto;
}

.notsi .inf2 a {
  position: relative;
  height: 30px;
  width: 30px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  color: #666660;
  border-radius: 0px; 
  box-sizing: border-box;
  padding: 0 8px;
  overflow: hidden;
  
  transition: 
    background 0.2s ease, 
    color 0.2s ease, 
    width 0.25s cubic-bezier(0.16, 1, 0.3, 1),
    padding 0.25s cubic-bezier(0.16, 1, 0.3, 1);
}

.notsi .ac-label {
  max-width: 0;
  opacity: 0;
  overflow: hidden;
  white-space: nowrap;

  font-family: "Rajdhani", sans-serif;
  font-size: 8.5px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-left: 0;
  
  transition: 
    max-width 0.25s cubic-bezier(0.16, 1, 0.3, 1), 
    opacity 0.12s ease, 
    margin-left 0.25s ease;
}

.notsi .inf2 a:hover {
  background: #f4f4f4;
  color: #111111;
  width: 84px; 
  justify-content: flex-start;
  gap: 6px;
  padding: 0 9px;
}

.notsi .inf2 a:hover .ac-label {
  max-width: 55px;
  opacity: 1;
  margin-left: 2px;
}

.notsi .inf2 .rb-icon {
  width: 13px;
  height: 13px;
  flex: 0 0 auto;
}

.notsi .inf2 .rb-icon path {
  fill: none;
  stroke: currentColor;
  stroke-width: 1.7px;
  stroke-linecap: square; 
  stroke-linejoin: miter;
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2 {
  opacity: 1;
  transform: translateY(0);
}

