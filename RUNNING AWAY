  function hasTumblrMediaUrl(str){
    str = (str || '').toLowerCase();
    return (
      str.indexOf('64.media.tumblr.com') !== -1 ||
      str.indexOf('va.media.tumblr.com') !== -1 ||
      str.indexOf('media.tumblr.com') !== -1
    );
  }

  function inThemeChrome($el){
    return $el.closest('#sidebar, #topbar, .sb-icon, .brand-icon, .sb-card, .cc, #ltop').length > 0;
  }

  function inPXUPhotoset($el){
    return $el.closest('.photo-slideshow, .pxu-photo, .photo-data').length > 0;
  }

  function looksLikeNPFImage($img){
    if(!$img || !$img.length) return false;
    if(inThemeChrome($img) || inPXUPhotoset($img)) return false;

    var src = $img.attr('src') || '';
    var srcset = $img.attr('srcset') || '';
    var dataSrc = $img.attr('data-src') || '';

    if(hasTumblrMediaUrl(src) || hasTumblrMediaUrl(srcset) || hasTumblrMediaUrl(dataSrc)) return true;

    if($img.closest('figure.tmblr-full, .tmblr-full, .npf_image, .npf_row, .npf_col, .reblog-list').length) return true;

    var $pic = $img.closest('picture');

    if($pic.length){
      var ok = false;

      $pic.find('source').each(function(){
        if(hasTumblrMediaUrl($(this).attr('srcset') || '')) ok = true;
      });

      if(ok) return true;
    }

    return false;
  }

  function looksLikeNPFVideo($node){
    if(!$node || !$node.length) return false;
    if(inPXUPhotoset($node)) return false;

    if($node.is('.npf_video_container, .npf_video, video')) return true;

    if($node.is('iframe')){
      var s = $node.attr('src') || '';

      return (
        s.indexOf('tumblr.com/video') !== -1 ||
        s.indexOf('youtube.com') !== -1 ||
        s.indexOf('vimeo.com') !== -1
      );
    }

    return false;
  }

  function scopePosts($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    return $scope.filter('.posts').add($scope.find('.posts'));
  }

  function initPhotosets($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    if(!$.fn.pxuPhotoset) return;

