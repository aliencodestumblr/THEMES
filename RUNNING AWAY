<script>
document.addEventListener("DOMContentLoaded", function(){

  var audio = document.getElementById("acMiniAudio");
  var toggle = document.getElementById("acMiniToggle");
  var icon = document.getElementById("acMiniIcon");
  var next = document.getElementById("sbNext");
  var title = document.getElementById("sbTrackName");
  var artist = document.getElementById("sbTrackArtist");
  var playlist = document.getElementById("sbPlaylist");
  var songs = [].slice.call(document.querySelectorAll("#sbPlaylist .sb-song"));

  if(!audio || !toggle || !icon || !songs.length) return;

  var index = 0;

  function loadSong(i){
    if(i < 0 || i >= songs.length) i = 0;

    index = i;
    var song = songs[index];
    var src = song.getAttribute("data-src");

    if(!src) return;

    audio.pause();
    audio.src = src;
    audio.load();

    if(title) title.innerHTML = song.getAttribute("data-title") || "Untitled";
    if(artist) artist.innerHTML = song.getAttribute("data-artist") || "Unknown";

    songs.forEach(function(s){
      s.classList.remove("is-active");
    });

    song.classList.add("is-active");
  }

  function playSong(){
    var playPromise = audio.play();

    if(playPromise !== undefined){
      playPromise.catch(function(){});
    }
  }

  function showPlaying(){
    icon.classList.remove("play-state");
    icon.classList.add("pause-state");
    toggle.classList.add("is-playing");
  }

  function showPaused(){
    icon.classList.remove("pause-state");
    icon.classList.add("play-state");
    toggle.classList.remove("is-playing");
  }

  toggle.addEventListener("click", function(e){
    e.preventDefault();
    e.stopPropagation();

    if(!audio.getAttribute("src")) loadSong(index);

    if(audio.paused){
      playSong();
    } else {
      audio.pause();
    }
  });

  if(next){
    next.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      index = (index + 1) % songs.length;
      loadSong(index);
      playSong();
    });
  }

  songs.forEach(function(song, i){
    song.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      loadSong(i);
      playSong();
    });
  });

  audio.addEventListener("play", showPlaying);
  audio.addEventListener("pause", showPaused);

  audio.addEventListener("ended", function(){
    index = (index + 1) % songs.length;
    loadSong(index);
    playSong();
  });

  loadSong(0);
  showPaused();

});
</script>

