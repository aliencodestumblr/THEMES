    var currentIndex = 0;

    function loadTrack(index) {
      if (!songs[index]) return;
      songs.forEach(function(s) { s.classList.remove('is-active'); });
      
      var currentSong = songs[index];
      currentSong.classList.add('is-active');
      
      audio.src = currentSong.getAttribute('data-src');
      trackName.textContent = currentSong.getAttribute('data-title');
      trackArtist.textContent = currentSong.getAttribute('data-artist');
    }

    loadTrack(currentIndex);

    function playAudio() {
      audio.play();
      togglePlay.textContent = "Pause";
    }

    function pauseAudio() {
      audio.pause();
      togglePlay.textContent = "Play";
    }

    togglePlay.addEventListener('click', function() {
      if (audio.paused) {
        playAudio();
      } else {
        pauseAudio();
      }
    });

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        currentIndex = (currentIndex + 1) % songs.length;
        loadTrack(currentIndex);
        playAudio();
      });
    }

    audio.addEventListener('ended', function() {
      currentIndex = (currentIndex + 1) % songs.length;
      loadTrack(currentIndex);
      playAudio();
    });
  }
});
</script>

