/* ---------------- PERMALINK DO POST (INFERIOR) ---------------- */
{block:IndexPage}

/* Structural container - forced to clear and layout correctly */
.post-footer {
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  width: 100% !important;
  margin-top: 25px !important;
  padding: 12px 0 0 0 !important;
  background: transparent !important;
  clear: both !important;
  box-sizing: border-box !important;
  
  /* Premium, clean typographic stack */
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 11px !important;
  letter-spacing: 0.04em !important;
  text-transform: lowercase !important;
}

.pf-left,
.pf-right {
  display: flex !important;
  align-items: center !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* 15px spacing between the action text links */
.pf-right {
  gap: 15px !important; 
}

/* Native typographic links replacing the heavy shapes */
.pf-notes,
.pf-btn {
  display: inline-flex !important;
  align-items: center !important;
  padding: 0 !important;
  margin: 0 !important;
  background: transparent !important;
  border: none !important;
  text-decoration: none !important;
  color: #777777 !important; /* Elegant muted gray by default */
  font-weight: 500 !important;
  transition: color 0.15s ease !important;
}

/* Note count number highlighted slightly */
.pf-num {
  font-weight: 600 !important;
  color: #111111 !important;
  margin-right: 4px !important;
}

/* Hover State: Smooth transition to a sharp, minimalist black */
.pf-notes:hover,
.pf-btn:hover {
  color: #111111 !important;
}

/* Subtle physical feedback on click */
.pf-notes:active,
.pf-btn:active {
  opacity: 0.6 !important;
}

.post-footer *,
.post-footer *::before,
.post-footer *::after {
  box-sizing: border-box !important;
}

