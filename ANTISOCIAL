<style type="text/css">
/* ---------------- PLAYER DO SPOTIFY ---------------- */
:root{
  --sp-scale: 0.80;
  --sp-base-height: 80px;
}

article iframe[src*="spotify.com"],
iframe.spotify_audio_player {
  aspect-ratio: auto !important;
  width: calc(100% / var(--sp-scale)) !important;
  height: var(--sp-base-height) !important;
  transform: scale(var(--sp-scale)) !important;
  transform-origin: top left !important;
  display: block;
  border: 0;
  margin-bottom: calc(var(--sp-base-height) * (var(--sp-scale) - 1)) !important;
}

figure iframe.spotify_audio_player {
  max-height: none !important;
  width: calc(100% / var(--sp-scale)) !important;
}

@keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-moz-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-webkit-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-o-keyframes fadein {from {opacity:0;} to {opacity:1;}}

html, body, a, a:hover{cursor:crosshair;}

/* ---------------- CONTROLES ---------------- */
.cc {
    z-index: 100;
    position: fixed;
    top: 20px;
    right: 20px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 1s;
    padding: 0;
}

.cc svg {
    display: block;
    width: 11px;
    height: 11px;
    overflow: visible;
    color: {color:accent};
}

.cc svg path,
.cc svg circle,
.cc svg line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
}
     
iframe.tmblr-iframe {
    z-index: 999;
    right: 22px;
    top: 27px;
    opacity: 0;
    position: fixed;

    width: 0;

    {block:IfDarkTumblrControl}
    filter: invert(1);
    {/block:IfDarkTumblrControl}

    padding-right: 90px; 

    transform: scale(0.38);
    -webkit-transform: scale(0.38);

    transform-origin: 100% 0;
    -webkit-transform-origin: 100% 0;

    transition: opacity 0.35s ease;
    -webkit-transition: opacity 0.35s ease;
}

.tmblr-iframe:hover {
    opacity: 0.5 !important;
}
/* ---------------- IMAGENS EXPANDIDAS ---------------- */
.vignette, #vignette { opacity:0; }

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999;
  box-shadow:none !important;
  border-radius:2px !important;
  max-width:none;
}

.tmblr-lightbox, #tumblr_lightbox {
    z-index: 999999999;
  background-color:rgba({RGBcolor:background},.7) !important;
}

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999; 
  border:5px solid {color:background}; !important;
  box-shadow: 1px 1px 2px rgba(0,0,0,.1);
  -moz-box-sizing:border-box;
  box-sizing:border-box;
}

/* ---------------- ESTILO DE LINKS + MÍDIA ---------------- */
pre, code {
  overflow-x:auto;
  user-select:all;
  font-family:monospace;
  padding:4px 6px;
  line-height:14px;
  background:rgba(0,0,0,.04);
  margin:10px 0;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  cursor:crosshair; 
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  cursor:crosshair;
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
   cursor:crosshair; 
  width:calc(100% - 0);
  height:auto;
}
blockquote video {
  cursor:crosshair; 
  width:100%;
}

img {
  cursor:crosshair; 
  border:0;
  width:calc(100% - 0);
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
}

.npf_video,
.npf_video_container,
.tmblr-full,
figure.tmblr-full,
figure,
.npf_inst{
  margin:0 !important;
  padding:0 !important;
  line-height:1 !important;
}

.npf_video::after,
.npf_video_container::after,
figure::after,
.tmblr-full::after{
  content:none !important;
  display:none !important;
  height:0 !important;
}

/* ---------------- BODY ---------------- */
body {
