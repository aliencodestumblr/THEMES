/* BETTER BLOG TITLE */

#blogtitle{
  position:absolute;
  top:24px;
  left:24px;

  font-family:'Space Grotesk','Inter','Arial Black',sans-serif;
  font-size:32px;
  line-height:.92;
  font-weight:900;
  letter-spacing:-1.8px;
  text-transform:uppercase;

  color:#fff;

  text-shadow:
    2px 0 0 #6b7dff,
    -1px 0 0 rgba(255,255,255,.25);

  animation:titleSignal 4.2s infinite;
}

#blogtitle:before,
#blogtitle:after{
  content:attr(data-text);
  position:absolute;
  left:0;
  top:0;
  width:100%;
  overflow:hidden;
  color:#fff;
  pointer-events:none;
  opacity:0;
}

#blogtitle:before{
  text-shadow:2px 0 0 #637bff;
  clip-path:inset(0 0 55% 0);
  animation:titleSliceOne 4.2s infinite;
}

#blogtitle:after{
  text-shadow:-2px 0 0 rgba(255,255,255,.4);
  clip-path:inset(55% 0 0 0);
  animation:titleSliceTwo 4.2s infinite;
}

.blogtitle-line{
  position:absolute;
  left:1px;
  bottom:-9px;
  width:58%;
  height:2px;
  background:#fff;
  opacity:.85;
  transform-origin:left;
  animation:titleUnderline 3.2s infinite ease-in-out;
}

@keyframes titleSignal{
  0%,86%,100%{
    transform:translate(0,0);
    letter-spacing:-1.8px;
  }
  88%{
    transform:translate(1px,-1px);
    letter-spacing:-1.4px;
  }
  90%{
    transform:translate(-1px,1px);
  }
  92%{
    transform:translate(0,0);
  }
}

@keyframes titleSliceOne{
  0%,86%,100%{
    opacity:0;
    transform:translate(0,0);
  }
  88%{
    opacity:.9;
    transform:translate(3px,-1px);
  }
  90%{
    opacity:.4;
    transform:translate(-2px,0);
  }
  92%{
    opacity:0;
  }
}

@keyframes titleSliceTwo{
  0%,86%,100%{
    opacity:0;
    transform:translate(0,0);
  }
  88%{
    opacity:.7;
    transform:translate(-3px,1px);
  }
  91%{
    opacity:.35;
    transform:translate(2px,0);
  }
  93%{
    opacity:0;
  }
}

@keyframes titleUnderline{
  0%,100%{
    transform:scaleX(.45);
    opacity:.45;
  }
  50%{
    transform:scaleX(1);
    opacity:1;
  }
}

