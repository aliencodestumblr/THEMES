<script>
document.addEventListener("DOMContentLoaded", function(){

  function checkScroll(){
    if(window.scrollY > 120){
      document.body.classList.add("is-scrolled");
    } else {
      document.body.classList.remove("is-scrolled");
    }
  }

  window.addEventListener("scroll", checkScroll, {passive:true});
  checkScroll();

  var audio = document.getElementById("acMiniAudio");
  var toggle = document.getElementById("acMiniToggle");
  var icon = document.getElementById("acMiniIcon");
  var next = document.getElementById("sbNext");
  var title = document.getElementById("sbTrackName");
  var artist = document.getElementById("sbTrackArtist");
  var songs = [].slice.call(document.querySelectorAll("#sbPlaylist .sb-song"));

  if(!audio || !toggle || !icon || !songs.length) return;

  var index = 0;

  function loadSong(i){
    index = i;
    var song = songs[index];

    songs.forEach(function(s){
      s.classList.remove("is-active");
    });

    song.classList.add("is-active");
    audio.src = song.dataset.src || "";

    if(title) title.innerHTML = song.dataset.title || "Untitled";
    if(artist) artist.innerHTML = song.dataset.artist || "Unknown";
  }

  function playSong(){
    audio.play().then(function(){
      icon.innerHTML = "Ⅱ";
    }).catch(function(){
      icon.innerHTML = "▷";
    });
  }

  function pauseSong(){
    audio.pause();
    icon.innerHTML = "▷";
  }

  toggle.addEventListener("click", function(){
    if(!audio.src) loadSong(index);

    if(audio.paused){
      playSong();
    } else {
      pauseSong();
    }
  });

  if(next){
    next.addEventListener("click", function(){
      index = (index + 1) % songs.length;
      loadSong(index);
      playSong();
    });
  }

  songs.forEach(function(song, i){
    song.addEventListener("click", function(){
      loadSong(i);
      playSong();
    });
  });

  audio.addEventListener("ended", function(){
    index = (index + 1) % songs.length;
    loadSong(index);
    playSong();
  });

  loadSong(0);

});
</script>

