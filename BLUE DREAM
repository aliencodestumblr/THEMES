  var accentColor = '#acd7bb';   
  var playerHeight = 116;       

  $('.soundcloud_audio_player').each(function(){

    let baseSrc = $(this).attr('src').split('&')[0];

    let params = [
      'liking=false',
      'sharing=false',
      'auto_play=false',
      'show_comments=false',
      'continuous_play=false',
      'buying=false',
      'show_playcount=false',
      'show_artwork=false',
      'hide_related=true',
      'origin=tumblr',
      'color=' + accentColor.replace('#','')
    ].join('&');

    $(this).attr({
      src: baseSrc + '&' + params,
      height: playerHeight,
      width: '100%',
      loading: 'lazy'
    });

  });

});

</script>

<script>
document.addEventListener("DOMContentLoaded", function(){

  var audio = document.getElementById("acMiniAudio");
  var toggle = document.getElementById("acMiniToggle");
  var icon = document.getElementById("acMiniIcon");
  var next = document.getElementById("sbNext");
  var title = document.getElementById("sbTrackName");
  var artist = document.getElementById("sbTrackArtist");
  var songs = [].slice.call(document.querySelectorAll("#sbPlaylist .sb-song"));

  if(!audio || !toggle || !icon || !songs.length) return;

  var index = 0;

  function loadSong(i){
    index = i;
    var song = songs[index];

    audio.src = song.dataset.src;

    if(title) title.innerHTML = song.dataset.title || "untitled";
    if(artist) artist.innerHTML = song.dataset.artist || "unknown";
  }

  function showPlaying(){
  icon.innerHTML = "▢";
  toggle.classList.add("is-playing");
}

function showPaused(){
  icon.innerHTML = "▷";
  toggle.classList.remove("is-playing");
}

  toggle.addEventListener("click", function(e){
    e.preventDefault();
    e.stopPropagation();

    if(!audio.src) loadSong(index);

    if(audio.paused){
      audio.play();
    } else {
      audio.pause();
    }
  });

  if(next){
    next.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      index = (index + 1) % songs.length;
      loadSong(index);
      audio.play();
    });
  }

  audio.addEventListener("play", showPlaying);
  audio.addEventListener("pause", showPaused);
  audio.addEventListener("ended", function(){
    index = (index + 1) % songs.length;
    loadSong(index);
    audio.play();
  });

  loadSong(0);
  showPaused();

});
</script>
