<script>
  (function() {
    function runSidebarCoreModules() {
      
      // --- 1. Robust Dropdown Drawer Handler ---
      const triggerButton = document.getElementById("sbNavTrigger");
      const linkDrawer = document.getElementById("sbNavDrawer");

      if (triggerButton && linkDrawer) {
        triggerButton.addEventListener("click", function(event) {
          event.preventDefault();
          const drawerState = linkDrawer.classList.contains("drawer-open");
          
          if (drawerState) {
            linkDrawer.classList.remove("drawer-open");
            triggerButton.classList.remove("active-menu");
            triggerButton.setAttribute("aria-expanded", "false");
            linkDrawer.setAttribute("aria-hidden", "true");
          } else {
            linkDrawer.classList.add("drawer-open");
            triggerButton.setAttribute("aria-expanded", "true");
            triggerButton.classList.add("active-menu");
            linkDrawer.setAttribute("aria-hidden", "false");
          }
        });
      }

      // --- 2. Central Time (CT) Clock Format Engine ---
      function initializeCentralClock() {
        const clockUI = document.getElementById("sb-clock-val");
        if (!clockUI) return;

        try {
          // Enforces 12-hour formatting logic inside America/Chicago (Central Time Zone)
          const options = {
            timeZone: "America/Chicago",
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: true
          };
          
          let ctFormattedString = new Date().toLocaleTimeString("en-US", options);
          clockUI.textContent = ctFormattedString;
        } catch (error) {
          // Failure recovery module
          const backupDate = new Date();
          clockUI.textContent = backupDate.toLocaleTimeString();
        }
      }
      setInterval(initializeCentralClock, 1000);
      initializeCentralClock();

      // --- 3. Live Natural User Count Engine ---
      let userCount = Math.floor(Math.random() * (45 - 21 + 1)) + 21;
      const counterUI = document.getElementById("sb-counter-val");
      
      if (counterUI) {
        counterUI.textContent = String(userCount).padStart(2, "0");
      }

      function fluctuateUsersLoop() {
        const liveCounterTarget = document.getElementById("sb-counter-val");
        if (!liveCounterTarget) return;

        const shiftVal = Math.floor(Math.random() * 5) - 2; // Shifts dynamically from -2 to +2
        userCount += shiftVal;

        if (userCount < 15) userCount = 18;
        if (userCount > 65) userCount = 34;

        liveCounterTarget.textContent = String(userCount).padStart(2, "0");
        setTimeout(fluctuateUsersLoop, Math.random() * (8500 - 4500) + 4500);
      }
      setTimeout(fluctuateUsersLoop, 2500);
    }

    // Run verification blocks to catch late loaded elements on slow connections
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", runSidebarCoreModules);
    } else {
      runSidebarCoreModules();
    }
  })();
</script>

<script>
  (function() {
    function initHeaderEngines() {
      
      // --- 1. Clean HH:MM 12-Hour Layout (e.g., 10:52 PM) ---
      function renderCentralTime() {
        const clockUI = document.getElementById("sb-clock-val");
        if (!clockUI) return;

        try {
          const options = {
            timeZone: "America/Chicago",
            hour: "2-digit",
            minute: "2-digit",
            hour12: true
          };
          
          let ctString = new Date().toLocaleTimeString("en-US", options);
          clockUI.textContent = ctString;
        } catch (err) {
          const backupDate = new Date();
          const fallbackOptions = { hour: '2-digit', minute: '2-digit', hour12: true };
          clockUI.textContent = backupDate.toLocaleTimeString("en-US", fallbackOptions);
        }
      }
      // Updates once every 15 seconds to keep precision clean without running continuously
      setInterval(renderCentralTime, 15000); 
      renderCentralTime();

      // --- 2. Live Natural Counter Loop ---
      let currentUsers = Math.floor(Math.random() * (32 - 14 + 1)) + 14;
      const counterUI = document.getElementById("sb-counter-val");
      
      if (counterUI) {
        counterUI.textContent = String(currentUsers).padStart(2, "0");
      }

      function loopUserMetrics() {
        const targetUI = document.getElementById("sb-counter-val");
        if (!targetUI) return;

        const variation = Math.floor(Math.random() * 3) - 1; 
        currentUsers += variation;

        if (currentUsers < 10) currentUsers = 12;
        if (currentUsers > 45) currentUsers = 28;

        targetUI.textContent = String(currentUsers).padStart(2, "0");
        setTimeout(loopUserMetrics, Math.random() * (9000 - 5000) + 5000);
      }
      setTimeout(loopUserMetrics, 3000);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initHeaderEngines);
    } else {
      initHeaderEngines();
    }
  })();
</script>

<script>
  (function() {
    function launchCyberConsole() {
      // 1. CHRONOGRAPH CONTROL SYSTEM (Clean 12hr Clock, No Seconds)
      const clockView = document.getElementById("cyber-clock-output");
      if (clockView) {
        function computeCyberClock() {
          try {
            const rules = {
              timeZone: "America/Chicago",
              hour: "2-digit",
              minute: "2-digit",
              hour12: true
            };
            let plainTime = new Date().toLocaleTimeString("en-US", rules);
            if (plainTime.startsWith("0")) {
              plainTime = plainTime.substring(1);
            }
            clockView.textContent = plainTime;
          } catch (err) {
            const fallback = new Date();
            let hr = fallback.getHours();
            const mn = String(fallback.getMinutes()).padStart(2, "0");
            const ampm = hr >= 12 ? "PM" : "AM";
            hr = hr % 12 || 12;
            clockView.textContent = `${hr}:${mn} ${ampm}`;
          }
        }
        setInterval(computeCyberClock, 10000);
        computeCyberClock();
      }

      // 2. HARDENED STATE-MONITORED MEDIA CORE
      const mediaPipeline = document.getElementById("acMiniAudio");
      const toggleTrigger = document.getElementById("acMiniToggle");
      const stepForward = document.getElementById("sbNext");
      const trackNodes = document.querySelectorAll("#sbPlaylist .sb-song");

      if (!mediaPipeline || !toggleTrigger) return;

      let runtimePlaylist = [];
      let currentPointer = 0;

      trackNodes.forEach((node, position) => {
        runtimePlaylist.push({
          sourceUrl: node.getAttribute("data-src") || "",
          trackTitle: node.getAttribute("data-title") || "Active Track",
          trackArtist: node.getAttribute("data-artist") || "System Audio"
        });
        if (node.classList.contains("is-active")) {
          currentPointer = position;
        }
      });

      function assignTrackSource(position) {
        if (!runtimePlaylist[position]) return;
        mediaPipeline.src = runtimePlaylist[position].sourceUrl;
        
        const viewTitle = document.getElementById("sbTrackName");
        const viewArtist = document.getElementById("sbTrackArtist");
        if (viewTitle) viewTitle.textContent = runtimePlaylist[position].trackTitle;
        if (viewArtist) viewArtist.textContent = runtimePlaylist[position].trackArtist;

        trackNodes.forEach((node, idx) => {
          node.classList.toggle("is-active", idx === position);
        });
      }

      if (runtimePlaylist.length > 0) {
        assignTrackSource(currentPointer);
      }

      /* ==========================================================================
         OVERWRITE-PROOF AUDIO PIPELINE TRACKERS
         ========================================================================== */
      mediaPipeline.addEventListener("play", function() {
        toggleTrigger.setAttribute("data-audio-state", "playing");
      });

      mediaPipeline.addEventListener("playing", function() {
        toggleTrigger.setAttribute("data-audio-state", "playing");
      });

      mediaPipeline.addEventListener("pause", function() {
        toggleTrigger.setAttribute("data-audio-state", "paused");
      });

      toggleTrigger.addEventListener("click", function(e) {
        if (!mediaPipeline.src && runtimePlaylist.length > 0) {
          assignTrackSource(currentPointer);
        }
        
        if (mediaPipeline.paused) {
          mediaPipeline.play().catch(err => console.log("Stream initialize deferred..."));
        } else {
          mediaPipeline.pause();
        }
      });

      if (stepForward) {
        stepForward.addEventListener("click", function() {
          currentPointer = (currentPointer + 1) % runtimePlaylist.length;
          assignTrackSource(currentPointer);
          mediaPipeline.play().catch(err => console.log("Skip initialize deferred..."));
        });
      }

      mediaPipeline.addEventListener("ended", function() {
        if (runtimePlaylist.length > 1) {
          currentPointer = (currentPointer + 1) % runtimePlaylist.length;
          assignTrackSource(currentPointer);
          mediaPipeline.play();
        } else {
          toggleTrigger.setAttribute("data-audio-state", "paused");
        }
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", launchCyberConsole);
    } else {
      launchCyberConsole();
    }
  })();
</script>

