<style type="text/css">
/* ANTI-SCROLL LATERAL */
html { scrollbar-gutter: stable both-edges; }
body { overflow-y: scroll; }


/* ---------------- PLAYER DO SPOTIFY ---------------- */
:root{
  --sp-scale: 0.80;
  --sp-base-height: 80px;
}

article iframe[src*="spotify.com"],
iframe.spotify_audio_player {
  aspect-ratio: auto !important;
  width: calc(100% / var(--sp-scale)) !important;
  height: var(--sp-base-height) !important;
  transform: scale(var(--sp-scale)) !important;
  transform-origin: top left !important;
  display: block;
  border: 0;
  margin-bottom: calc(var(--sp-base-height) * (var(--sp-scale) - 1)) !important;
}

figure iframe.spotify_audio_player {
  max-height: none !important;
  width: calc(100% / var(--sp-scale)) !important;
}

@keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-moz-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-webkit-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-o-keyframes fadein {from {opacity:0;} to {opacity:1;}}

html, body, a, a:hover{cursor:crosshair;}

/* ---------------- CONTROLES ---------------- */
.cc {
    z-index: 100;
    position: fixed;
    top: 20px;
    right: 20px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 1s;
    padding: 0;
}

.cc svg {
    display: block;
    width: 11px;
    height: 11px;
    overflow: visible;
    color: {color:accent};
}

.cc svg path,
.cc svg circle,
.cc svg line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
}
     
iframe.tmblr-iframe {
    z-index: 999;
    right: 22px;
    top: 27px;
    opacity: 0;
    position: fixed;

    width: 0;

    {block:IfDarkTumblrControl}
    filter: invert(1);
    {/block:IfDarkTumblrControl}

    padding-right: 90px; 

    transform: scale(0.38);
    -webkit-transform: scale(0.38);

    transform-origin: 100% 0;
    -webkit-transform-origin: 100% 0;

    transition: opacity 0.35s ease;
    -webkit-transition: opacity 0.35s ease;
}

.tmblr-iframe:hover {
    opacity: 0.5 !important;
}
/* ---------------- IMAGENS EXPANDIDAS ---------------- */
.vignette, #vignette { opacity:0; }

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999;
  box-shadow:none !important;
  border-radius:2px !important;
  max-width:none;
}

.tmblr-lightbox, #tumblr_lightbox {
    z-index: 999999999;
  background-color:rgba({RGBcolor:background},.7) !important;
}

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999; 
  border:5px solid {color:background}; !important;
  box-shadow: 1px 1px 2px rgba(0,0,0,.1);
  -moz-box-sizing:border-box;
  box-sizing:border-box;
}

/* ---------------- ESTILO DE LINKS + MÍDIA ---------------- */
pre, code {
  overflow-x:auto;
  user-select:all;
  font-family:monospace;
  padding:4px 6px;
  line-height:14px;
  background:rgba(0,0,0,.04);
  margin:10px 0;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  cursor:crosshair; 
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  cursor:crosshair;
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
   cursor:crosshair; 
  width:calc(100% - 0);
  height:auto;
}
blockquote video {
  cursor:crosshair; 
  width:100%;
}

img {
  cursor:crosshair; 
  border:0;
  width:calc(100% - 0);
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
}

.npf_video,
.npf_video_container,
.tmblr-full,
figure.tmblr-full,
figure,
.npf_inst{
  margin:0 !important;
  padding:0 !important;
  line-height:1 !important;
}

.npf_video::after,
.npf_video_container::after,
figure::after,
.tmblr-full::after{
  content:none !important;
  display:none !important;
  height:0 !important;
}

/* ---------------- BODY ---------------- */
body {
  color:{color:text};
  background-color:#000000;
  font:400 10.5px 'DM Sans', sans-serif;
  transition:1.3s;
  letter-spacing:0.5px;
  text-align:justify;
  line-height:15px;
  word-wrap:break-word;
  -webkit-animation-name:fadeIn; animation-name:fadeIn;
}


/* ------------ TÍTULOS DE CABEÇALHO DE POSTS DE TEXTO ------------ */
h1,h2,h3,h4,h5,h6{
  color:{color:accent};
  font:"Rajdhani", sans-serif;
  text-align:justify;
  line-height:15px;
}


/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */
.entry{
  width:740px;
  height:auto;
  margin: 0 auto !important;

  {block:PermalinkPage}
  width:640px;
  margin: 0 auto !important;
  {/block:PermalinkPage}
}

#posts {
  width: 740px;
  margin: 40px auto 50px auto !important; 
  
  transition-property: opacity, filter;
  transition-duration: .0s;

  {block:PermalinkPage}
  width: 640px;
  margin: 45px auto 0 auto !important;
  border: 0px;
  {/block:PermalinkPage}
}

.posts{
  width:320px;
  margin:20px;
  margin-bottom:20px;

  padding:10px;

  overflow:visible;
  opacity:1;
  transition:1s;

  background:#000000;

  border:1px solid {color:Borders};

  box-shadow:
    0 12px 28px rgba(0,0,0,.65),
    inset 0 1px 0 rgba(255,255,255,.03);

  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);

  {block:PermalinkPage}
  width:640px;
  margin:25px auto 0 auto;

  background:transparent;

  border:0;

  box-shadow:none;
  {/block:PermalinkPage}
}


/* ---------------- LINHA DO USUÁRIO NO TOPO DO POST ---------------- */
.post-top{
  margin: 0 0 8px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:0px;

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  letter-spacing:1.6px;
  text-transform:uppercase;

  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}

.notsi {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 99;
}

.notsi .inf {
  display: none !important;
}

.notsi .npf-box {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 5;
  pointer-events: none;
}

.notsi .inf2 {
  display: flex;
  align-items: center;
  justify-content: flex-end; 
  gap: 20px;

  width: 100%;
  box-sizing: border-box;
  padding: 12px 20px;
  background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0) 100%);

  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.3s ease, transform 0.3s ease;
  pointer-events: auto;
}

.notsi .inf2 a {
  position: relative;
  display: flex;
  align-items: center;
  gap: 6px;
  height: 30px;

  background: transparent;
  color: rgba(255, 255, 255, 0.35);
  text-decoration: none;

  font-family: "Rajdhani", sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;

  transition: color 0.2s ease, padding 0.25s ease;
}

.notsi .inf2 a::before,
.notsi .inf2::before,
.notsi .inf2::after {
  display: none !important;
}

/* ICONS */
.notsi .inf2 .rb-icon {
  width: 10px;
  height: 10px;
  opacity: 0.4;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.notsi .inf2 .rb-icon path {
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
}

.notsi .ac-label {
  display: block;
  line-height: 1;
}

/* ACTIVE HOVER */
.notsi .inf2 a:hover {
  color: #ffffff;
  padding-left: 8px; 
}

.notsi .inf2 a:hover .rb-icon {
  opacity: 1;
  transform: rotate(45deg); 
}

.notsi .inf2 a::after {
  content: "";
  position: absolute;
  left: 0;
  top: 25%;
  width: 2px;
  height: 50%;
  background: #ffffff; 
  transform: scaleY(0);
  transition: transform 0.2s ease;
  display: block !important;
}

.notsi .inf2 a:hover::after {
  transform: scaleY(1);
}

/* REVEAL ON POST HOVER */
.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2 {
  opacity: 1;
  transform: translateY(0);
}

{/block:IndexPage}

/* --------- TAMANHOS DE IMAGEM + VÍDEO / NÃO ALTERAR --------- */
.posts img{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
  transition:1s;
}

.video{
