          {block:NotReblog}
          <span class="th th-placeholder-o" style="color:{color:accent}"></span>
          originally: <a href="{BlogURL}"><b>{Name}</b></a>
          {/block:NotReblog}
          <br>
          <span class="note-total">{NoteCountWithLabel}</span>
        </div>
        {PostNotes-64}
      </div>
      {/block:PostNotes}
      {/block:PermalinkPage}
    </div>
    {/block:Posts}
  </div>
</div>

