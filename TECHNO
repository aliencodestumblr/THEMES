/* ---------------- PAGINAÇÃO ---------------- */
.page-nav{
  width:min(700px, calc(100% - 40px));
  margin:50px auto 80px!important;

  display:flex;
  align-items:center;
  justify-content:center;
  flex-wrap:wrap;
