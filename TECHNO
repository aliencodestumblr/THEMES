/* CSS Vector Outlined Glyphs */
.vector-play-glyph {
  width: 0;
  height: 0;
  border-top: 5px solid transparent;
  border-bottom: 5px solid transparent;
  border-left: 9px solid transparent;
  position: relative;
  box-sizing: border-box;
  display: block;
  margin-left: 1px; 
}

.vector-play-glyph::before {
  content: "";
  position: absolute;
  top: -5px;
  left: -9px;
  width: 0;
  height: 0;
  border-top: 5px solid transparent;
  border-bottom: 5px solid transparent;
  border-left: 9px solid #ffffff;
}

.vector-play-glyph::after {
  content: "";
  position: absolute;
  top: -3px;
  left: -8px;
  width: 0;
  height: 0;
  border-top: 3px solid transparent;
  border-bottom: 3px solid transparent;
  border-left: 5px solid #0a0a0c; 
}

.vector-pause-bars {
  width: 9px;
  height: 9px;
  display: none;
  justify-content: space-between;
  box-sizing: border-box;
}

.vector-pause-bars::before,
.vector-pause-bars::after {
  content: '';
  width: 3px;
  height: 9px;
  border: 1px solid #ffffff;
  background: transparent;
  box-sizing: border-box;
}

.mp-play[data-audio-state="playing"] .vector-play-glyph {
