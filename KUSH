}

.sb-title-glitch::before,
.sb-title-glitch::after{
  content:attr(data-text);
  position:absolute;
  inset:0;
  pointer-events:none;
}

.sb-title-glitch::before{
  color:rgba(255,255,255,.9);
  transform:translate(1px,0);
  clip-path:inset(0 0 53% 0);
  animation:thinGlitchTop 3.2s infinite steps(1,end);
}

.sb-title-glitch::after{
  color:rgba(0,0,0,.22);
  transform:translate(-1px,0);
  clip-path:inset(50% 0 0 0);
  animation:thinGlitchBottom 2.5s infinite steps(1,end);
}

@keyframes thinGlitchTop{
  0%,91%,100%{ transform:translate(1px,0); opacity:.34; }
  92%{ transform:translate(5px,-1px); opacity:.8; }
  93%{ transform:translate(-2px,1px); opacity:.28; }
}

@keyframes thinGlitchBottom{
  0%,84%,100%{ transform:translate(-1px,0); opacity:.28; }
  85%{ transform:translate(-5px,1px); opacity:.62; }
  86%{ transform:translate(2px,-1px); opacity:.24; }
}

