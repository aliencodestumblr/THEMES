  width:84px;
  height:84px;

  display:block;
  object-fit:cover;

  border-radius:50%;
  background:#eee;

  filter:grayscale(100%) contrast(.96);
  transition:
    filter .35s ease,
    transform .55s cubic-bezier(.22,1,.36,1);
}

.sb-icon:hover img{
  filter:grayscale(0%) contrast(1);
  transform:scale(1.045);
}

@keyframes sbIconSpin{
  to{ transform:rotate(360deg); }
}

/* THIN GLITCH TITLE */

.sb-title-glitch{
  position:relative;
  display:block;

  max-width:210px;
