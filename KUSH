  place-items:center;

  margin:0 0 15px auto;

  border-radius:50%;
  text-decoration:none;
  overflow:visible;
}

.sb-icon::before{
  content:"";
  position:absolute;
  inset:-5px;
  border-radius:50%;

  background:
    conic-gradient(
      from 0deg,
      rgba(0,0,0,.05),
      rgba(0,0,0,.36),
      rgba(255,255,255,.85),
      rgba(0,0,0,.05)
    );

  animation:sbIconSpin 6s linear infinite;
  opacity:.5;
}

.sb-icon::after{
  content:"";
  position:absolute;
  inset:-1px;
  border-radius:50%;

  border:1px solid rgba(255,255,255,.9);
  box-shadow:
    0 0 0 1px rgba(0,0,0,.08),
    0 9px 22px rgba(0,0,0,.10);
}

.sb-icon img{
