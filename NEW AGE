  var accentColor = '#acd7bb';   
  var playerHeight = 116;       

  $('.soundcloud_audio_player').each(function(){

    let baseSrc = $(this).attr('src').split('&')[0];

    let params = [
      'liking=false',
      'sharing=false',
      'auto_play=false',
      'show_comments=false',
      'continuous_play=false',
      'buying=false',
      'show_playcount=false',
      'show_artwork=false',
      'hide_related=true',
      'origin=tumblr',
      'color=' + accentColor.replace('#','')
    ].join('&');

    $(this).attr({
      src: baseSrc + '&' + params,
      height: playerHeight,
      width: '100%',
      loading: 'lazy'
    });

  });

});

</script>

<script>
(function(){
  var t;
  window.addEventListener('scroll', function(){
    document.documentElement.classList.add('is-scrolling');
    clearTimeout(t);
    t = setTimeout(function(){
      document.documentElement.classList.remove('is-scrolling');
    }, 500);
  }, {passive:true});
})();
</script>

<script>
(function(){
  var wrap = document.getElementById('hb-header-music');
  var audio = document.getElementById('audio');
  if(!wrap || !audio) return;

  function toggle(){
    if(audio.paused){
      audio.play();
    } else {
      audio.pause();
    }
  }

  wrap.addEventListener('click', function(e){
    e.preventDefault();
    toggle();
  });
})();
</script>

