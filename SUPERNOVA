  letter-spacing:1px;
  text-transform:uppercase;
  color:rgba(255,255,255,0.72);
  box-shadow:inset 0 1px 0 rgba(255,255,255,0.08);
}

/* RIGHT */
.hd-right{
  display: flex;
  align-items: center;
  gap: 10px;
  justify-content: flex-end;
  flex-wrap: wrap;
}

.hd-click-menu{
  position: relative;
}

.hd-trigger{
  list-style: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 33px;
  padding: 0 14px;
