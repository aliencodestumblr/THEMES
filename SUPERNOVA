  function hidePostsUntilLayout($posts) {
    if(!$posts || !$posts.length) return;
    
    $posts.each(function() {
      var $p = $(this);
      if(!$p.data('originalDisplay')) {
        $p.data('originalDisplay', $p.css('display'));
      }
    });
    
