<style type="text/css">
/* ANTI-SCROLL LATERAL */
html { scrollbar-gutter: stable both-edges; }
body { overflow-y: scroll; }


/* ---------------- PLAYER DO SPOTIFY ---------------- */
:root{
  --sp-scale: 0.80;
  --sp-base-height: 80px;
}

article iframe[src*="spotify.com"],
iframe.spotify_audio_player {
  aspect-ratio: auto !important;
  width: calc(100% / var(--sp-scale)) !important;
  height: var(--sp-base-height) !important;
  transform: scale(var(--sp-scale)) !important;
  transform-origin: top left !important;
  display: block;
  border: 0;
  margin-bottom: calc(var(--sp-base-height) * (var(--sp-scale) - 1)) !important;
}

figure iframe.spotify_audio_player {
  max-height: none !important;
  width: calc(100% / var(--sp-scale)) !important;
}

@keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-moz-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-webkit-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-o-keyframes fadein {from {opacity:0;} to {opacity:1;}}

html, body, * {
cursor:crosshair;
}

/* ---------------- CONTROLES ---------------- */
.cc {
    z-index: 100;
    position: fixed;
    top: 20px;
    right: 20px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 1s;
    padding: 0;
}

.cc svg {
    display: block;
    width: 11px;
    height: 11px;
    overflow: visible;
    color: {color:accent};
}

.cc svg path,
.cc svg circle,
.cc svg line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
}
     
iframe.tmblr-iframe {
    z-index: 999;
    right: 22px;
    top: 27px;
    opacity: 0;
    position: fixed;

    width: 0;

    filter: invert(1);

    padding-right: 90px; /* smaller hover area */

    transform: scale(0.38);
    -webkit-transform: scale(0.38);

    transform-origin: 100% 0;
    -webkit-transform-origin: 100% 0;

    transition: opacity 0.35s ease;
    -webkit-transition: opacity 0.35s ease;
}

.tmblr-iframe:hover {
    opacity: 0.5 !important;
}
/* ---------------- IMAGENS EXPANDIDAS ---------------- */
.vignette, #vignette { opacity:0; }

.lightbox-image, #tumblr_lightbox img {
  box-shadow:none !important;
  border-radius:2px !important;
  max-width:none;
}

.tmblr-lightbox, #tumblr_lightbox {
  background-color:rgba({RGBcolor:background},.7) !important;
}

.lightbox-image, #tumblr_lightbox img {
  border:5px solid {color:background}; !important;
  box-shadow: 1px 1px 2px rgba(0,0,0,.1);
  -moz-box-sizing:border-box;
  box-sizing:border-box;
}

/* ---------------- ESTILO DE LINKS + MÍDIA ---------------- */
pre, code {
  overflow-x:auto;
  user-select:all;
  font-family:monospace;
  padding:4px 6px;
  line-height:14px;
  background:rgba(0,0,0,.04);
  margin:10px 0;
  border-radius:4px;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  cursor:help;
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
  border-radius:4px;
  width:calc(100% - 0);
  height:auto;
}
blockquote video {
  border-radius:4px;
  width:100%;
}

img {
  border-radius:4px;
  border:0;
  width:calc(100% - 0);
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
}

.npf_video,
.npf_video_container,
.tmblr-full,
figure.tmblr-full,
figure,
.npf_inst{
  margin:0 !important;
  padding:0 !important;
  line-height:1 !important;
}

.npf_video::after,
.npf_video_container::after,
figure::after,
.tmblr-full::after{
  content:none !important;
  display:none !important;
  height:0 !important;
}

/* ---------------- BODY ---------------- */
body {
  color:{color:text};
  background-color:#000;
  font:400 10.5px "Rajdhani", sans-serif;
  transition:1.3s;
  letter-spacing:0.5px;
  text-align:justify;
  line-height:15px;
  word-wrap:break-word;
  -webkit-animation-name:fadeIn; animation-name:fadeIn;
}


/* ------------ TÍTULOS DE CABEÇALHO DE POSTS DE TEXTO ----------- */
h1,h2,h3,h4,h5,h6{
  color:{color:accent};
  font:"Rajdhani", sans-serif;
  text-align:justify;
  line-height:15px;
}


/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */
.entry{
  width:930px;
  height:auto;
  margin: 0 auto !important;

  {block:PermalinkPage}
  width:800px;
  margin: 0 auto !important;
  {/block:PermalinkPage}
}

#posts{
  width:930px;
  margin: 120px auto 50px auto !important;
  
  
  /* POSIÇÃO DOS POSTS
   Este valor move todos os posts horizontalmente.
   Use números negativos para mover os posts para a ESQUERDA.
   Use números positivos para mover os posts para a DIREITA.
   Ajuste esse valor se quiser alinhar os posts melhor no layout. */
  transform: translateX(0px);
  

/* permitir transições, mas NÃO no transform — NÃO REMOVA */
  transition-property: opacity, filter;
  transition-duration: .0s;

  {block:PermalinkPage}
  width:800px;
  margin:145px auto 0 auto !important;
  transform: translateX(0px);
  {/block:PermalinkPage}
}

.posts{
  width:260px;
  margin:25px;
  margin-bottom:25px;
  padding:0;
  overflow:visible;
  opacity:1;
  transition:1s;

  {block:PermalinkPage}
  width:700px;
  margin:25px auto 0 auto;
  {/block:PermalinkPage}
}


/* ---------------- LINHA DO USUÁRIO NO TOPO DO POST ---------------- */
.post-top{
  margin: 0 0 8px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:0px;

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  letter-spacing:1.6px;
  text-transform:uppercase;

  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;600&display=swap');

.notsi{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  pointer-events:none;
  z-index:10;
  border-radius:4px;
}

/* dark glass fade background */
.notsi::before{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.28);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  opacity:0;
  transition:
    opacity .75s cubic-bezier(.19,1,.22,1);
  pointer-events:none;
  border-radius:4px;
}

/* time */
.notsi .inf{
  position:relative;
  z-index:2;
  opacity:0;
  margin-bottom:10px;
  transform:translateY(12px);
  transition:
    opacity .7s cubic-bezier(.19,1,.22,1),
    transform .7s cubic-bezier(.19,1,.22,1);
  transition-delay:.08s;
  pointer-events:none;
}

.notsi .npf-time{
  font-family:"Orbitron", sans-serif;
  font-size:7px;
  font-weight:400;
  letter-spacing:2px;
  text-transform:uppercase;
  color:rgba(255,255,255,.78);
  text-align:center;
  text-shadow:0 0 10px rgba(0,0,0,.35);
}

/* icon row */
.notsi .inf2{
  position:relative;
  z-index:2;
  opacity:0;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:30px;
  transform:translateY(14px);
  transition:
    opacity .8s cubic-bezier(.19,1,.22,1),
    transform .8s cubic-bezier(.19,1,.22,1);
  transition-delay:.16s;
  pointer-events:auto;
}

/* icon links */
.notsi .inf2 a{
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  color:rgba(255,255,255,.72);
  font-size:10px;
  line-height:1;
  padding:0;
  background:none !important;
  border:none !important;
  box-shadow:none !important;
  opacity:.92;
  transition:
    color .3s ease,
    transform .35s ease,
    opacity .35s ease;
}

.notsi .inf2 a:hover{
  color:#fff;
  transform:translateY(-1px) scale(1.06);
  opacity:1;
}

/* show on hover */
.post:hover .notsi::before,
.ac-hover-on .notsi::before{
  opacity:1;
}

.post:hover .notsi .inf,
.ac-hover-on .notsi .inf{
  opacity:1;
  transform:translateY(0);
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2{
  opacity:1;
  transform:translateY(0);
}
{/block:IndexPage}

/* --------- TAMANHOS DE IMAGEM + VÍDEO / NÃO ALTERAR --------- */
.posts img{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
  transition:1s;
}

.video{
  width:100%;
  {block:permalinkpage}
