@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600&family=Rajdhani:wght@600;700&display=swap');

:root{
  --header-bg: rgba(8,8,8,0.72);
  --header-bg-strong: rgba(14,14,14,0.88);
  --header-blur: blur(20px) saturate(155%);
  --sharp-radius: 16px;

  --text-color: rgba(255,255,255,0.90);
  --muted: rgba(255,255,255,0.46);
  --line: rgba(255,255,255,0.10);
  --line-soft: rgba(255,255,255,0.14);
  --soft-glow: rgba(255,255,255,0.08);
}

#sharp-header{
  position: fixed;
  top: 22px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 99999;
  width: auto;
  min-width: 910px;
  max-width: 94vw;
  padding: 12px 14px;
  background: linear-gradient(180deg, rgba(18,18,18,0.82), rgba(6,6,6,0.72));
  backdrop-filter: var(--header-blur);
  -webkit-backdrop-filter: var(--header-blur);
  border: 1px solid var(--line);
  border-radius: var(--sharp-radius);
  box-shadow:
    0 18px 48px rgba(0,0,0,0.62),
    0 0 18px rgba(255,255,255,0.03),
    inset 0 1px 0 rgba(255,255,255,0.08),
    inset 0 0 0 1px rgba(255,255,255,0.02);
  overflow: visible;
  animation: headerDrift 7s ease-in-out infinite;
}

#sharp-header::before{
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0.06) 0%,
      rgba(255,255,255,0.02) 28%,
      transparent 60%,
      rgba(255,255,255,0.03) 100%
    );
  opacity: .9;
}

#sharp-header::after{
  content: "";
  position: absolute;
  left: 16px;
  right: 16px;
  bottom: -1px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.35), transparent);
  opacity: .35;
}

@keyframes headerDrift{
  0%,100%{ transform: translateX(-50%) translateY(0); }
  50%{ transform: translateX(-50%) translateY(-2px); }
}

.hd-inner{
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  align-items: center;
  gap: 18px;
}

/* LEFT */
.hd-left{
  display: flex;
  align-items: center;
  gap: 16px;
  min-width: 0;
}

/* AVATAR */
.hd-avatar-link{
  position: relative;
  display: block;
  width: 48px;
  height: 48px;
  flex: 0 0 48px;
  border-radius: 50%;
  overflow: visible;
}

.hd-avatar-link img{
  position: relative;
  z-index: 5;
  display: block;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid rgba(255,255,255,0.74);
  box-shadow:
    0 8px 18px rgba(0,0,0,0.52),
    0 0 12px rgba(255,255,255,0.04),
    inset 0 0 0 1px rgba(255,255,255,0.04);
}

.avatar-glow,
.avatar-orbit{
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.avatar-glow{
  inset: -14px;
  z-index: 1;
  background: radial-gradient(circle, rgba(255,255,255,0.09) 0%, rgba(255,255,255,0.03) 34%, rgba(255,255,255,0) 70%);
  animation: glowPulse 4s ease-in-out infinite;
}

.avatar-orbit{
  inset: -6px;
  z-index: 3;
}

.avatar-orbit::before{
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  padding: 2px;
  background: conic-gradient(
    from 0deg,
    transparent 0 16%,
    rgba(255,255,255,0.85) 24%,
    transparent 32%,
    transparent 56%,
    rgba(255,255,255,0.40) 64%,
    transparent 72%,
    transparent 100%
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.orbit-a::before{
  animation: orbitSpin 7s linear infinite;
  opacity: .85;
}

.orbit-b{
  inset: -10px;
}

.orbit-b::before{
  animation: orbitSpinReverse 10s linear infinite;
  opacity: .32;
}

@keyframes orbitSpin{
  to{ transform: rotate(360deg); }
}

@keyframes orbitSpinReverse{
  to{ transform: rotate(-360deg); }
}

@keyframes glowPulse{
  0%,100%{ transform: scale(.97); opacity: .42; }
  50%{ transform: scale(1.07); opacity: .82; }
}

/* META */
.hd-meta{
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.hd-title-row{
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: 0;
  flex-wrap: wrap;
}

.hd-title-wrap{
  position: relative;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10px;
}

.hd-title{
  position: relative;
  font-family: "Orbitron", sans-serif;
  font-size: 11px;
  line-height: 1;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--text-color);
  white-space: nowrap;
  opacity: .90;
  text-shadow: 0 0 8px rgba(255,255,255,0.06);
  animation: titlePulse 5.8s ease-in-out infinite;
}

.title-line{
  position: relative;
  width: 58px;
  height: 1px;
  background: linear-gradient(90deg, rgba(255,255,255,.34), transparent);
  opacity: .45;
  animation: lineBlink 4.2s ease-in-out infinite;
}

@keyframes titlePulse{
  0%,100%{ opacity: .72; letter-spacing: 3px; }
  50%{ opacity: 1; letter-spacing: 3.4px; }
}

@keyframes lineBlink{
  0%,100%{ opacity: .24; transform: scaleX(.92); }
  50%{ opacity: .65; transform: scaleX(1); }
}

.hd-profile-info{
  display: inline-flex;
  align-items: center;
  gap: 7px;
  height: 27px;
  padding: 0 11px;
  border-radius: 999px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.09);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.08),
    0 0 10px rgba(255,255,255,0.015);
  animation: chipFloat 6s ease-in-out infinite;
}

.hd-name-text{
  font-family: "Orbitron", sans-serif;
  font-size: 8px;
  letter-spacing: 1.3px;
  text-transform: uppercase;
  color: var(--text-color);
}

.hd-verified-badge{
  width: 14px;
  height: 14px;
  border-radius: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.10);
  box-shadow: 0 0 0 0 rgba(255,255,255,0);
  animation: badgeGlow 4s ease-in-out infinite;
}

.hd-verified-badge svg{
  width: 9px;
  height: 9px;
  fill: none;
  stroke: rgba(255,255,255,0.84);
  stroke-width: 2;
}

@keyframes badgeGlow{
  0%,100%{ box-shadow: 0 0 0 0 rgba(255,255,255,0); }
  50%{ box-shadow: 0 0 10px 1px rgba(255,255,255,.06); }
}

.hd-status-row{
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.status-chip{
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 24px;
  padding: 0 10px;
  border-radius: 999px;
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.09);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
  font-family: "Orbitron", sans-serif;
  font-size: 8px;
  letter-spacing: 1px;
  text-transform: uppercase;
  color: var(--text-color);
  animation: chipFloat 6s ease-in-out infinite;
}

.status-chip:nth-child(2){
  animation-delay: .8s;
}

.chip-label,
.online-label{
  opacity: .52;
}

.online-dot{
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: rgba(255,255,255,0.85);
  box-shadow: 0 0 0 0 rgba(255,255,255,0);
  animation: dotSignal 2.1s ease-in-out infinite;
}

@keyframes chipFloat{
  0%,100%{ transform: translateY(0); }
  50%{ transform: translateY(-1px); }
}

@keyframes dotSignal{
  0%,100%{ transform: scale(1); opacity: .55; box-shadow: 0 0 0 0 rgba(255,255,255,0); }
  50%{ transform: scale(1.18); opacity: 1; box-shadow: 0 0 10px 1px rgba(255,255,255,.10); }
}

.hd-inline-time{
  display:inline-flex;
