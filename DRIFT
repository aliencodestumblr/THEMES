<script>
(function($){
  if(!window.jQuery) return;

  var $win = $(window);
  var $doc = $(document);
  var $container = $('#posts');
  if(!$container.length) return;

  if($container.data('acInitDoneSpotifyFix') === 1) return;
  $container.data('acInitDoneSpotifyFix', 1);

  var resizeObserver = null;
  var activePost = null;
  var activeRoot = null;
  var hoverTimer = null;
  var isLoadingMore = false;

  function safe(fn){
    try{ fn(); }catch(e){}
  }

  function throttle(fn, wait){
    var t = null;
    return function(){
      if(t) return;
      t = setTimeout(function(){
        t = null;
        fn();
      }, wait);
    };
  }

  function clearActiveHover(){
    $('.posts.ac-hover-on, .ac-hover-root.ac-hover-on').removeClass('ac-hover-on');
    activePost = null;
    activeRoot = null;
  }

  function relayout(){
    if(!$.fn.masonry) return;
    safe(function(){
      $container.masonry('reloadItems');
      $container.masonry('layout');
    });
  }

  function relayoutSoon(){
    setTimeout(relayout, 80);
    setTimeout(relayout, 300);
    setTimeout(relayout, 900);
  }

  function forceVisible($items){
    if(!$items || !$items.length) return;

    $items.css({
      opacity:'',
      visibility:'',
      display:'',
      transform:''
    });

    $items.addClass('is-ready');
  }

  function forceEager($scope){
    $scope = $scope && $scope.length ? $scope : $(document);

    $scope.find('img[loading="lazy"]').each(function(){
      try{ this.loading = 'eager'; }catch(e){}
      $(this).attr('loading','eager');
    });

    $scope.find('iframe[loading="lazy"]').each(function(){
      $(this).attr('loading','eager');
    });
  }

  function inThemeChrome($el){
    return $el.closest(
      '#sidebar, #topbar, .sb-icon, .brand-icon, .sb-card, .cc, #ltop, #sharp-sidebar-wrap, #top-player-fixed, .sb-mini-player, iframe.tmblr-iframe'
    ).length > 0;
  }

  function inPXUPhotoset($el){
    return $el.closest('.photo-slideshow, .pxu-photo, .photo-data').length > 0;
  }

  function hasTumblrMediaUrl(str){
    str = (str || '').toLowerCase();
    return (
      str.indexOf('64.media.tumblr.com') !== -1 ||
      str.indexOf('va.media.tumblr.com') !== -1 ||
      str.indexOf('media.tumblr.com') !== -1
    );
  }

  function isSpotifyOrAudioEmbed($node){
    if(!$node || !$node.length) return false;

    var src = ($node.attr('src') || '').toLowerCase();
    var href = ($node.attr('href') || '').toLowerCase();

    return (
      src.indexOf('spotify.com') !== -1 ||
      src.indexOf('open.spotify.com') !== -1 ||
      src.indexOf('soundcloud.com') !== -1 ||
      href.indexOf('spotify.com') !== -1 ||
      href.indexOf('open.spotify.com') !== -1 ||
      href.indexOf('soundcloud.com') !== -1 ||
      $node.closest('.spotify_audio_player, .soundcloud_audio_player, .audio_player, .tumblr_audio_player').length > 0
    );
  }

  function markSpotifyPostsAsText($scope){
    var $posts = scopePosts($scope);

    $posts.each(function(){
      var $post = $(this);

      var hasSpotify = $post.find('iframe, a, .spotify_audio_player, .soundcloud_audio_player, .audio_player, .tumblr_audio_player').filter(function(){
        return isSpotifyOrAudioEmbed($(this));
      }).length > 0;

      if(hasSpotify){
        $post
          .addClass('ac-text-post ac-embed-post ac-spotify-post')
          .removeClass('has-npf-media ac-hover-on');

        $post.find('.notsi').remove();
        $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-npf-media');
        $post.removeData('acHoverDone');
      }
    });
  }

  function looksLikeNPFImage($img){
    if(!$img || !$img.length) return false;
    if(inThemeChrome($img) || inPXUPhotoset($img)) return false;

    var src = $img.attr('src') || '';
    var srcset = $img.attr('srcset') || '';
    var dataSrc = $img.attr('data-src') || '';

    if(hasTumblrMediaUrl(src) || hasTumblrMediaUrl(srcset) || hasTumblrMediaUrl(dataSrc)) return true;

    if($img.closest(
      '.media-wrap, figure.tmblr-full, .tmblr-full, .npf_image, .npf_row, .npf_col, .npf_photoset, .npf_grid, .npf_container, .reblog-list'
    ).length) return true;

    var $pic = $img.closest('picture');
    if($pic.length){
      var ok = false;
      $pic.find('source').each(function(){
        if(hasTumblrMediaUrl($(this).attr('srcset') || '')) ok = true;
      });
      if(ok) return true;
    }

    return false;
  }

  function looksLikeNPFVideo($node){
    if(!$node || !$node.length) return false;
    if(inThemeChrome($node) || inPXUPhotoset($node)) return false;

    /* IMPORTANT:
       Spotify/SoundCloud/audio embeds are NOT media-hover posts.
       They should behave like text/embed posts. */
    if(isSpotifyOrAudioEmbed($node)) return false;

    if($node.is('.npf_video_container, .npf_video, video')) return true;

    if($node.is('iframe')){
      var s = ($node.attr('src') || '').toLowerCase();

      return (
        s.indexOf('tumblr.com/video') !== -1 ||
        s.indexOf('youtube.com') !== -1 ||
        s.indexOf('youtu.be') !== -1 ||
        s.indexOf('vimeo.com') !== -1
      );
    }

    return false;
  }

  function scopePosts($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    return $scope.filter('.posts').add($scope.find('.posts'));
  }

  function initPhotosets($scope){
    $scope = $scope && $scope.length ? $scope : $(document);
    if(!$.fn.pxuPhotoset) return;

    $scope.find('.photo-slideshow').each(function(){
      if(this._acPXUInited) return;
      this._acPXUInited = true;

      $(this).pxuPhotoset({
        lightbox:true,
        rounded:false,
        gutter:'1px',
        photoset:'.photo-slideshow',
        photoWrap:'.photo-data',
        photo:'.pxu-photo'
      });
    });
  }

  function initUnnest($scope){
    if(!$.fn.unnest) return;

    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    $posts.each(function(){
      var $post = $(this);
      if($post.data('acUnnestDone') === 1) return;
      $post.data('acUnnestDone', 1);

      $post.unnest({
        yourCaption:".caption",
        wrapName:".tumblr_parent",
        newCaptionUsername:false,
        originalPostCaptionUsername:false,
        tumblrAvatars:false,
        tumblrAvatarsName:".tumblr_avatar",
        usernameColon:false
      });
    });
  }

  function cleanupNPFMediaUrls($scope){
    $scope = $scope && $scope.length ? $scope : $(document);
    var hosts = ['64.media.tumblr.com/','va.media.tumblr.com/','media.tumblr.com/'];

    $scope.find('a[href]').each(function(){
      var $a = $(this);
      var hrefRaw = $a.attr('href') || '';
      var href = hrefRaw.toLowerCase();
      var txt = $.trim($a.text() || '');

      var isMedia = false;

      for(var i = 0; i < hosts.length; i++){
        if(href.indexOf(hosts[i]) !== -1){
          isMedia = true;
          break;
        }
      }

      if(!isMedia) return;

      if(txt && ($.trim(hrefRaw) === txt || $.trim(href) === txt.toLowerCase()) && $a.children().length === 0){
        var $p = $a.closest('p');
        if($p.length && $.trim($p.text()) === txt) $p.remove();
        else $a.remove();
      }
    });
  }

  function countNPFMedia($scope){
    if(!$scope || !$scope.length) return 0;

    var imgCount = $scope.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).length;

    var vidCount = $scope.find('video, iframe, .npf_video_container, .npf_video').filter(function(){
      return looksLikeNPFVideo($(this));
    }).length;

    return imgCount + vidCount;
  }

  function postHasAudioEmbed($post){
    return $post.find('iframe, a, .spotify_audio_player, .soundcloud_audio_player, .audio_player, .tumblr_audio_player').filter(function(){
      return isSpotifyOrAudioEmbed($(this));
    }).length > 0;
  }

  function postHasMedia($post){
    if(!$post || !$post.length) return false;

    /* Spotify/audio posts stay text/embed posts, not hover-media posts. */
    if(postHasAudioEmbed($post)) return false;

    if($post.find('.media-wrap, .photo-slideshow').length) return true;

    return countNPFMedia($post) > 0;
  }

  function pickHoverTarget($post){
    if(!$post || !$post.length) return $();

    if(postHasAudioEmbed($post)) return $();

    var $mw = $post.find('.media-wrap').first();
    if($mw.length) return $mw;

    var $old = $post.find('.photo-slideshow').first();
    if($old.length) return $old;

    var $group = $post.find(
      '.npf_photoset, .npf_grid, .npf_container, .npf_group, .npf_row'
    ).filter(function(){
      return countNPFMedia($(this)) > 0;
    }).first();

    if($group.length) return $group;

    var $vid = $post.find('.npf_video_container, .npf_video, video, iframe').filter(function(){
      return looksLikeNPFVideo($(this));
    }).first();

    if($vid.length){
      var $wrap = $vid.closest('figure.tmblr-full, .tmblr-full, .npf_video_container, .npf_video').first();
      return $wrap.length ? $wrap : $vid;
    }

    var $oneBlock = $post.find('figure.tmblr-full, .tmblr-full, .npf_image, figure').filter(function(){
      var $b = $(this);
      if(inPXUPhotoset($b)) return false;

      return $b.find('img').filter(function(){
        return looksLikeNPFImage($(this));
      }).length > 0;
    }).first();

    if($oneBlock.length) return $oneBlock;

    var $img = $post.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).first();

    if($img.length){
      var $imgWrap = $img.closest('figure.tmblr-full, .tmblr-full, .npf_image, picture, div').first();
      return $imgWrap.length ? $imgWrap : $img;
    }

    return $();
  }

  function normalizeOverlayNode($node){
    if(!$node || !$node.length) return $node;

    $node.addClass('notsi');
    $node.attr('data-ac-hover-root','');

    if(!$node.find('.npf-box').length){
      var $inf = $node.children('.inf').first();
      var $inf2 = $node.children('.inf2').first();
      var $box = $('<div class="npf-box"></div>');

      if($inf.length) $box.append($inf);
      if($inf2.length) $box.append($inf2);

      if(!$box.children().length){
        $box.append(
          '<div class="inf2">' +
            '<a class="npf-reblog" data-ac-reblog href="#"><i class="ph ph-arrows-clockwise"></i></a>' +
            '<a class="npf-permalink" data-ac-permalink href="#"><i class="ph ph-link-simple-horizontal"></i></a>' +
            '<a class="npf-lightbox" data-ac-lightbox href="#"><i class="ph ph-arrows-out"></i></a>' +
          '</div>'
        );
      }

      $node.append($box);
    }

    $node[0].style.pointerEvents = 'none';

    $node.find('.npf-box, .inf2, .inf2 a, a').each(function(){
      this.style.pointerEvents = 'auto';
    });

    return $node;
  }

  function buildOverlayNode(){
    var tpl = document.getElementById('npf-hover-template');

    if(tpl && tpl.content && tpl.content.firstElementChild){
      return normalizeOverlayNode($(tpl.content.firstElementChild.cloneNode(true)));
    }

    return normalizeOverlayNode($(
      '<div class="notsi" data-ac-hover-root>' +
        '<div class="npf-box">' +
          '<div class="inf">' +
            '<div class="npf-time" data-ac-time></div>' +
          '</div>' +
          '<div class="inf2">' +
            '<a class="npf-reblog" data-ac-reblog href="#"><i class="ph ph-arrows-clockwise"></i></a>' +
            '<a class="npf-permalink" data-ac-permalink href="#"><i class="ph ph-link-simple-horizontal"></i></a>' +
            '<a class="npf-lightbox" data-ac-lightbox href="#"><i class="ph ph-arrows-out"></i></a>' +
          '</div>' +
        '</div>' +
      '</div>'
    ));
  }

  function postNeedsRebuild($post){
    if(!$post || !$post.length) return false;

    if(postHasAudioEmbed($post)) return false;

    var $root = $post.find('.ac-hover-root').first();
    var $overlay = $post.find('.notsi').first();

    if(!$root.length || !$overlay.length) return true;
    if(!$overlay.closest('.ac-hover-root').length) return true;

    var $wanted = pickHoverTarget($post);
    if(!$wanted.length) return false;

    return $root[0] !== $wanted[0];
  }

  function removeHoverFromTextEmbed($post){
    $post
      .addClass('ac-text-post ac-embed-post')
      .removeClass('has-npf-media ac-hover-on');

    $post.find('.notsi').remove();
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-npf-media');
    $post.removeData('acHoverDone');

    if(activePost === $post[0] || (activeRoot && $.contains($post[0], activeRoot))){
      clearActiveHover();
    }
  }

  function addHoverOverlay($post){
    if(!$post || !$post.length) return;

    if(postHasAudioEmbed($post)){
      removeHoverFromTextEmbed($post);
      return;
    }

    if(!postHasMedia($post)){
      $post.removeClass('has-npf-media ac-hover-on');
      $post.removeData('acHoverDone');
      $post.find('.notsi').remove();
      $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-npf-media');
      return;
    }

    var perma = $post.attr('data-permalink') || '';
    if(!perma) return;

    if($post.data('acHoverDone') === 1 && !postNeedsRebuild($post)) return;

    if(activePost === $post[0] || (activeRoot && $.contains($post[0], activeRoot))){
      clearActiveHover();
    }

    var rb = $post.attr('data-reblogurl') || '#';
    var tm = $post.attr('data-time') || '';

    $post
      .addClass('has-npf-media')
      .removeClass('ac-text-post ac-embed-post ac-spotify-post ac-hover-on');

    $post.find('.notsi').remove();
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-npf-media');

    var $target = pickHoverTarget($post);
    if(!$target.length) return;

    if(($target.css('position') || 'static') === 'static'){
      $target.css('position','relative');
    }

    $target.css('overflow','hidden');

    var $node = buildOverlayNode();

    $node.find('.npf-time, [data-ac-time]').first().text(tm);

    var $rbA = $node.find('a.npf-reblog, [data-ac-reblog]').first();
    if($rbA.length) $rbA.attr('href', rb);

    var $pmA = $node.find('a.npf-permalink, [data-ac-permalink]').first();
    if($pmA.length) $pmA.attr('href', perma);

    var $lbA = $node.find('a.npf-lightbox, [data-ac-lightbox]').first();
    if($lbA.length) $lbA.attr('href', '#');

    $target.addClass('ac-npf-media ac-hover-root').append($node);
    $post.data('acHoverDone', 1);
  }

  function watchHeights($items){
    if(!$items || !$items.length) return;

    $items.find('img').each(function(){
      var img = this;
      if(img._acHoverWatchBound) return;
      img._acHoverWatchBound = true;

      img.addEventListener('load', relayoutSoon, { passive:true });
      img.addEventListener('error', relayoutSoon, { passive:true });
    });

    $items.find('iframe').each(function(){
      var frame = this;
      if(frame._acHoverWatchBound) return;
      frame._acHoverWatchBound = true;

      frame.addEventListener('load', relayoutSoon, { passive:true });
    });

    if(window.ResizeObserver){
      if(!resizeObserver){
        resizeObserver = new ResizeObserver(throttle(relayoutSoon, 100));
      }

      $items.each(function(){
        if(this._acHoverROBound) return;
        this._acHoverROBound = true;

        try{
          resizeObserver.observe(this);
        }catch(e){}
      });
    }
  }

  function processPosts($scope){
    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    forceVisible($posts);
    forceEager($posts);

    safe(function(){ initPhotosets($posts); });
    safe(function(){ initUnnest($posts); });
    safe(function(){ cleanupNPFMediaUrls($posts); });

    markSpotifyPostsAsText($posts);

    $posts.each(function(){
      addHoverOverlay($(this));
    });

    watchHeights($posts);
  }

  function processUnprocessedPosts(){
    var $todo = $container.find('.posts').filter(function(){
      var $post = $(this);

      if(postHasAudioEmbed($post)) return true;
      if(!$post.data('acHoverDone') && postHasMedia($post)) return true;
      if(postNeedsRebuild($post)) return true;

      return false;
    });

    if(!$todo.length) return;
    processPosts($todo);
  }

  function openTumblrLightboxFromPost($post){
    if(!$post || !$post.length) return;

    var imgs = [];

    $post.find('.media-wrap img, .photo-slideshow img, .pxu-photo img, .npf_image img, figure.tmblr-full img, .tmblr-full img').each(function(){
      var $img = $(this);
      if($img.closest('.notsi').length) return;

      var high =
        $img.attr('data-highres') ||
        $img.attr('data-src') ||
        $img.closest('a[href]').attr('href') ||
        $img.attr('src');

      var low = $img.attr('src') || high;
      if(!high) return;

      imgs.push({
        width: parseInt($img.attr('data-width'),10) || this.naturalWidth || this.width || 1280,
        height: parseInt($img.attr('data-height'),10) || this.naturalHeight || this.height || 1280,
        low_res: low,
        high_res: high
      });
    });

    if(imgs.length && window.Tumblr && Tumblr.Lightbox && typeof Tumblr.Lightbox.init === 'function'){
      Tumblr.Lightbox.init(imgs);
      $('body').addClass('tumblr_lightbox_active');
    }
  }

  function activateHover($root){
    if(!$root || !$root.length || isLoadingMore) return;

    var $post = $root.closest('.posts');
    if(!$post.length) return;

    if(postHasAudioEmbed($post)) return;

    if(activeRoot !== $root[0]){
      clearActiveHover();
      activeRoot = $root[0];
      activePost = $post[0];
    }

    $root.addClass('ac-hover-on');
    $post.addClass('ac-hover-on');
  }

  function bindHoverEvents(){
    $doc.off('.acHoverFix');
    $win.off('.acHoverFixWin');

    $doc.on('mouseenter.acHoverFix mouseover.acHoverFix', '.ac-hover-root, .notsi .npf-box, .notsi .inf2, .notsi a', function(){
      clearTimeout(hoverTimer);

      var $root = $(this).closest('.ac-hover-root');
      if($root.length) activateHover($root);
    });

    $doc.on('mouseleave.acHoverFix', '.ac-hover-root', function(e){
      var rootEl = this;
      var rel = e.relatedTarget;

      if(rel && $(rel).closest('.ac-hover-root, .notsi, .npf-box, .inf2').length) return;

      clearTimeout(hoverTimer);

      hoverTimer = setTimeout(function(){
        $(rootEl).removeClass('ac-hover-on');

        var $post = $(rootEl).closest('.posts');
        $post.removeClass('ac-hover-on');

        if(activeRoot === rootEl){
          activeRoot = null;
          activePost = null;
        }
      }, 110);
    });

    $doc.on('click.acHoverFix', '.notsi .npf-reblog, .notsi [data-ac-reblog]', function(e){
      var href = $(this).attr('href');
      if(!href || href === '#') e.preventDefault();
    });

    $doc.on('click.acHoverFix', '.notsi .npf-permalink, .notsi [data-ac-permalink]', function(e){
      var href = $(this).attr('href');
      if(!href || href === '#') e.preventDefault();
    });

    $doc.on('click.acHoverFix', '.notsi .npf-lightbox, .notsi [data-ac-lightbox]', function(e){
      e.preventDefault();
      e.stopPropagation();

      var $post = $(this).closest('.posts');
      if($post.length) openTumblrLightboxFromPost($post);
    });

    $win.on('resize.acHoverFixWin', throttle(function(){
      processUnprocessedPosts();
      relayoutSoon();
    }, 120));

    $win.on('blur.acHoverFixWin', function(){
      clearActiveHover();
    });

    document.addEventListener('visibilitychange', function(){
      if(document.hidden) clearActiveHover();
    }, { passive:true });

    document.addEventListener('touchstart', function(){
      clearActiveHover();
    }, { passive:true });
  }

  function appendNewPosts($new){
    if(!$new || !$new.length) return;

    isLoadingMore = true;
    clearActiveHover();

    $new = $new.filter('.posts').add($new.find('.posts'));

    if(!$new.length){
      isLoadingMore = false;
      return;
    }

    $new.removeClass('ac-hover-on');
    $new.css({
      opacity:'1',
      visibility:'visible',
      display:'block'
    });

    $container.append($new);

    processPosts($new);

    if($.fn.imagesLoaded){
      $new.imagesLoaded(function(){
        processPosts($new);

        if($.fn.masonry){
          safe(function(){
            $container.masonry('appended', $new, true);
            $container.masonry('reloadItems');
            $container.masonry('layout');
          });
        }

        forceVisible($new);
        relayoutSoon();

        setTimeout(function(){
          processPosts($new);
          forceVisible($new);
          relayout();
          isLoadingMore = false;
        }, 500);
      });
    } else {
      if($.fn.masonry){
        safe(function(){
          $container.masonry('appended', $new, true);
          $container.masonry('reloadItems');
          $container.masonry('layout');
        });
      }

      forceVisible($new);
      relayoutSoon();

      setTimeout(function(){
        processPosts($new);
        forceVisible($new);
        relayout();
        isLoadingMore = false;
      }, 650);
    }
  }

  function initInfiniteScrollIfPresent(){
    if(!$.fn.infinitescroll) return;
    if(!document.getElementById('next')) return;
    if(!document.getElementById('pagination')) return;

    $container.infinitescroll({
      navSelector:'#pagination',
      nextSelector:'#next',
      itemSelector:'.posts',
      loading:{
        selector:'#infscr-loading',
        img:'',
        msgText:'',
        finishedMsg:''
      },
      bufferPx:1200,
      appendCallback:false
    }, function(newElements){
      appendNewPosts($(newElements));
    });
  }

  $(document).ready(function(){
    processPosts($(document));
    bindHoverEvents();
    initInfiniteScrollIfPresent();

    forceVisible($('.posts'));

    safe(function(){
      if($.fn.masonry){
        $container.masonry('reloadItems');
        $container.masonry('layout');
      }
    });

    setTimeout(function(){
      processUnprocessedPosts();
      forceVisible($('.posts'));
      relayout();
    }, 700);

    setTimeout(function(){
      processUnprocessedPosts();
      forceVisible($('.posts'));
      relayout();
    }, 1600);

    setTimeout(function(){
      processUnprocessedPosts();
      forceVisible($('.posts'));
      relayout();
    }, 2800);
  });

})(window.jQuery);
</script>
