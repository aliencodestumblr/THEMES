/* ---------------- PERMALINK DO POST (INFERIOR) ---------------- */
{block:IndexPage}

.post-footer{
  margin-top:10px;
  width:100%;

  display:flex;
  align-items:center;
  justify-content:space-between;

  padding:7px 8px!important;

  background:
    linear-gradient(180deg, #fff 0%, #f7f7f7 100%)!important;

  border:1px solid rgba(0,0,0,.10)!important;
  border-radius:3px!important;

  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.9),
    0 8px 18px rgba(0,0,0,.035)!important;

  box-sizing:border-box;
}

.pf-left,
.pf-right{
  display:flex;
  align-items:center;
  margin:0!important;
  padding:0!important;
}

.pf-right{
  gap:5px;
}

.pf-notes{
  height:19px;

  display:flex;
  align-items:center;
  gap:5px;

  padding:0 7px!important;

  background:rgba(0,0,0,.035)!important;
  border:1px solid rgba(0,0,0,.07)!important;
  border-radius:2px!important;

  text-decoration:none!important;

  font-family:"Rajdhani",sans-serif;
  font-size:8px;
  font-weight:800;
  letter-spacing:1.15px;
  text-transform:uppercase;

  color:rgba(0,0,0,.48);

  transition:
    background .2s ease,
    border-color .2s ease,
    color .2s ease,
    transform .2s ease;
}

.pf-num{
  color:#111;
  font-size:9px;
  font-weight:900;
}

.pf-lab{
  color:rgba(0,0,0,.38);
}

.pf-btn{
  width:20px!important;
  height:20px!important;

  display:flex;
  align-items:center;
  justify-content:center;

  padding:0!important;
  margin:0!important;

  background:rgba(0,0,0,.035)!important;
  border:1px solid rgba(0,0,0,.07)!important;
  border-radius:2px!important;

  color:rgba(0,0,0,.48);

  text-decoration:none!important;

  transition:
    background .2s ease,
    border-color .2s ease,
    color .2s ease,
    transform .2s ease;
}

.pf-btn svg{
  width:10px!important;
  height:10px!important;
  display:block!important;
}

.pf-notes:hover,
.pf-btn:hover{
  background:#111!important;
  border-color:#111!important;
  color:#fff!important;
  transform:translateY(-1px);
}

.pf-notes:hover .pf-num,
.pf-notes:hover .pf-lab{
  color:#fff!important;
}

.pf-btn:hover svg{
  stroke:#fff!important;
}

.pf-btn:active,
.pf-notes:active{
  transform:scale(.94);
}

.post-footer *,
.post-footer *::before,
.post-footer *::after{
  box-sizing:border-box;
}

{/block:IndexPage}

