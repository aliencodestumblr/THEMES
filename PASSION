}

.sidebar {
  position: absolute;
  top: 50px;
  left: 50%;
  transform: translateX(-50%);
  width: 100%;
  max-width: 780px;    
  z-index: 999999;
  box-sizing: border-box;

  display: flex;
  flex-direction: row; 
