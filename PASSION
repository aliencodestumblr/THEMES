/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
.notsi {
  --ac-bg: rgba(255, 255, 255, 0.85);
  --ac-bg-hover: #111111;
  --ac-text: #4a4a4a;
  --ac-text-hover: #ffffff;
  --ac-border: rgba(255, 255, 255, 0.6);
  --ac-shadow: 0 4px 14px rgba(0, 0, 0, 0.08), 0 1px 2px rgba(0, 0, 0, 0.04);
  --ac-shadow-hover: 0 8px 20px rgba(0, 0, 0, 0.2);
  --ac-easing: cubic-bezier(0.34, 1.56, 0.64, 1);
}

.notsi .npf-box {
  position: absolute;
  right: 12px;
  bottom: 12px;
  z-index: 10;
  pointer-events: none;
}

.notsi .inf2 {
  display: flex;
  align-items: center;
  gap: 6px;
  opacity: 0;
  transform: translateY(10px);
  pointer-events: auto;
  transition: opacity 0.3s ease, transform 0.3s var(--ac-easing);
}

.notsi .inf2 a {
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 !important;
  margin: 0 !important;

  background: var(--ac-bg);
  color: var(--ac-text);
  border: 1px solid var(--ac-border);
  border-radius: 50%;
  text-decoration: none !important;

  box-shadow: var(--ac-shadow);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);

  opacity: 0;
  transform: translateY(12px) scale(0.85);

  transition: 
    opacity 0.3s ease,
    transform 0.35s var(--ac-easing),
    background-color 0.2s ease,
    color 0.2s ease,
    border-color 0.2s ease,
    box-shadow 0.2s ease;
}

.notsi .inf2 a:nth-child(1) { transition-delay: 0.03s; }
.notsi .inf2 a:nth-child(2) { transition-delay: 0.07s; }
.notsi .inf2 a:nth-child(3) { transition-delay: 0.11s; }

.notsi .inf2 i {
  font-size: 14px;
  line-height: 1;
  transition: transform 0.2s ease;
}

.notsi .inf2 .rb-icon {
  width: 13px;
  height: 13px;
  transition: transform 0.2s ease;
}

.notsi .inf2 .rb-icon path {
  fill: none;
  stroke: currentColor;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.notsi .ac-label,
.notsi .inf2 a::before,
.notsi .inf2 a::after {
  display: none !important;
}

.notsi .inf2 a:hover {
  color: var(--ac-text-hover);
  background: var(--ac-bg-hover);
  border-color: var(--ac-bg-hover);
  box-shadow: var(--ac-shadow-hover);
  transform: translateY(-3px) scale(1.05);
}

.notsi .inf2 a:hover i,
.notsi .inf2 a:hover .rb-icon {
  transform: scale(1.1);
}

.notsi .inf2 a:active {
  transform: translateY(-1px) scale(0.96);
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2 {
  opacity: 1;
  transform: translateY(0);
}

.post:hover .notsi .inf2 a,
.ac-hover-on .notsi .inf2 a {
  opacity: 1;
  transform: translateY(0) scale(1);
}

