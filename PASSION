  background: var(--accent-color);      
  padding: 4px 8px;
  display: flex;
  align-items: center;      
  gap: 6px;
  line-height: 1;
  border-radius: 2px;
}

.sb-live-indicator span {
  font-family: "Rajdhani", sans-serif;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 1px;
  color: #ffffff !important; 
  text-transform: uppercase;
  margin-top:1px;
}

.sb-live-dot {
  width: 4px;
  height: 4px;
  background: #ffffff;
  position: relative;
  border-radius: 50%;
}

.sb-live-dot::after {
  content: '';
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: #ffffff;
  border-radius: 50%;
  animation: cleanPulse 2s infinite ease-in-out;
}

@keyframes cleanPulse {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(3.5); opacity: 0; }
}

.sb-content-deck {
  flex-grow: 1;
  box-sizing: border-box;
  
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 15px;
}

