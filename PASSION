<script>
document.addEventListener("DOMContentLoaded", function () {
  function cleanNoteCounts(scope) {
    (scope || document).querySelectorAll(".npf-notes[data-ac-notes]").forEach(function(el) {
      var raw = (el.textContent || "").trim();
      var match = raw.match(/[\d.,]+(?:[KMB])?/i);
      if (match) {
        el.textContent = match[0];
      }
    });
  }

  cleanNoteCounts();

  var observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
      if (mutation.type === "childList") {
        mutation.addedNodes.forEach(function(node) {
          if (node.nodeType === 1) cleanNoteCounts(node);
        });
      }
      if (mutation.type === "characterData") {
        cleanNoteCounts(mutation.target.parentNode);
      }
    });
  });

  observer.observe(document.body, {
    subtree: true,
    childList: true,
    characterData: true
  });
});
</script>


