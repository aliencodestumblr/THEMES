<script>
(function($){
  if(!window.jQuery) return;

  var $win = $(window);
  var $doc = $(document);
  var $container = $('#posts');
  if(!$container.length) return;

  if($container.data('acInitDone') === 1) return;
  $container.data('acInitDone', 1);

  var layoutTimer = null;
  var scanTimer = null;
  var mutationObserver = null;
  var activeRoot = null;
  var activePost = null;

  $('#ac-hover-script-safety').remove();

  $('<style id="ac-hover-script-safety">' +
    '#posts{position:relative!important;}' +
    '#posts > .posts{position:absolute;z-index:1;box-sizing:border-box;}' +
    '#posts > .posts.ac-hover-on{z-index:50!important;}' +
    '.ac-hover-root{position:relative;z-index:2;}' +
    '.ac-hover-root.ac-hover-on{z-index:60!important;}' +
    '.posts.ac-prep{visibility:hidden!important;opacity:0!important;pointer-events:none!important;z-index:-1!important;}' +
    '.posts.is-ready{visibility:visible;opacity:1;pointer-events:auto;}' +
  '</style>').appendTo('head');

  function safe(fn){ try{ fn(); }catch(e){} }

  function throttle(fn, wait){
    var t = null;
    return function(){
      if(t) return;
      t = setTimeout(function(){
        t = null;
        fn();
      }, wait);
    };
  }

  function clearActiveHover(){
    $('.posts.ac-hover-on, .ac-hover-root.ac-hover-on').removeClass('ac-hover-on');
    activeRoot = null;
    activePost = null;
  }

  function clearDeadHover(){
    if(activeRoot && !document.documentElement.contains(activeRoot)){
      clearActiveHover();
      return;
    }

    if(activePost && !document.documentElement.contains(activePost)){
      clearActiveHover();
    }
  }

  function hasTumblrMediaUrl(str){
    str = (str || '').toLowerCase();
    return (
      str.indexOf('64.media.tumblr.com') !== -1 ||
      str.indexOf('va.media.tumblr.com') !== -1 ||
      str.indexOf('media.tumblr.com') !== -1
    );
  }

  function inThemeChrome($el){
    return $el.closest('#sidebar, #topbar, .sb-icon, .brand-icon, .sb-card, .cc, #ltop').length > 0;
  }

  function inPXUPhotoset($el){
    return $el.closest('.photo-slideshow, .pxu-photo, .photo-data').length > 0;
  }

  function looksLikeNPFImage($img){
    if(!$img || !$img.length) return false;
    if(inThemeChrome($img) || inPXUPhotoset($img)) return false;

    var src = $img.attr('src') || '';
    var srcset = $img.attr('srcset') || '';
    var dataSrc = $img.attr('data-src') || '';

    if(hasTumblrMediaUrl(src) || hasTumblrMediaUrl(srcset) || hasTumblrMediaUrl(dataSrc)) return true;

    if($img.closest('figure.tmblr-full, .tmblr-full, .npf_image, .npf_row, .npf_col, .reblog-list').length) return true;

    var $pic = $img.closest('picture');

    if($pic.length){
      var ok = false;

      $pic.find('source').each(function(){
        if(hasTumblrMediaUrl($(this).attr('srcset') || '')) ok = true;
      });

      if(ok) return true;
    }

    return false;
  }

  function looksLikeNPFVideo($node){
    if(!$node || !$node.length) return false;
    if(inPXUPhotoset($node)) return false;

    if($node.is('.npf_video_container, .npf_video, video')) return true;

    if($node.is('iframe')){
      var s = $node.attr('src') || '';

      return (
        s.indexOf('tumblr.com/video') !== -1 ||
        s.indexOf('youtube.com') !== -1 ||
        s.indexOf('vimeo.com') !== -1
      );
    }

    return false;
  }

  function scopePosts($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    return $scope.filter('.posts').add($scope.find('.posts'));
  }

  function initPhotosets($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    if(!$.fn.pxuPhotoset) return;

    $scope.find('.photo-slideshow').each(function(){
      if(this._acPXUInited) return;
      this._acPXUInited = true;

      $(this).pxuPhotoset({
        lightbox:true,
        rounded:false,
        gutter:'1px',
        photoset:'.photo-slideshow',
        photoWrap:'.photo-data',
        photo:'.pxu-photo'
      });
    });
  }

  function initUnnest($scope){
    if(!$.fn.unnest) return;

    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    $posts.each(function(){
      var $post = $(this);
      if($post.data('acUnnestDone') === 1) return;

      $post.data('acUnnestDone', 1);

      $post.unnest({
        yourCaption:".caption",
        wrapName:".tumblr_parent",
        newCaptionUsername:false,
        originalPostCaptionUsername:false,
        tumblrAvatars:false,
        tumblrAvatarsName:".tumblr_avatar",
        usernameColon:false
      });
    });
  }

  function cleanupNPFMediaUrls($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);

    $scope.find('a[href]').each(function(){
      var $a = $(this);
      var hrefRaw = $a.attr('href') || '';
      var href = hrefRaw.toLowerCase();
      var txt = $.trim($a.text() || '');

      var isMedia =
        href.indexOf('64.media.tumblr.com/') !== -1 ||
        href.indexOf('va.media.tumblr.com/') !== -1 ||
        href.indexOf('media.tumblr.com/') !== -1;

      if(!isMedia) return;

      if(txt && ($.trim(hrefRaw) === txt || $.trim(href) === txt.toLowerCase()) && $a.children().length === 0){
        var $p = $a.closest('p');
        if($p.length && $.trim($p.text()) === txt) $p.remove();
        else $a.remove();
      }
    });
  }

  function killFloatingPermalinkIcons($post, permalink){
    if(!$post || !$post.length || !permalink) return;

    $post.find('a[href]').each(function(){
      var $a = $(this);
      if($a.closest('.notsi').length) return;

      var href = $a.attr('href') || '';
      if(!href) return;

      var isSame =
        href === permalink ||
        href.indexOf(permalink) !== -1 ||
        permalink.indexOf(href) !== -1;

      if(!isSame) return;

      var txt = $.trim($a.text() || '');
      var hasIcon = $a.find('svg, img').length > 0;

      if(hasIcon && txt.length <= 1) $a.remove();
    });
  }

  function commonAncestor(nodes, stopAt){
    if(!nodes || !nodes.length) return null;
    if(nodes.length === 1) return nodes[0];

    var paths = [];
    var minLen = Infinity;

    for(var i=0;i<nodes.length;i++){
      var path = [];
      var n = nodes[i];

      while(n && n.nodeType === 1){
        path.unshift(n);
        if(n === stopAt) break;
        n = n.parentNode;
      }

      paths.push(path);
      if(path.length < minLen) minLen = path.length;
    }

    var lastCommon = null;

    for(var j=0;j<minLen;j++){
      var test = paths[0][j];
      var same = true;

      for(var k=1;k<paths.length;k++){
        if(paths[k][j] !== test){
          same = false;
          break;
        }
      }

      if(same) lastCommon = test;
      else break;
    }

    return lastCommon;
  }

  function countNPFMedia($scope){
    if(!$scope || !$scope.length) return 0;

    var imgCount = $scope.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).length;

    var vidCount = $scope.find('video, iframe, .npf_video_container, .npf_video').filter(function(){
      return looksLikeNPFVideo($(this));
    }).length;

    return imgCount + vidCount;
  }

  function cleanHoverTarget($candidate, $post){
    if(!$candidate || !$candidate.length) return $();

    if($candidate.is('a, img, picture, source')){
      var $better = $candidate.closest('.npf_photoset, .npf_grid, .npf_container, .npf_group, .npf_row, figure.tmblr-full, .tmblr-full, .npf_image, div');
      if($better.length && $better[0] !== $post[0]) return $better.first();
    }

    if($candidate.is('.posts')) return $post;

    return $candidate.first();
  }

  function tightenNPFHoverTarget($target){
    if(!$target || !$target.length) return $();

    var $t = $target.first();

    if($t.is('.npf_container, .npf_grid, .npf_photoset, .npf_group, .npf_row, .npf_col')){
      var totalMedia = countNPFMedia($t);

      if(totalMedia <= 1){
        var $tightSingle = $t.find('figure.tmblr-full, .tmblr-full, .npf_image, .npf_video_container, .npf_video').filter(function(){
          return countNPFMedia($(this)) > 0;
        }).first();

        if($tightSingle.length) return $tightSingle;
      }

      var $sameCountChild = $t.find('.npf_image, figure.tmblr-full, .tmblr-full').filter(function(){
        return countNPFMedia($(this)) === totalMedia && totalMedia > 0;
      }).first();

      if($sameCountChild.length) return $sameCountChild;
    }

    return $t;
  }

  function pickNPFUnifiedContainer($post){
    if(!$post || !$post.length) return $();

    var postNode = $post[0];

    var $mediaBits = $post.find(
      '.npf_photoset, .npf_grid, .npf_container, .npf_group, .npf_row, .npf_col,' +
      'figure.tmblr-full, .tmblr-full, .npf_image, .npf_video_container, .npf_video'
    ).filter(function(){
      var $el = $(this);

      if(inPXUPhotoset($el)) return false;

      var hasImg = $el.find('img').filter(function(){
        return looksLikeNPFImage($(this));
      }).length > 0;

      var hasVid = $el.find('video, iframe, .npf_video_container, .npf_video').filter(function(){
        return looksLikeNPFVideo($(this));
      }).length > 0;

      return hasImg || hasVid;
    });

    if(!$mediaBits.length){
      $mediaBits = $post.find('img, video, iframe').filter(function(){
        var $el = $(this);
        return looksLikeNPFImage($el) || looksLikeNPFVideo($el);
      });
    }

    if(!$mediaBits.length) return $();

    var nodes = [];
    $mediaBits.each(function(){ nodes.push(this); });

    var ancestor = commonAncestor(nodes, postNode);
    if(!ancestor) return $();

    var $ancestor = $(ancestor);

    var $preferred = $ancestor.find('.npf_photoset, .npf_grid, .npf_container, .npf_group').filter(function(){
      return countNPFMedia($(this)) > 1;
    }).first();

    if($preferred.length){
      return tightenNPFHoverTarget(cleanHoverTarget($preferred, $post));
    }

    return tightenNPFHoverTarget(cleanHoverTarget($ancestor, $post));
  }

  function pickHoverTarget($post){
    if(!$post || !$post.length) return $();

    var $mw = $post.find('.media-wrap').first();
    if($mw.length) return $mw;

    var $old = $post.find('.photo-slideshow').first();
    if($old.length) return $old;

    var $unified = pickNPFUnifiedContainer($post);
    if($unified.length) return $unified;

    var $vid = $post.find('.npf_video_container, .npf_video, video, iframe').filter(function(){
      return looksLikeNPFVideo($(this));
    }).first();

    if($vid.length){
      var $wrap = $vid.closest('figure.tmblr-full, .tmblr-full, .npf_video_container, .npf_video').first();
      return $wrap.length ? $wrap : $vid;
    }

    var $oneBlock = $post.find('figure.tmblr-full, .tmblr-full, .npf_image, figure').filter(function(){
      var $b = $(this);
      if(inPXUPhotoset($b)) return false;

      return $b.find('img').filter(function(){
        return looksLikeNPFImage($(this));
      }).length > 0;
    }).first();

    if($oneBlock.length) return $oneBlock;

    var $img = $post.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).first();

    if($img.length){
      var $imgWrap = $img.closest('figure.tmblr-full, .tmblr-full, .npf_image, figure, div').first();
      return $imgWrap.length ? $imgWrap : $img;
    }

    return $();
  }

  function isWideNPFRoot($target){
    if(!$target || !$target.length) return false;
    return $target.is('.npf_container, .npf_grid, .npf_photoset, .npf_group, .npf_row, .npf_col');
  }

  function postNeedsRebuild($post){
    if(!$post || !$post.length) return false;

    var $root = $post.find('.ac-hover-root').first();
    var $overlay = $post.find('.notsi').first();

    if(!$root.length || !$overlay.length) return true;
    if(!$overlay.parent().is($root)) return true;

    var $wanted = pickHoverTarget($post);
    if(!$wanted.length) $wanted = $post;

    $wanted = tightenNPFHoverTarget($wanted);
    if(!$wanted.length) return false;

    return $root[0] !== $wanted[0];
  }

  function getFirstLightboxTarget($post){
    if(!$post || !$post.length) return $();

    var $target = $post.find(
      '.photo-slideshow a[href], .pxu-photo a[href], .photo-data a[href], ' +
      '.npf_image a[href], figure.tmblr-full a[href], .tmblr-full a[href], ' +
      'a[href*="media.tumblr.com"], a[href*="64.media.tumblr.com"], a[href*="va.media.tumblr.com"]'
    ).filter(function(){
      return !$(this).closest('.notsi').length;
    }).first();

    if($target.length) return $target;

    return $post.find(
      '.photo-slideshow .pxu-photo img, .photo-slideshow img, .photo-data img, ' +
      '.npf_image img, figure.tmblr-full img, .tmblr-full img, ' +
      '.npf_video_container, .npf_video, video'
    ).filter(function(){
      return !$(this).closest('.notsi').length;
    }).first();
  }

  function buildOverlayNode(){
    var tpl = document.getElementById('npf-hover-template');

    if(tpl && tpl.content && tpl.content.firstElementChild){
      return $(tpl.content.firstElementChild.cloneNode(true));
    }

    return $(
      '<div class="notsi" data-ac-hover-root>' +
        '<div class="inf">' +
          '<div class="npf-time" data-ac-time></div>' +
        '</div>' +
        '<div class="inf2">' +
          '<a class="npf-reblog" data-ac-reblog href="#"><i class="ph ph-arrows-clockwise"></i></a>' +
          '<a class="npf-permalink" data-ac-permalink href="#"><i class="ph ph-link-simple-horizontal"></i></a>' +
          '<a class="npf-lightbox" data-ac-lightbox href="#"><i class="ph ph-arrows-out"></i></a>' +
        '</div>' +
      '</div>'
    );
  }

  function unmarkIfNoMedia($post){
    $post.removeClass('has-npf-media ac-hover-on');
    $post.removeData('acHoverDone');
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-hover-root--npf-wide');

    if(activePost === $post[0] || (activeRoot && $.contains($post[0], activeRoot))){
      clearActiveHover();
    }
  }

  function addHoverOverlay($post){
    if(!$post || !$post.length) return;

    var hasOldPhotoset = $post.find('.photo-slideshow').length > 0;

    var hasImg = $post.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).length > 0;

    var hasVid = $post.find('.npf_video_container, .npf_video, video, iframe').filter(function(){
      return looksLikeNPFVideo($(this));
    }).length > 0;

    if(!(hasOldPhotoset || hasImg || hasVid)){
      unmarkIfNoMedia($post);
      return;
    }

    $post.addClass('has-npf-media');

    var perma = $post.attr('data-permalink') || '';
    if(!perma) return;

    var rb = $post.attr('data-reblogurl') || '#';
    var tm = $post.attr('data-time') || '';

    if($post.data('acHoverDone') === 1 && !postNeedsRebuild($post)) return;

    $post.removeClass('ac-hover-on');
    $post.find('.notsi').remove();
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-hover-root--npf-wide');

    var $node = buildOverlayNode();

    $node.find('.npf-time, [data-ac-time]').first().text(tm);
    $node.find('a.npf-reblog, [data-ac-reblog]').first().attr('href', rb);
    $node.find('a.npf-permalink, [data-ac-permalink]').first().attr('href', perma);
    $node.find('a.npf-lightbox, [data-ac-lightbox]').first().attr('href', '#');

    var $target = pickHoverTarget($post);
    if(!$target.length) $target = $post;

    $target = tightenNPFHoverTarget($target);

    if(($target.css('position') || 'static') === 'static'){
      $target.css('position','relative');
    }

    if(isWideNPFRoot($target)){
      $node.css({
        top:'0',
        left:'0',
        right:'1px',
        bottom:'0',
        width:'auto'
      });

      $target.addClass('ac-hover-root--npf-wide');
    }

    $target.addClass('ac-npf-media ac-hover-root').append($node);
    $post.data('acHoverDone', 1);

    killFloatingPermalinkIcons($post, perma);
  }

  function forceEager($scope){
    $scope = $scope && $scope.length ? $scope : $(document);

    $scope.find('img[loading="lazy"]').each(function(){
      try{ this.loading = 'eager'; }catch(e){}
      $(this).attr('loading','eager');
    });

    $scope.find('iframe[loading="lazy"]').each(function(){
      $(this).attr('loading','eager');
    });
  }

  function processPosts($scope){
    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    forceEager($posts);

    safe(function(){ initPhotosets($posts); });
    safe(function(){ initUnnest($posts); });
    safe(function(){ cleanupNPFMediaUrls($posts); });

    $posts.each(function(){
      addHoverOverlay($(this));
    });

    watchMediaLoads($posts);
  }

  function scanForNewPosts(){
    if(scanTimer) clearTimeout(scanTimer);

    scanTimer = setTimeout(function(){
      scanTimer = null;

      var $new = $container.children('.posts').filter(function(){
        return !$(this).data('acScanned');
      });

      if(!$new.length) return;

      $new.each(function(){
        $(this).data('acScanned', 1);
      });

      hidePosts($new);
      processPosts($new);

      if($.fn.imagesLoaded){
        $new.imagesLoaded(function(){
          showPosts($new);
          layoutPosts();
          runSettledLayouts($new);
        });
      } else {
        showPosts($new);
        layoutPosts();
        runSettledLayouts($new);
      }
    }, 90);
  }

  function processUnprocessedPosts(){
    var $todo = $container.children('.posts').filter(function(){
      return !$(this).data('acHoverDone') && !$(this).data('acNoHoverScan');
    });

    if(!$todo.length) return;
    processPosts($todo);
  }

  function rebuildUnstablePosts($scope){
    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    var $bad = $posts.filter(function(){
      return postNeedsRebuild($(this));
    });

    if($bad.length) processPosts($bad);
  }

  function getPostWidth(containerWidth){
    return containerWidth / 5;
  }

  function getColumnCount(containerWidth, itemWidth){
    return 5;
  }

  function layoutPosts(){
    var $items = $container.children('.posts');
    if(!$items.length) return;

    clearDeadHover();

    var containerWidth =
      Math.round($container.width()) ||
      Math.round($container.parent().width()) ||
      Math.round($win.width());

    var itemWidth = getPostWidth(containerWidth);
    var cols = getColumnCount(containerWidth, itemWidth);

    var heights = [];
    for(var i=0; i<cols; i++) heights[i] = 0;

    $container.css({
      position:'relative',
      height:''
    });

    $items.each(function(){
      var $item = $(this);

      $item.css({
        position:'absolute',
        display:'block',
        width: itemWidth + 'px'
      });

      var shortest = 0;
      for(var c=1; c<cols; c++){
        if(heights[c] < heights[shortest]) shortest = c;
      }

      var itemHeight =
        Math.ceil($item.outerHeight(true)) ||
        Math.ceil(this.getBoundingClientRect().height) ||
        1;

      var left = shortest * itemWidth;
      var top = heights[shortest];

      $item.css({
        left:left + 'px',
        top:top + 'px',
        zIndex:1
      });

      heights[shortest] += itemHeight;
    });

    var maxHeight = 0;
    for(var j=0; j<heights.length; j++){
      if(heights[j] > maxHeight) maxHeight = heights[j];
    }

    $container.css('height', Math.ceil(maxHeight) + 'px');
  }

  function requestLayout(){
    if(layoutTimer) clearTimeout(layoutTimer);

    layoutTimer = setTimeout(function(){
      layoutTimer = null;
      layoutPosts();
    }, 90);
  }

  function hidePosts($posts){
    if(!$posts || !$posts.length) return;

    $posts
      .removeClass('is-ready ac-hover-on')
      .addClass('ac-prep')
      .css({
        visibility:'hidden',
        opacity:0,
        pointerEvents:'none',
        zIndex:-1
      });
  }

  function showPosts($posts){
    if(!$posts || !$posts.length) return;

    $posts
      .removeClass('ac-prep ac-hover-on')
      .addClass('is-ready')
      .css({
        visibility:'',
        opacity:'',
        pointerEvents:'',
        zIndex:1
      });
  }

  function layoutAndReveal($posts){
    processPosts($posts);

    function reveal(){
      showPosts($posts);
      layoutPosts();

      setTimeout(function(){ layoutPosts(); }, 180);
      setTimeout(function(){ layoutPosts(); }, 700);
      setTimeout(function(){ layoutPosts(); }, 1400);
    }

    if($.fn.imagesLoaded){
      $posts.imagesLoaded(function(){
        reveal();
      });
    } else {
      reveal();
    }
  }

  function watchMediaLoads($items){
    if(!$items || !$items.length) return;

    $items.find('img').each(function(){
      if(this._acHoverWatchBound) return;
      this._acHoverWatchBound = true;

      this.addEventListener('load', requestLayout, false);
      this.addEventListener('error', requestLayout, false);
    });

    $items.find('iframe').each(function(){
      if(this._acHoverWatchBound) return;
      this._acHoverWatchBound = true;

      this.addEventListener('load', requestLayout, false);
    });
  }

  function runSettledLayouts($scope){
    var delays = [180, 500, 1000, 1800];

    for(var i=0; i<delays.length;i++){
      setTimeout(function(){
        if($scope && $scope.length){
          rebuildUnstablePosts($scope);
        }

        layoutPosts();
      }, delays[i]);
    }
  }

  function bindHoverEvents(){
    $doc.off('.acHoverFix');
    $win.off('.acHoverFixWin');

    $doc.on('mouseenter.acHoverFix', '.ac-hover-root', function(){
      var $root = $(this);
      var $post = $root.closest('.posts');

      if(!$post.length || $post.hasClass('ac-prep')) return;

      clearActiveHover();

      activeRoot = this;
      activePost = $post[0];

      $root.addClass('ac-hover-on');
      $post.addClass('ac-hover-on');
    });

    $doc.on('mouseleave.acHoverFix', '.ac-hover-root', function(e){
      var rel = e.relatedTarget;

      if(rel && $(rel).closest('.notsi').length) return;
      if(rel && $(rel).closest('.ac-hover-root').length) return;

      var $root = $(this);
      var $post = $root.closest('.posts');

      $root.removeClass('ac-hover-on');

      if($post.length){
        $post.removeClass('ac-hover-on');
      }

      if(activeRoot === this){
        activeRoot = null;
        activePost = null;
      }
    });

    $doc.on('mouseenter.acHoverFix', '.notsi', function(){
      var $root = $(this).parent('.ac-hover-root');
      var $post = $root.closest('.posts');

      if(!$root.length || !$post.length || $post.hasClass('ac-prep')) return;

      activeRoot = $root[0];
      activePost = $post[0];

      $root.addClass('ac-hover-on');
      $post.addClass('ac-hover-on');
    });

    $doc.on('mouseleave.acHoverFix', '.notsi', function(e){
      var $root = $(this).parent('.ac-hover-root');
      var rel = e.relatedTarget;

      if($root.length && rel && $root[0].contains(rel)) return;
      if(rel && $(rel).closest('.ac-hover-root').length) return;

      if($root.length){
        var $post = $root.closest('.posts');

        $root.removeClass('ac-hover-on');

        if($post.length){
          $post.removeClass('ac-hover-on');
        }

        if(activeRoot === $root[0]){
          activeRoot = null;
          activePost = null;
        }
      }
    });

    $doc.on('click.acHoverFix', '.notsi .npf-lightbox, .notsi [data-ac-lightbox]', function(e){
      e.preventDefault();
      e.stopPropagation();

      var $post = $(this).closest('.posts');

      if(!$post.length){
        $post = $(this).closest('.ac-hover-root').closest('.posts');
      }

      if(!$post.length) return;

      var $target = getFirstLightboxTarget($post);
      if(!$target.length) return;

      $target[0].dispatchEvent(new MouseEvent('click', {
        bubbles:true,
        cancelable:true,
        view:window
      }));

      setTimeout(function(){
        var wrap =
          $target.closest('.pxu-photo')[0] ||
          $target.closest('.photo-data')[0] ||
          $target.closest('.npf_image, figure.tmblr-full, .tmblr-full')[0];

        if(wrap){
          wrap.dispatchEvent(new MouseEvent('click', {
            bubbles:true,
            cancelable:true,
            view:window
          }));
        }
      }, 0);
    });

    $win.on('scroll.acHoverFixWin', throttle(function(){
      clearDeadHover();
      scanForNewPosts();
    }, 160));

    $doc.on('wheel.acHoverFix touchmove.acHoverFix', throttle(function(){
      clearDeadHover();
    }, 160));

    $win.on('resize.acHoverFixWin', throttle(function(){
      requestLayout();
    }, 220));

    $win.on('blur.acHoverFixWin', function(){
      clearActiveHover();
    });

    document.addEventListener('visibilitychange', function(){
      if(document.hidden) clearActiveHover();
    }, { passive:true });

    document.addEventListener('touchstart', function(){
      clearActiveHover();
    }, { passive:true });

    document.addEventListener('pointercancel', function(){
      clearActiveHover();
    }, { passive:true });
  }

  function initMutationObserver(){
    if(!window.MutationObserver) return;

    if(mutationObserver){
      try{ mutationObserver.disconnect(); }catch(e){}
    }

    mutationObserver = new MutationObserver(function(mutations){
      var found = false;

      for(var i=0;i<mutations.length;i++){
        if(mutations[i].addedNodes && mutations[i].addedNodes.length){
          found = true;
          break;
        }
      }

      if(found) scanForNewPosts();
    });

    try{
      mutationObserver.observe($container[0], {
        childList:true,
        subtree:false
      });
    }catch(e){}
  }

  function initInfiniteScrollIfPresent(){
    if(!$.fn.infinitescroll) return;
    if(!document.getElementById('next')) return;
    if(!document.getElementById('pagination')) return;

    $container.infinitescroll({
      navSelector:'#pagination',
      nextSelector:'#next',
      itemSelector:'.posts',
      loading:{
        selector:'#infscr-loading',
        img:'',
        msgText:'',
        finishedMsg:''
      },
      bufferPx:1200,
      appendCallback:false
    }, function(newElements){
      var $new = $(newElements).filter('.posts');

      if(!$new.length){
        $new = $(newElements).find('.posts');
      }

      if(!$new.length) return;

      $new.each(function(){
        $(this).data('acScanned', 1);
      });

      $new
        .removeClass('is-ready ac-hover-on')
        .addClass('ac-prep')
        .css({
          visibility:'hidden',
          opacity:0,
          pointerEvents:'none',
          display:'block',
          position:'absolute',
          left:'-99999px',
          top:'0',
          zIndex:-1
        });

      $container.append($new);

      forceEager($new);
      layoutAndReveal($new);
      runSettledLayouts($new);
    });
  }

  $(document).ready(function(){
    $container.css('position','relative');

    var $initial = $container.children('.posts');

    $initial.each(function(){
      $(this).data('acScanned', 1);
    });

    hidePosts($initial);

    bindHoverEvents();
    initMutationObserver();

    forceEager($initial);
    layoutAndReveal($initial);
    initInfiniteScrollIfPresent();
    runSettledLayouts($initial);

    setTimeout(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($initial);
      showPosts($initial);
      layoutPosts();
    }, 800);

    setTimeout(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($initial);
      showPosts($initial);
      layoutPosts();
    }, 1800);

    setTimeout(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($initial);
      showPosts($initial);
      layoutPosts();
    }, 3000);
  });

})(window.jQuery);
</script>
