}

.title {
  position: relative;
  font-family: "Rajdhani", sans-serif;
  font-size: 42px; 
  font-weight: 700;
  letter-spacing: -0.5px;
  margin: 0;
  line-height: 0.95;
  text-transform: uppercase;
  color: var(--accent-color);
  display: inline-block;
  align-self: flex-start; 
}

.title i {
  font-style: normal;
  position: relative;
  display: block;
}

.title i::before,
.title i::after {
  content: "{Title}";
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--edit-bg);
}

.title i::before {
  color: var(--accent-color);
  text-shadow: 1px 0px var(--glitch-color-1);
  animation: clean-glitch-1 4s infinite steps(1) alternate-reverse;
}

.title i::after {
  color: var(--accent-color);
  text-shadow: -1px 0px var(--glitch-color-2);
  animation: clean-glitch-2 4s infinite steps(1) alternate-reverse;
}

.inf {
  font-family: "Rajdhani", sans-serif;
  color: var(--edit-text);
  font-size: 13px;
  font-weight: 500;
  line-height: 1.4;
  max-width: 650px;
  opacity: 0.8;
}

nav {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap; 
  align-items: center;
  gap: 20px 30px;  
  margin: 0;
  padding: 0;
  counter-reset: nav-counter; 
}

nav a {
  position: relative;
  display: inline-flex;
  align-items: center;
  color: var(--edit-text);
  text-decoration: none;
  font-family: "Rajdhani", sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px; 
  opacity: 0.5;
  padding: 4px 0;
  
  transition: opacity 0.3s ease, color 0.3s ease, transform 0.3s ease;
}

nav a::before {
  counter-increment: nav-counter;
  content: "0" counter(nav-counter) " /";
  font-size: 9px;
  font-weight: 500;
  margin-right: 8px;
  opacity: 0.6;
  letter-spacing: 0px;
  display: inline-block;
  transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.3s ease;
}

nav a::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--accent-color, #000000);
  transition: width 0.3s cubic-bezier(0.25, 1, 0.5, 1);
}

nav a:hover {
  opacity: 1;
  color: var(--accent-color, #000000);
  transform: translateX(4px); 
}

nav a:hover::before {
  opacity: 1;
  transform: translateX(-4px); 
}

nav a:hover::after {
  width: 100%;
}

nav a[href="/dashboard"] {
  opacity: 0.35;
  font-weight: 500;
}
nav a[href="/dashboard"]::before {
  content: "→"; 
}

@keyframes clean-glitch-1 {
  0%, 92% { clip-path: inset(0 0 100% 0); }
  93% { clip-path: inset(20% 0 60% 0); transform: translateX(2px); }
  95% { clip-path: inset(50% 0 30% 0); transform: translateX(-1px); }
  97%, 100% { clip-path: inset(0 0 100% 0); }
}

@keyframes clean-glitch-2 {
  0%, 91% { clip-path: inset(0 0 100% 0); }
  92% { clip-path: inset(10% 0 80% 0); transform: translateX(-2px); }
  94% { clip-path: inset(70% 0 15% 0); transform: translateX(1px); }
  96%, 100% { clip-path: inset(0 0 100% 0); }
}

