  opacity:.72;

  transition:
    opacity .55s cubic-bezier(.22,1,.36,1);
}

blockquote video{
  cursor: url(https://cur.cursors-4u.net/cursors/cur-9/cur817.cur), auto;
  width:100%;
  display:block;
}

img{
  cursor: url(https://cur.cursors-4u.net/cursors/cur-9/cur817.cur), auto;
  border:0;
  width:100%;
  height:auto;
  display:block;

  opacity:.72;

  transition:
    opacity .55s cubic-bezier(.22,1,.36,1);
}

video{
  display:block;
  margin:0 auto!important;
  padding:0!important;
}

.posts:hover img,
.posts:hover blockquote img{
