<script>
(function($){
  if(!window.jQuery) return;

  $(document).off('click.acDirectLightbox');

  $(document).on('click.acDirectLightbox', '.notsi .npf-lightbox, .notsi [data-ac-lightbox]', function(e){
    e.preventDefault();
    e.stopPropagation();

    var $post = $(this).closest('.posts');
    if(!$post.length) $post = $(this).closest('.ac-hover-root').closest('.posts');
    if(!$post.length) return;

    var imgs = [];

    $post.find('.media-wrap img, .photo-slideshow img, .pxu-photo img, .npf_image img, figure.tmblr-full img, .tmblr-full img').each(function(){
      var $img = $(this);
      if($img.closest('.notsi').length) return;

      var high =
        $img.attr('data-highres') ||
        $img.attr('data-src') ||
        $img.closest('a[href]').attr('href') ||
        $img.attr('src');

      var low = $img.attr('src') || high;

      if(!high) return;

      imgs.push({
        width: parseInt($img.attr('data-width'),10) || this.naturalWidth || this.width || 1280,
        height: parseInt($img.attr('data-height'),10) || this.naturalHeight || this.height || 1280,
        low_res: low,
        high_res: high
      });
    });

    if(imgs.length && window.Tumblr && Tumblr.Lightbox && typeof Tumblr.Lightbox.init === 'function'){
      Tumblr.Lightbox.init(imgs);
      $('body').addClass('tumblr_lightbox_active');
    }
  });

})(jQuery);
</script>

