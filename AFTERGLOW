<script>
(function(){
  var audio = document.getElementById('audio');
  var playBtn = document.getElementById('music-toggle');
  var nextBtn = document.getElementById('music-next');
  var nameEl = document.getElementById('track-name');
  var artistEl = document.getElementById('track-artist');
  var dataEl = document.getElementById('playlist-data');

  if(!audio || !playBtn || !nextBtn || !nameEl || !artistEl || !dataEl) return;

  // Get the icon element inside the play button
  var playIcon = playBtn.querySelector('.material-icons');

  var playlist = [];
  try {
    playlist = JSON.parse(dataEl.textContent.trim());
  } catch(e) {
    playlist = [];
  }

  if(!playlist.length) return;

  var index = 0;

  function loadTrack(i, autoplay) {
    if(i < 0) i = 0;
    if(i >= playlist.length) i = 0;
    index = i;

    var track = playlist[index];
    
    // Safety check for empty sources
    if(!track.src || track.src === "" || track.src.includes("Track")) {
        console.warn("Track source missing for index: " + i);
        return;
    }

    audio.src = track.src;
    nameEl.textContent = track.title || 'Unknown Title';
    artistEl.textContent = track.artist || 'Unknown Artist';

    if(autoplay) {
      audio.play().catch(function(error) {
          console.log("Autoplay prevented or failed: ", error);
      });
    } else {
      audio.load();
      updateUI(false);
    }
  }

  function updateUI(playing) {
    if (playIcon) {
      // Swaps the Material Icon text between play and pause
      playIcon.textContent = playing ? 'pause' : 'play_arrow';
    }
  }

  function togglePlay() {
    if(audio.paused) {
      audio.play().catch(function(e){ console.error("Playback failed", e); });
    } else {
      audio.pause();
    }
  }

  function nextTrack(autoplay) {
    index = (index + 1) % playlist.length;
    loadTrack(index, autoplay);
  }

  // Listeners
  playBtn.addEventListener('click', function(e) {
    e.preventDefault();
    togglePlay();
  });

  nextBtn.addEventListener('click', function(e) {
    e.preventDefault();
    nextTrack(true);
  });

  audio.addEventListener('play', function() {
    updateUI(true);
  });

  audio.addEventListener('pause', function() {
    updateUI(false);
  });

  audio.addEventListener('ended', function() {
    nextTrack(true);
  });

  // Initial load
  loadTrack(0, false);
})();
</script>

