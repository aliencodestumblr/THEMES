}


/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */

.entry{
  width:330px;
  height:auto;
  margin:0 auto!important;

  {block:PermalinkPage}
  width:360px;
  margin:0 auto!important;
  border:0;
  {/block:PermalinkPage}
}

#posts{
  position:relative;

  width:350px;
  margin:0 auto 50px auto!important;
  transform:translateX(48px);

  padding:18px 20px 0 20px;
  box-sizing:border-box;

  {block:PermalinkPage}
  width:350px;
  margin:0 auto!important;
  transform:translateX(58px);
  {/block:PermalinkPage}
}

/* side borders */
#posts::before,
#posts::after{
  content:"";
  position:absolute;

  top:-10px;
  bottom:0;

  width:1px;
  background:rgba(0,0,0,.075);

  pointer-events:none;
  z-index:0;
}

#posts::before{
  left:0;
}

#posts::after{
  right:0;
}

.posts{
  width:300px;
  margin:0 auto 45px auto!important;
  padding:0;

  box-sizing:border-box;
  position:relative!important;
  overflow:visible!important;

  opacity:1;
  z-index:2;

  {block:PermalinkPage}
  width:300px;
  margin:0 auto 25px auto!important;
  border:0;
  {/block:PermalinkPage}
}

/* ---------------- LINHA DO USUÁRIO NO TOPO DO POST ---------------- */
.post-top{
  margin: 0 0 8px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:0px;

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  letter-spacing:1.6px;
  text-transform:uppercase;

  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}

.notsi{
    position:absolute;
    top:0px;
    left:-45px;
    
    transform:translateY(-6px);
    
    width:42px;
    height:70px;

    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;

    opacity:0;

    overflow:visible!important;
    pointer-events:none!important;

    z-index:99999999999999999!important;

    transition:
        opacity .55s cubic-bezier(.22,1,.36,1);
}

.notsi.is-open{
    opacity:1!important;
}

/* INNER WRAP */

.notsi .npf-box{
    position:relative!important;

    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;

    pointer-events:auto!important;
    z-index:99999999999999!important;
}

/* BUTTON STACK */

.notsi .inf2{
    position:relative!important;

    display:flex;
    flex-direction:column;
    gap:5px;

    pointer-events:auto!important;
}

/* invisible hover bridge */

/* invisible hover bridge */

.notsi .inf2::after{
    content:"";

    position:absolute;

    top:-12px;
    bottom:-12px;

    /* starts AFTER the buttons instead of covering them */
    left:100%;
    margin-left:0;

    width:72px;

    background:transparent!important;
    pointer-events:auto!important;

    z-index:0;
}

/* BUTTONS */

.notsi .inf2 a{
     z-index:5!important;
    position:relative!important;

    width:10px;
    height:10px;

    display:inline-flex!important;
    justify-content:center!important;
    align-items:center!important;

    background:#fff!important;

    border:3px double rgba(0,0,0,.16)!important;

    box-shadow:
        0 1px 4px rgba(0,0,0,.05)!important;

    text-decoration:none!important;

    opacity:1!important;

    color:transparent!important;
    font-size:0!important;

    pointer-events:auto!important;
    z-index:9999999999999999999!important;

    transition:
        background .28s ease,
        box-shadow .28s ease;
}

.notsi .inf2 a:hover{
    background:#f7f7f7!important;

    box-shadow:
        0 3px 8px rgba(0,0,0,.1)!important;
}

/* HIDE ICONS COMPLETELY */

.notsi .inf2 i,
.notsi .inf2 svg{
    display:none!important;
}

/* PREVENT CLIPPING */

.post,
.posts,
.entry,
article,
.media-wrap,
.tmblr-full,
figure,
.npf_row{
    overflow:visible!important;
}

/* REMOVE UNUSED ELEMENTS */

.notsi .inf,
.notsi .npf-box::before,
.notsi::before,
.notsi::after{
    display:none!important;
}

{/block:IndexPage}

/* --------- TAMANHOS DE IMAGEM + VÍDEO / NÃO ALTERAR --------- */
.posts img{
