{block:IndexPage}
<script>
(function($){
  if(!window.jQuery) return;

  var $win = $(window);
  var $doc = $(document);
  var $container = $('#posts');
  if(!$container.length) return;

  // never init twice
  if($container.data('acInitDone') === 1) return;
  $container.data('acInitDone', 1);

  var lastMouse = { x:-1, y:-1 };
  var resizeObserver = null;
  var activePost = null;
  var activeRoot = null;
  var scrollTimer = null;
  var restoreRAF = 0;
  var isScrolling = false;
  var scrollTimeout = null;
  var isLoadingMore = false;
  var layoutSettling = false;          // still used to block restore, not mouseenter
  var settlingEndTimer = null;          // timer to end settling period

  /* -----------------------------
     helpers
  ----------------------------- */
  function safe(fn){ try{ fn(); }catch(e){} }

  function throttle(fn, wait){
    var t = null;
    return function(){
      if(t) return;
      t = setTimeout(function(){
        t = null;
        fn();
      }, wait);
    };
  }

  function cancelRestoreRAF(){
    if(restoreRAF){
      cancelAnimationFrame(restoreRAF);
      restoreRAF = 0;
    }
  }

  function clearActiveHover(){
    $('.posts.ac-hover-on, .ac-hover-root.ac-hover-on').removeClass('ac-hover-on');
    activePost = null;
    activeRoot = null;
    cancelRestoreRAF();
  }

  function activateHoverForRoot($root){
    if(!$root || !$root.length) return;

    var root = $root[0];
    var $post = $root.closest('.posts.has-npf-media');
    if(!$post.length) return;

    var post = $post[0];

    if(activePost === post && activeRoot === root) return;

    clearActiveHover();

    activePost = post;
    activeRoot = root;

    $post.addClass('ac-hover-on');
    $root.addClass('ac-hover-on');
  }

  function pointerInsideElement(el, x, y){
    if(!el || x < 0 || y < 0) return false;

    var rect;
    try{
      rect = el.getBoundingClientRect();
    }catch(e){
      return false;
    }

    if(!rect) return false;

    return (
      x >= rect.left &&
      x <= rect.right &&
      y >= rect.top &&
      y <= rect.bottom
    );
  }

  function getHoverRootUnderPointer(){
    if(lastMouse.x < 0 || lastMouse.y < 0) return $();

    var el = null;
    try{
      el = document.elementFromPoint(lastMouse.x, lastMouse.y);
    }catch(e){
      el = null;
    }

    if(!el) return $();

    var $el = $(el);
    var $root = $el.closest('.ac-hover-root');
    if($root.length) return $root;

    var $overlay = $el.closest('.notsi');
    if($overlay.length){
      var $overlayRoot = $overlay.parent('.ac-hover-root');
      if($overlayRoot.length) return $overlayRoot;
    }

    return $();
  }

  function restoreHoverUnderPointer(){
    // Don't restore if we're scrolling
    if(isScrolling) return;
    
    // Don't restore if we don't have valid mouse position
    if(lastMouse.x < 0 || lastMouse.y < 0) return;
    
    // Don't restore while loading more posts or layout settling
    if(isLoadingMore || layoutSettling) return;
    
    /* keep current hover if pointer is still inside it */
    if(activeRoot && document.documentElement.contains(activeRoot)){
      if(pointerInsideElement(activeRoot, lastMouse.x, lastMouse.y)){
        var $still = $(activeRoot);
        var $stillPost = $still.closest('.posts.has-npf-media');
        if($stillPost.length){
          $stillPost.addClass('ac-hover-on');
          $still.addClass('ac-hover-on');
          return;
        }
      }
    }

    var $root = getHoverRootUnderPointer();

    if(!$root.length){
      clearActiveHover();
      return;
    }

    activateHoverForRoot($root);
  }

  function scheduleRestore(){
    cancelRestoreRAF();
    restoreRAF = requestAnimationFrame(function(){
      restoreRAF = 0;
      restoreHoverUnderPointer();
    });
  }

  function relayout(){
    if(!$.fn.masonry) return;
    safe(function(){
      $container.masonry('reloadItems');
      $container.masonry('layout');
    });
  }

  // relayout and restore, but do NOT extend settling (used for image loads etc.)
  function relayoutAndRestore(){
    relayout();
    scheduleRestore();
  }

  // relayout, restore, AND extend settling if we are still loading more posts
  function relayoutAndExtendSettling(){
    relayout();
    if(isLoadingMore) scheduleEndSettling(200); // shorter extension
    scheduleRestore();
  }

  function forceEager($scope){
    $scope = $scope && $scope.length ? $scope : $(document);

    $scope.find('img[loading="lazy"]').each(function(){
      try{ this.loading = 'eager'; }catch(e){}
      $(this).attr('loading','eager');
    });

    $scope.find('iframe[loading="lazy"]').each(function(){
      $(this).attr('loading','eager');
    });
  }

  function watchHeights($items){
    if(!$items || !$items.length) $items = $container.find('.posts');

    $items.find('img').each(function(){
      var img = this;
      if(img.complete) return;
      if(img._acHoverWatchBound) return;
      img._acHoverWatchBound = true;

      // Use relayoutAndRestore (does NOT extend settling)
      img.addEventListener('load', relayoutAndRestore, { once:false });
      img.addEventListener('error', relayoutAndRestore, { once:false });
    });

    $items.find('iframe').each(function(){
      var frame = this;
      if(frame._acHoverWatchBound) return;
      frame._acHoverWatchBound = true;

      frame.addEventListener('load', relayoutAndRestore, { once:false });
    });

    if(window.ResizeObserver){
      if(!resizeObserver){
        resizeObserver = new ResizeObserver(throttle(relayoutAndRestore, 80));
      }

      $items.each(function(){
        if(this._acHoverROBound) return;
        this._acHoverROBound = true;
        try{ resizeObserver.observe(this); }catch(e){}
      });
    } else {
      setTimeout(relayoutAndRestore, 300);
      setTimeout(relayoutAndRestore, 800);
      setTimeout(relayoutAndRestore, 1400);
      setTimeout(relayoutAndRestore, 2200);
    }
  }

  /* -----------------------------
     media detection (unchanged)
  ----------------------------- */
  function hasTumblrMediaUrl(str){
    str = (str || '').toLowerCase();
    return (
      str.indexOf('64.media.tumblr.com') !== -1 ||
      str.indexOf('va.media.tumblr.com') !== -1 ||
      str.indexOf('media.tumblr.com') !== -1
    );
  }

  function inThemeChrome($el){
    return $el.closest('#sidebar, #topbar, .sb-icon, .brand-icon, .sb-card, .cc, #ltop').length > 0;
  }

  function inPXUPhotoset($el){
    return $el.closest('.photo-slideshow, .pxu-photo, .photo-data').length > 0;
  }

  function looksLikeNPFImage($img){
    if(!$img || !$img.length) return false;
    if(inThemeChrome($img) || inPXUPhotoset($img)) return false;

    var src = ($img.attr('src') || '');
    var srcset = ($img.attr('srcset') || '');
    var dataSrc = ($img.attr('data-src') || '');

    if(hasTumblrMediaUrl(src) || hasTumblrMediaUrl(srcset) || hasTumblrMediaUrl(dataSrc)) return true;

    if($img.closest('figure.tmblr-full, .tmblr-full, .npf_image, .npf_row, .npf_col, .reblog-list').length) return true;

    var $pic = $img.closest('picture');
    if($pic.length){
      var ok = false;
      $pic.find('source').each(function(){
        if(hasTumblrMediaUrl($(this).attr('srcset') || '')) ok = true;
      });
      if(ok) return true;
    }

    return false;
  }

  function looksLikeNPFVideo($node){
    if(!$node || !$node.length) return false;
    if(inPXUPhotoset($node)) return false;

    if($node.is('.npf_video_container, .npf_video, video')) return true;

    if($node.is('iframe')){
      var s = ($node.attr('src') || '');
      return (
        s.indexOf('tumblr.com/video') !== -1 ||
        s.indexOf('youtube.com') !== -1 ||
        s.indexOf('vimeo.com') !== -1
      );
    }

    return false;
  }

  function scopePosts($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    return $scope.filter('.posts').add($scope.find('.posts'));
  }

  /* -----------------------------
     plugin inits (safe, unchanged)
  ----------------------------- */
  function initPhotosets($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    if(!$.fn.pxuPhotoset) return;

    $scope.find('.photo-slideshow').each(function(){
      var el = this;
      if(el._acPXUInited) return;
      el._acPXUInited = true;

      $(el).pxuPhotoset({
        lightbox:true,
        rounded:false,
        gutter:'1px',
        photoset:'.photo-slideshow',
        photoWrap:'.photo-data',
        photo:'.pxu-photo'
      });
    });
  }

  function initUnnest($scope){
    if(!$.fn.unnest) return;

    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    $posts.each(function(){
      var $post = $(this);
      if($post.data('acUnnestDone') === 1) return;
      $post.data('acUnnestDone', 1);

      $post.unnest({
        yourCaption:".caption",
        wrapName:".tumblr_parent",
        newCaptionUsername:false,
        originalPostCaptionUsername:false,
        tumblrAvatars:false,
        tumblrAvatarsName:".tumblr_avatar",
        usernameColon:false
      });
    });
  }

  function cleanupNPFMediaUrls($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    var hosts = ['64.media.tumblr.com/','va.media.tumblr.com/','media.tumblr.com/'];

    $scope.find('a[href]').each(function(){
      var $a = $(this);
      var hrefRaw = ($a.attr('href') || '');
      var href = hrefRaw.toLowerCase();
      var txt  = $.trim($a.text() || '');

      var isMedia = false;
      for(var i=0;i<hosts.length;i++){
        if(href.indexOf(hosts[i]) !== -1){
          isMedia = true;
          break;
        }
      }
      if(!isMedia) return;

      if(txt && ($.trim(hrefRaw) === txt || $.trim(href) === txt.toLowerCase()) && $a.children().length === 0){
        var $p = $a.closest('p');
        if($p.length && $.trim($p.text()) === txt) $p.remove();
        else $a.remove();
      }
    });
  }

  function killFloatingPermalinkIcons($post, permalink){
    if(!$post || !$post.length || !permalink) return;

    $post.find('a[href]').each(function(){
      var $a = $(this);
      if($a.closest('.notsi').length) return;

      var href = $a.attr('href') || '';
      if(!href) return;

      var isSame = (href === permalink) ||
                   (href.indexOf(permalink) !== -1) ||
                   (permalink.indexOf(href) !== -1);
      if(!isSame) return;

      var txt = $.trim($a.text() || '');
      var hasIcon = $a.find('svg, img').length > 0;

      if(hasIcon && txt === ''){
        $a.remove();
        return;
      }

      if(hasIcon && txt.length <= 1){
        $a.remove();
        return;
      }
    });
  }

  function markAsMediaPost($post){
    $post.addClass('has-npf-media');
  }

  function unmarkIfNoMedia($post){
    $post.removeClass('has-npf-media');
    $post.removeData('acHoverDone');
    $post.removeClass('ac-hover-on');
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-hover-root--npf-wide');

    if(activePost === $post[0] || (activeRoot && $.contains($post[0], activeRoot))){
      clearActiveHover();
    }
  }

  function commonAncestor(nodes, stopAt){
    if(!nodes || !nodes.length) return null;
    if(nodes.length === 1) return nodes[0];

    var paths = [];
    var minLen = Infinity;

    for(var i=0;i<nodes.length;i++){
      var path = [];
      var n = nodes[i];
      while(n && n.nodeType === 1){
        path.unshift(n);
        if(n === stopAt) break;
        n = n.parentNode;
      }
      paths.push(path);
      if(path.length < minLen) minLen = path.length;
    }

    var lastCommon = null;
    for(var j=0;j<minLen;j++){
      var test = paths[0][j];
      var same = true;
      for(var k=1;k<paths.length;k++){
        if(paths[k][j] !== test){
          same = false;
          break;
        }
      }
      if(same) lastCommon = test;
      else break;
    }

    return lastCommon;
  }

  function cleanHoverTarget($candidate, $post){
    if(!$candidate || !$candidate.length) return $();

    if($candidate.is('a, img, picture, source')){
      var $better = $candidate.closest('.npf_photoset, .npf_grid, .npf_container, .npf_group, .npf_row, figure.tmblr-full, .tmblr-full, .npf_image, div');
      if($better.length && $better[0] !== $post[0]) return $better.first();
    }

    if($candidate.is('.posts')) return $post;

    return $candidate.first();
  }

  function countNPFMedia($scope){
    if(!$scope || !$scope.length) return 0;
    var imgCount = $scope.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).length;
    var vidCount = $scope.find('video, iframe, .npf_video_container, .npf_video').filter(function(){
      return looksLikeNPFVideo($(this));
    }).length;
    return imgCount + vidCount;
  }

  function tightenNPFHoverTarget($target, $post){
    if(!$target || !$target.length) return $();

    var $t = $target.first();

    if($t.is('.npf_container, .npf_grid, .npf_photoset, .npf_group, .npf_row, .npf_col')){
      var totalMedia = countNPFMedia($t);

      if(totalMedia <= 1){
        var $tightSingle = $t.find('figure.tmblr-full, .tmblr-full, .npf_image, .npf_video_container, .npf_video').filter(function(){
          return countNPFMedia($(this)) > 0;
        }).first();

        if($tightSingle.length) return $tightSingle;
      }

      var $sameCountChild = $t.find('.npf_image, figure.tmblr-full, .tmblr-full').filter(function(){
        return countNPFMedia($(this)) === totalMedia && totalMedia > 0;
      }).first();

      if($sameCountChild.length) return $sameCountChild;
    }

    return $t;
  }

  function isWideNPFRoot($target){
    if(!$target || !$target.length) return false;
    return $target.is('.npf_container, .npf_grid, .npf_photoset, .npf_group, .npf_row, .npf_col');
  }

  function pickNPFUnifiedContainer($post){
    if(!$post || !$post.length) return $();

    var postNode = $post[0];

    var $mediaBits = $post.find(
      '.npf_photoset, .npf_grid, .npf_container, .npf_group, .npf_row, .npf_col,' +
      'figure.tmblr-full, .tmblr-full, .npf_image, .npf_video_container, .npf_video'
    ).filter(function(){
      var $el = $(this);
      if(inPXUPhotoset($el)) return false;

      var hasImg = $el.find('img').filter(function(){
        return looksLikeNPFImage($(this));
      }).length > 0;

      var hasVid = $el.find('video, iframe, .npf_video_container, .npf_video').filter(function(){
        return looksLikeNPFVideo($(this));
      }).length > 0;

      return hasImg || hasVid;
    });

    if(!$mediaBits.length){
      $mediaBits = $post.find('img, video, iframe').filter(function(){
        var $el = $(this);
        return looksLikeNPFImage($el) || looksLikeNPFVideo($el);
      });
    }

    if(!$mediaBits.length) return $();

    var nodes = [];
    $mediaBits.each(function(){ nodes.push(this); });

    var ancestor = commonAncestor(nodes, postNode);
    if(!ancestor) return $();

    var $ancestor = $(ancestor);

    var $preferred = $ancestor.find('.npf_photoset, .npf_grid, .npf_container, .npf_group').filter(function(){
      var $el = $(this);
      var imgCount = $el.find('img').filter(function(){
        return looksLikeNPFImage($(this));
      }).length;
      var vidCount = $el.find('video, iframe, .npf_video_container, .npf_video').filter(function(){
        return looksLikeNPFVideo($(this));
      }).length;
      return imgCount > 1 || vidCount > 0;
    }).first();

    if($preferred.length) return tightenNPFHoverTarget(cleanHoverTarget($preferred, $post), $post);

    return tightenNPFHoverTarget(cleanHoverTarget($ancestor, $post), $post);
  }

  /* -----------------------------
     pick hover target (unchanged)
  ----------------------------- */
  function pickHoverTarget($post){
    if(!$post || !$post.length) return $();

    var $mw = $post.find('.media-wrap').first();
    if($mw.length) return $mw;

    var $old = $post.find('.photo-slideshow').first();
    if($old.length) return $old;

    var $unified = pickNPFUnifiedContainer($post);
    if($unified.length) return $unified;

    var $vid = $post.find('.npf_video_container, .npf_video, video, iframe').filter(function(){
      return looksLikeNPFVideo($(this));
    }).first();
    if($vid.length){
      var $wrap = $vid.closest('figure.tmblr-full, .tmblr-full, .npf_video_container, .npf_video').first();
      return $wrap.length ? $wrap : $vid;
    }

    var $oneBlock = $post.find('figure.tmblr-full, .tmblr-full, .npf_image, figure').filter(function(){
      var $b = $(this);
      if(inPXUPhotoset($b)) return false;
      return $b.find('img').filter(function(){
        return looksLikeNPFImage($(this));
      }).length > 0;
    }).first();
    if($oneBlock.length) return $oneBlock;

    var $img = $post.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).first();
    if($img.length){
      var $imgWrap = $img.closest('figure.tmblr-full, .tmblr-full, .npf_image, figure, div').first();
      return $imgWrap.length ? $imgWrap : $img;
    }

    return $();
  }

  function postNeedsRebuild($post){
    if(!$post || !$post.length) return false;

    var $root = $post.find('.ac-hover-root').first();
    var $overlay = $post.find('.notsi').first();

    if(!$root.length || !$overlay.length) return true;
    if(!$overlay.parent().is($root)) return true;

    var $wanted = pickHoverTarget($post);
    if(!$wanted.length) $wanted = $post;
    $wanted = tightenNPFHoverTarget($wanted, $post);

    if(!$wanted.length) return false;

    return $root[0] !== $wanted[0];
  }

  /* -----------------------------
     build overlay node (unchanged)
  ----------------------------- */
  function buildOverlayNode(){
    var tpl = document.getElementById('npf-hover-template');
    if(tpl && tpl.content && tpl.content.firstElementChild){
      return $(tpl.content.firstElementChild.cloneNode(true));
    }

    return $(
      '<div class="notsi">' +
        '<div class="inf">Posted <div class="npf-time"></div></div>' +
        '<div class="inf2">' +
          '<a class="npf-reblog" href="#" target="_blank">reblog</a>' +
          '<a class="npf-permalink" href="#"><span class="npf-notes">notes</span></a>' +
        '</div>' +
      '</div>'
    );
  }

  /* -----------------------------
     inject overlay - with immediate hover check
  ----------------------------- */
  function addHoverOverlay($post){
    if(!$post || !$post.length) return;

    var hasOldPhotoset = $post.find('.photo-slideshow').length > 0;
    var hasImg = $post.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).length > 0;
    var hasVid = $post.find('.npf_video_container, .npf_video, video, iframe').filter(function(){
      return looksLikeNPFVideo($(this));
    }).length > 0;

    if(!(hasOldPhotoset || hasImg || hasVid)){
      unmarkIfNoMedia($post);
      return;
    }

    markAsMediaPost($post);

    var perma = $post.attr('data-permalink') || '';
    if(!perma) return;

    var rb  = $post.attr('data-reblogurl') || '#';
    var tm  = $post.attr('data-time') || '';
    var nts = ($post.attr('data-notes') || '').trim();

    // if already built and still valid, do not tear it down again
    if($post.data('acHoverDone') === 1 && !postNeedsRebuild($post)){
      return;
    }

    // remove old hover pieces before rebuilding
    if(activePost === $post[0] || (activeRoot && $.contains($post[0], activeRoot))){
      clearActiveHover();
    }

    $post.removeClass('ac-hover-on');
    $post.find('.notsi').remove();
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-hover-root--npf-wide');

    var $node = buildOverlayNode();

    $node.find('.npf-time, [data-ac-time]').first().text(tm);

    var $rbA = $node.find('a.npf-reblog, [data-ac-reblog]').first();
    if($rbA.length) $rbA.attr('href', rb);

    var $pmA = $node.find('a.npf-permalink, [data-ac-permalink]').first();
    if($pmA.length) $pmA.attr('href', perma);

    if(nts){
      $node.find('.npf-notes, [data-ac-notes]').first().text(nts);
    }

    var $target = pickHoverTarget($post);
    if(!$target.length) $target = $post;

    $target = tightenNPFHoverTarget($target, $post);

    if(($target.css('position') || 'static') === 'static'){
      $target.css('position','relative');
    }

    if(isWideNPFRoot($target)){
      $node.css({
        top: '0',
        left: '0',
        right: '1px',
        bottom: '0',
        width: 'auto'
      });
      $target.addClass('ac-hover-root--npf-wide');
    } else {
      $node.css({
        top: '',
        left: '',
        right: '',
        bottom: '',
        width: ''
      });
    }

    $target.addClass('ac-npf-media ac-hover-root').append($node);
    $post.data('acHoverDone', 1);
    $post.trigger('ac:hoverroot:rebuilt');

    killFloatingPermalinkIcons($post, perma);

    // IMMEDIATE HOVER CHECK: if mouse is inside this new root and not loading, activate now
    if (!isLoadingMore && lastMouse.x >= 0 && lastMouse.y >= 0) {
      if (pointerInsideElement($target[0], lastMouse.x, lastMouse.y)) {
        activateHoverForRoot($target);
      }
    }
  }

  function processPosts($scope){
    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    forceEager($posts);
    safe(function(){ initPhotosets($posts); });
    safe(function(){ initUnnest($posts); });
    safe(function(){ cleanupNPFMediaUrls($posts); });

    $posts.each(function(){
      addHoverOverlay($(this));
    });

    watchHeights($posts);
  }

  function processUnprocessedPosts(){
    var $todo = $container.find('.posts').filter(function(){
      return !$(this).data('acHoverDone');
    });

    if(!$todo.length) return;
    processPosts($todo);
  }

  function rebuildUnstablePosts($scope){
    var $posts = scopePosts($scope);
    if(!$posts.length) $posts = $container.find('.posts');

    var $bad = $posts.filter(function(){
      return postNeedsRebuild($(this));
    });

    if(!$bad.length) return;
    processPosts($bad);
  }

  /* -----------------------------
     Settling management
  ----------------------------- */
  function endSettling(){
    layoutSettling = false;
    isLoadingMore = false;
    // Force a hover check now that layout is stable
    restoreHoverUnderPointer();
  }

  function scheduleEndSettling(delay){
    if(settlingEndTimer) clearTimeout(settlingEndTimer);
    settlingEndTimer = setTimeout(function(){
      settlingEndTimer = null;
      endSettling();
    }, delay);
  }

  /* -----------------------------
     hover toggler - IMMEDIATE ACTIVATION & DEACTIVATION, BLOCKED DURING SCROLL
  ----------------------------- */
  function bindHoverEvents(){
    $doc.off('.acHoverFix');
    $win.off('.acHoverFixWin');

    // Track mouse position
    $doc.on('mousemove.acHoverFix', function(e){
      lastMouse.x = e.clientX;
      lastMouse.y = e.clientY;
      scheduleRestore();
    });

    // Direct hover on root elements - activation allowed even during layoutSettling, but not during scroll or loading
    $doc.on('mouseenter.acHoverFix', '.ac-hover-root', function(e){
      if(isScrolling || isLoadingMore) return;  // block during scroll or loading
      activateHoverForRoot($(this));
    });

    // IMMEDIATE deactivation on mouseleave, regardless of layoutSettling
    $doc.on('mouseleave.acHoverFix', '.ac-hover-root', function(e){
      var rel = e.relatedTarget;
      
      // If moving to something inside the notsi overlay, keep hover
      if(rel && $(rel).closest('.notsi').length) {
        return;
      }
      
      // If moving to another ac-hover-root, let that one handle activation
      if(rel && $(rel).closest('.ac-hover-root').length) {
        return;
      }
      
      // Immediate clear
      $(this).removeClass('ac-hover-on');
      var $post = $(this).closest('.posts');
      if($post.length) {
        $post.removeClass('ac-hover-on');
      }
      
      activePost = null;
      activeRoot = null;
      cancelRestoreRAF(); // prevent any pending restore
    });

    // Handle overlay hover
    $doc.on('mouseenter.acHoverFix', '.notsi', function(){
      if(isScrolling || isLoadingMore) return;
      
      var $root = $(this).parent('.ac-hover-root');
      if($root.length) {
        activateHoverForRoot($root);
      }
    });

    $doc.on('mouseleave.acHoverFix', '.notsi', function(e){
      var $root = $(this).parent('.ac-hover-root');
      var rel = e.relatedTarget;
      
      // If moving to another part of the root, keep hover
      if($root.length && rel && $root[0].contains(rel)) {
        return;
      }
      
      // If moving to another ac-hover-root, let that one handle activation
      if(rel && $(rel).closest('.ac-hover-root').length) {
        return;
      }
      
      if($root.length) {
        $root.removeClass('ac-hover-on');
        var $post = $root.closest('.posts');
        if($post.length) {
          $post.removeClass('ac-hover-on');
        }
        activePost = null;
        activeRoot = null;
        cancelRestoreRAF();
      }
    });

    // Handle scroll - shorter timeout and immediate restore after stop
    $win.on('scroll.acHoverFixWin', function(){
      isScrolling = true;
      
      if(scrollTimeout) {
        clearTimeout(scrollTimeout);
      }
      
      scrollTimeout = setTimeout(function(){
        isScrolling = false;
        scrollTimeout = null;
        
        // Immediately check hover after scrolling stops
        if(lastMouse.x >= 0 && lastMouse.y >= 0 && !isLoadingMore && !layoutSettling) {
          restoreHoverUnderPointer();
        }
        // Also schedule a restore for safety
        scheduleRestore();
      }, 50); // reduced to 50ms
    });

    // Handle wheel
    $doc.on('wheel.acHoverFix', function(){
      isScrolling = true;
      
      if(scrollTimeout) {
        clearTimeout(scrollTimeout);
      }
      
      scrollTimeout = setTimeout(function(){
        isScrolling = false;
        scrollTimeout = null;
        
        if(lastMouse.x >= 0 && lastMouse.y >= 0 && !isLoadingMore && !layoutSettling) {
          restoreHoverUnderPointer();
        }
        scheduleRestore();
      }, 50);
    });

    // Handle resize
    $win.on('resize.acHoverFixWin', throttle(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();  // no settling extension
    }, 20));

    // Handle mouse leaving the document
    $doc.on('mouseleave.acHoverFix', function(e){
      if(e.target === document || e.target === document.documentElement || e.target === document.body){
        clearActiveHover();
      }
    });

    // Handle window blur
    $win.on('blur.acHoverFixWin', function(){
      clearActiveHover();
    });

    // Handle visibility change
    document.addEventListener('visibilitychange', function(){
      if(document.hidden){
        clearActiveHover();
      }
    }, { passive:true });

    // Handle touch
    document.addEventListener('touchstart', function(){
      clearActiveHover();
    }, { passive:true });

    document.addEventListener('pointercancel', function(){
      clearActiveHover();
    }, { passive:true });
  }

  /* -----------------------------
     Masonry + Infinite Scroll - WITH SMARTER SETTLING
  ----------------------------- */
  function initMasonryIfPresent(){
    if(!$.fn.masonry) return;

    $container.css('position','relative');

    var start = function(){
      safe(function(){
        $container.masonry({
          itemSelector: '.posts',
          isFitWidth: true,
          transitionDuration: 0
        });

        relayoutAndRestore();

        setTimeout(function(){
          processUnprocessedPosts();
          rebuildUnstablePosts($container);
          relayoutAndRestore();
        }, 120);

        setTimeout(function(){
          processUnprocessedPosts();
          rebuildUnstablePosts($container);
          relayoutAndRestore();
        }, 420);

        setTimeout(function(){
          processUnprocessedPosts();
          rebuildUnstablePosts($container);
          relayoutAndRestore();
        }, 900);
      });

      $win.on('resize', throttle(function(){
        processUnprocessedPosts();
        rebuildUnstablePosts($container);
        relayoutAndRestore();
      }, 220));
    };

    if($.fn.imagesLoaded){
      $container.imagesLoaded(function(){ start(); });
    } else if(window.imagesLoaded){
      imagesLoaded($container[0], function(){ start(); });
    } else {
      setTimeout(start, 250);
    }
  }

  function initInfiniteScrollIfPresent(){
    if(!$.fn.infinitescroll) return;
    if(!document.getElementById('next')) return;
    if(!document.getElementById('pagination')) return;

    $container.infinitescroll({
      navSelector:   '#pagination',
      nextSelector:  '#next',
      itemSelector:  '.posts',
      loading: { selector:'#infscr-loading', img:'', msgText:'', finishedMsg:'' },
      bufferPx: 1200,
      appendCallback: false
    }, function(newElements){
      var $new = $(newElements);
      if(!$new.length) return;

      // Set loading flag to prevent hover interference
      isLoadingMore = true;
      layoutSettling = true;

      $new.removeClass('is-ready');

      var finish = function(){
        $container.append($new);

        processPosts($new);
        processUnprocessedPosts();
        rebuildUnstablePosts($new);

        if($.fn.masonry){
          safe(function(){
            $container.masonry('appended', $new);
          });
          // Use extending version for the initial masonry relayout
          relayoutAndExtendSettling();
        }

        setTimeout(function(){
          $new.addClass('is-ready');
        }, 80);

        // Follow‑up relayouts – also extend settling because layout may still shift
        setTimeout(function(){
          processUnprocessedPosts();
          rebuildUnstablePosts($new);
          relayoutAndExtendSettling();
        }, 140);

        setTimeout(function(){
          processUnprocessedPosts();
          rebuildUnstablePosts($new);
          relayoutAndExtendSettling();
        }, 420);

        setTimeout(function(){
          processUnprocessedPosts();
          rebuildUnstablePosts($new);
          relayoutAndExtendSettling();
        }, 900);
      };

      // Initial settling end scheduled (300ms, extended by relayoutAndExtendSettling)
      scheduleEndSettling(300);

      if($new.imagesLoaded){
        $new.imagesLoaded(function(){ finish(); });
      } else if(window.imagesLoaded){
        imagesLoaded($new.get(), function(){ finish(); });
      } else {
        setTimeout(finish, 180);
      }
    });
  }

  /* -----------------------------
     GO
  ----------------------------- */
  $(document).ready(function(){
    processPosts($(document));
    processUnprocessedPosts();
    rebuildUnstablePosts($container);
    bindHoverEvents();

    initMasonryIfPresent();
    initInfiniteScrollIfPresent();

    $('.posts').addClass('is-ready');

    setTimeout(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();
    }, 700);

    setTimeout(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();
    }, 1500);

    setTimeout(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();
    }, 2400);
  });

})(window.jQuery);
</script>
