/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */
.entry{
  width:800px;
  height:auto;
  margin: 0 auto !important;

  {block:PermalinkPage}
  width:700px;
  margin: 0 auto !important;
  {/block:PermalinkPage}
}

#posts{
  width:800px;
  margin: 10px auto 50px auto !important;
  
  
  /* POSIÇÃO DOS POSTS
   Este valor move todos os posts horizontalmente.
   Use números negativos para mover os posts para a ESQUERDA.
   Use números positivos para mover os posts para a DIREITA.
   Ajuste esse valor se quiser alinhar os posts melhor no layout. */
  transform: translateX(-100px);
  

/* permitir transições, mas NÃO no transform — NÃO REMOVA */
  transition-property: opacity, filter;
  transition-duration: .5s;
  transition-timing-function: ease;

  {block:PermalinkPage}
  width:700px;
  margin:35px auto 0 auto !important;
  transform: translateX(-100px);
  {/block:PermalinkPage}
}

.posts{
  width:330px;
  margin:25px;
  margin-bottom:25px;
  padding:0;
  overflow:visible;
  opacity:1;
  transition:2s;

  {block:PermalinkPage}
  width:700px;
  margin:25px auto 0 auto;
