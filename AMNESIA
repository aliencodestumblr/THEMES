/* ---------------- SEÇÃO DA SIDEBAR/CABEÇALHO ---------------- */
:root{
  --sb-w: 180px;
  --sb-pad: 16px;
  --sb-top-pad: 30px;  /* Increased top padding */

  --sb-bg: rgba(20, 20, 20, 0.95);
  --sb-border: rgba(255,255,255,.08);
  --sb-text: rgba(255,255,255,.9);
  --glitch-pink: #ff44e6;
  --glitch-blue: #4afff5;

  --sb-font: "Rajdhani", sans-serif;
}

#sidebar, #sidebar *{ box-sizing:border-box; }

/* ESTRUTURA PRINCIPAL */
#sidebar{
  position:fixed;
  top:0;
  right:0;
  left:auto;
  width: var(--sb-w);
  height: 100vh;
  z-index:9999;
  user-select:none;

  background: var(--sb-bg);
  border-left: 1px solid var(--sb-border);
  border-right: 0;
  backdrop-filter: blur(10px);

  overflow-y:auto;
  overflow-x:hidden;

  scrollbar-width: thin;
  color: var(--sb-text);
}

#sidebar::-webkit-scrollbar{ width: 8px; }
#sidebar::-webkit-scrollbar-thumb{
  background: rgba(255,255,255,.12);
  border-radius: 10px;
}

#sidebar::-webkit-scrollbar-track{ background: transparent; }

#sidebar .sb-card{
  width:100%;
  padding: var(--sb-top-pad) var(--sb-pad) var(--sb-pad);

  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;

  background: transparent;
  border:0;
  border-radius:0;
  box-shadow:none;
  overflow:visible;
  position:relative;
  min-height: 100%;  /* Helps with spacing */
}

/* TIME - now at top with more space */
#sidebar .sb-time{
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;

  margin: 0 0 12px 0;  /* Increased bottom margin */

  font-family:"Orbitron", sans-serif;
  font-size: 11px;  /* Slightly larger */
  letter-spacing: 3px;
  text-transform:uppercase;

  color: var(--sb-text);
  opacity:.7;
  line-height:1;
}

/* ONLINE COUNTER */
#sidebar .sb-online{
  width:100%;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:8px;

  margin: 0 0 10px 0;
  white-space:nowrap;

  font-family:"Orbitron", sans-serif;
  font-size: 10px;
  font-weight:400;
  letter-spacing:2px;
  text-transform:uppercase;

  color: var(--sb-text);
  opacity:.7;
  line-height:1;
}

#sidebar .sb-online-dot{
  width:6px;
  height:6px;
  border-radius:999px;
  background: rgba(255,255,255,.5);
  box-shadow: 0 0 0 2px rgba(255,255,255,.1);
  flex:0 0 auto;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}

#sidebar #LiveOnlineCount{
  font-family:"Orbitron", sans-serif;
  font-size:10px;
  letter-spacing:1.5px;
  font-weight:500;
}

/* VISITS COUNTER - now below online */
#sidebar .sb-visits {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  margin-bottom: 40px;  /* Extra space before vertical title */
  
  font-family: "Orbitron", sans-serif;
  font-size: 10px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--sb-text);
  opacity: 0.6;
}

#sidebar .sb-visits-count {
  font-weight: 700;
  opacity: 0.9;
}

/* VERTICAL TITLE CONTAINER */
#sidebar .sb-vertical-container {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-bottom: 35px;  /* Space after vertical title */
}

#sidebar .sb-vertical-title {
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  height: auto;
  display: flex;
  flex-direction: row;
  gap: 25px;  /* Increased gap between words */
  letter-spacing: 3px;
}

#sidebar .sb-title-line {
  font-family: "Orbitron", sans-serif;
  font-size: 14px;  /* Larger for vertical impact */
  font-weight: 900;
  text-transform: uppercase;
  line-height: 1.4;
  white-space: nowrap;
  color: var(--sb-text);
  opacity: 0.95;
  position: relative;
}

/* GLITCH EFFECT - keeping the amazing animation */
#sidebar .glitch {
  position: relative;
  animation: glitch-skew 3s infinite linear alternate-reverse;
}

#sidebar .glitch::before,
#sidebar .glitch::after {
  content: attr(data-text);
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--sb-bg);
}

#sidebar .glitch::before {
  animation: glitch-anim-1 2.5s infinite linear alternate-reverse;
  color: var(--glitch-pink);
  z-index: -1;
  text-shadow: 2px 0 currentColor;
}

#sidebar .glitch::after {
  animation: glitch-anim-2 2.5s infinite linear alternate-reverse;
  color: var(--glitch-blue);
  z-index: -2;
  text-shadow: -2px 0 currentColor;
}

@keyframes glitch-anim-1 {
  0% { clip-path: inset(20% 0 30% 0); transform: translate(-2px, 2px); opacity: 0.8; }
  20% { clip-path: inset(50% 0 20% 0); transform: translate(-3px, 1px); opacity: 0.9; }
  40% { clip-path: inset(5% 0 70% 0); transform: translate(-2px, -2px); opacity: 0.8; }
  60% { clip-path: inset(70% 0 15% 0); transform: translate(-3px, -1px); opacity: 0.7; }
  80% { clip-path: inset(15% 0 65% 0); transform: translate(-2px, 3px); opacity: 0.9; }
  100% { clip-path: inset(45% 0 35% 0); transform: translate(-2px, 1px); opacity: 0.8; }
}

@keyframes glitch-anim-2 {
  0% { clip-path: inset(60% 0 15% 0); transform: translate(2px, -2px); opacity: 0.7; }
  20% { clip-path: inset(70% 0 20% 0); transform: translate(3px, -1px); opacity: 0.6; }
  40% { clip-path: inset(45% 0 40% 0); transform: translate(2px, 3px); opacity: 1; }
  60% { clip-path: inset(20% 0 60% 0); transform: translate(3px, 2px); opacity: 0.8; }
  80% { clip-path: inset(10% 0 75% 0); transform: translate(2px, -1px); opacity: 0.9; }
  100% { clip-path: inset(65% 0 20% 0); transform: translate(2px, 2px); opacity: 0.8; }
}

@keyframes glitch-skew {
  0% { transform: skew(0deg); }
  40% { transform: skew(0.5deg); }
  60% { transform: skew(-0.5deg); }
  100% { transform: skew(0deg); }
}

