}

.post-top a:hover{
  opacity:.6;
}


/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}
.notsi{
  position:absolute;
  inset:0;
  pointer-events:none;
  border-radius:4px;
  overflow:hidden;
  z-index:2;
}

.notsi::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:inherit;

  background:
    linear-gradient(
      to bottom,
      rgba(255,255,255,.65) 0%,
      rgba(255,255,255,.45) 40%,
      rgba(255,255,255,.55) 100%
    );

  backdrop-filter:blur(6px);
  -webkit-backdrop-filter:blur(6px);

  opacity:0;
  transition:opacity 1.2s cubic-bezier(0.23, 1, 0.32, 1);  /* Increased to 1.2s */
  pointer-events:none;
  will-change:opacity;
}

/* centered control bar */
.notsi .inf{
  position:absolute;
  left:50%;
  bottom:12px;
  transform:translateX(-50%) translateY(8px);

  display:flex;
  align-items:center;
  justify-content:center;
  gap:14px;

  height:30px;
  padding:0 14px;

  background:rgba(255,255,255,.46);
  border:1px solid rgba(0,0,0,.08);
  border-radius:6px;

  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  font-weight:800;
  letter-spacing:1.4px;
  text-transform:uppercase;
  line-height:1;

  color:{color:Notes Color};

  opacity:0;
  visibility:hidden;
  transition:
    opacity 1.2s cubic-bezier(0.23, 1, 0.32, 1),    /* Increased to 1.2s */
    transform 1.2s cubic-bezier(0.23, 1, 0.32, 1),   /* Increased to 1.2s */
    visibility 0s linear 1.2s;                       /* Delay matches new duration */

  box-shadow:
    0 0 0 1px rgba(255,255,255,.25) inset,
    0 10px 22px rgba(0,0,0,.09);

  pointer-events:none;
  z-index:3;

  will-change:opacity, transform;
  backface-visibility:hidden;
  -webkit-backface-visibility:hidden;
}

/* divider */
.notsi .inf .divider{
  width:1px;
  height:12px;
  background:rgba(0,0,0,.12);
  flex:0 0 1px;
}

/* links */
.notsi .inf a{
  display:flex;
  align-items:center;
  justify-content:center;
  color:{color:Notes Color};
  opacity:.88;

  transition:
    color .16s ease,
    opacity .16s ease,
    letter-spacing .16s ease;
}

.notsi .inf a:hover{
  opacity:1;
  color:{color:Links Hover};
  letter-spacing:1.55px;
}

.notsi .npf-time{
  opacity:.65;
}

.notsi .npf-notes{
  font-weight:900;
}

.notsi a::before,
.notsi a::after{
  content:"" !important;
}

.ac-hover-on .notsi::before{
  opacity:1;
}

.ac-hover-on .notsi .inf{
  opacity:1;
  visibility:visible;
  transform:translateX(-50%) translateY(0);
  pointer-events:auto;
  transition:
    opacity 1.2s cubic-bezier(0.23, 1, 0.32, 1),    /* Increased to 1.2s */
    transform 1.2s cubic-bezier(0.23, 1, 0.32, 1),   /* Increased to 1.2s */
    visibility 0s linear 0s;
}
{/block:IndexPage}


/* --------- TAMANHOS DE IMAGEM + VÍDEO / NÃO ALTERAR --------- */
.posts img{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
