  border-radius:4px;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  cursor:crosshair;
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
  border-radius:4px;
  width:100%;
  height:auto;
}
blockquote video {
  border-radius:4px;
  width:100%;
}

img {
  border-radius:4px;
  cursor:crosshair;
  width:100%;
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
