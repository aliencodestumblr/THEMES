(function(){
  function updateSBClock(){
    var clock = document.getElementById("ac-live-time"); // matches your sidebar ID
    if(!clock) return;

    var now = new Date();

    var options = {
      timeZone: "America/Chicago",
      hour: "numeric",
      minute: "2-digit",
      hour12: true
    };

    var timeString = now.toLocaleTimeString("en-US", options);
    clock.textContent = timeString;
  }

  updateSBClock();
  setInterval(updateSBClock, 1000);
})();
</script>

<script>
(function() {
  var el = document.getElementById("hd-online-count");
  if (!el) return;

  var min = 8;
  var max = 75;

  var current = Math.floor(Math.random() * (max - min + 1)) + min;

  function updateCounter() {
    // small natural fluctuation
    var change = Math.floor(Math.random() * 5) - 2; // -2 to +2
    current += change;

    // clamp strictly between 8 and 75
    if (current < min) current = min;
    if (current > max) current = max;

    el.textContent = current;
  }

  // initial value
  el.textContent = current;

  function scheduleUpdate() {
    var interval = Math.floor(Math.random() * 4000) + 3000; // 3–7s
    setTimeout(function() {
      updateCounter();
      scheduleUpdate();
    }, interval);
  }

  scheduleUpdate();
})();
</script>

