/* ÁUDIOS */
.album{ margin-left: 20px; }
.player{ opacity:1; pointer-events:auto; margin:0; }
.art, .track{ display:none; }


/* DESIGN DO POST DE ASK */
.ask-wrap{
  margin-bottom:14px;
}

.asker{
  font-family:"Rajdhani", sans-serif;
  font-size:10px;
  text-transform:uppercase;
  letter-spacing:1.2px;
  margin:0 0 7px 0;
  color:{color:text};
  opacity:.78;
}

/* add the dashes */
.asker::before{
  content:"— ";
  opacity:.6;
}

.asker::after{
  content:" —";
  opacity:.6;
}

.asker a{
  color:{color:links};
  font-weight:700;
  text-decoration:none;
  transition:color .14s linear, opacity .14s linear;
}

.asker a:hover{
  color:{color:links hover};
  opacity:1;
}

.bubble{
  position:relative;
  display:inline-block;
  max-width:92%;
  padding:10px 13px;
  border-radius:8px;
  line-height:1.48;
  font-size:11px;
  word-wrap:break-word;
  overflow-wrap:break-word;
  border:1px solid rgba(0,0,0,.09);
  box-shadow:
    0 3px 10px rgba(0,0,0,.06),
    inset 0 1px 0 rgba(255,255,255,.35);
  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);
}

/* ONLY left-side tail (ask) */
.bubble::after{
  content:"";
  position:absolute;
  width:10px;
  height:10px;
  bottom:10px;
  left:-5px;
  transform:rotate(45deg);
  background:inherit;
  border-left:1px solid currentColor;
  border-bottom:1px solid currentColor;
}

.ask{
  background:{color:Ask background};
  color:{color:Ask Text};
  border-color:{color:Ask Border};
  border-radius:8px 8px 8px 3px;
}

/* fix tail color properly */
.ask::after{
  background:{color:Ask background};
  border-left:1px solid {color:Ask Border};
  border-bottom:1px solid {color:Ask Border};
}

/* ANSWER SIDE */
.answer{
  margin-top:9px;
  text-align:right;
}

.answer .bubble{
  background:{color:Answer Background};
  color:{color:Answer Text};
  border-color:{color:Answer Border};
  border-radius:8px;
  box-shadow:
    0 3px 12px rgba(0,0,0,.08),
    inset 0 1px 0 rgba(255,255,255,.28);
}

/* REMOVE tail entirely on answer */
.answer .bubble::after{
  display:none;
}

.answer img{
  width:100%;
  border-radius:6px;
  margin-top:10px;
  display:block;
}

.bubble a{
  color:inherit;
  text-decoration:underline;
  text-underline-offset:2px;
  text-decoration-thickness:1px;
  opacity:.96;
}

.bubble a:hover{
  opacity:1;
}

.bubble p:first-child{ margin-top:0; }
.bubble p:last-child{ margin-bottom:0; }

/* CITAÇÃO */
.quote{
  text-align:justify;
  line-height:15px;
  margin-bottom:-5px;
  margin-top:0px;
  margin-left:0px;
  margin-right:0px;
