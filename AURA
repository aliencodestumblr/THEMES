}

/* ===== ICON BUTTONS ===== */
.pf-btn{
  width:17px;
  height:17px;

  display:inline-flex;
  align-items:center;
  justify-content:center;

  text-decoration:none;
  color:rgba(255,255,255,.65);

  background:rgba(255,255,255,.035);
  border:1px solid rgba(255,255,255,.08);
  border-radius:4px;

  transition:.15s ease;
}

.pf-btn svg{
  width:9px;
  height:9px;
}

/* ===== HOVER ===== */
.pf-notes:hover{
  color:#ffffff;
  background:rgba(255,255,255,.07);
  border-color:rgba(255,255,255,.18);

  box-shadow:
    0 0 6px rgba(255,255,255,.08);
}

.pf-btn:hover{
  color:{color:Accent};
  background:rgba(255,255,255,.06);
  border-color:rgba(255,255,255,.18);

  box-shadow:
    0 0 6px rgba(255,255,255,.06);
}

/* ===== CLICK FEEL ===== */
.pf-btn:active,
.pf-notes:active{
  transform:scale(.94);
}
