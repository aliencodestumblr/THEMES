  function manualLayoutPosts(forceReveal){
    var $items = $container.children('.posts');
    if(!$items.length) return false;

    manualLayoutActive = true;

    var containerWidth = Math.round($container.width() || $container.parent().width() || $win.width() || 0);
    if(containerWidth <= 0){
      manualLayoutActive = false;
      return false;
    }

    var sampleWidth = 0;
    $items.each(function(){
      var w = Math.ceil($(this).outerWidth(true) || 0);
      if(w > sampleWidth) sampleWidth = w;
    });

    if(sampleWidth <= 0) sampleWidth = 250;

    var cols = Math.max(1, Math.floor(containerWidth / sampleWidth));
    var colWidth = sampleWidth;
    var usedWidth = cols * colWidth;
    var leftOffset = Math.max(0, Math.floor((containerWidth - usedWidth) / 2));
    var heights = [];

    for(var i=0;i<cols;i++) heights[i] = 0;

    $container.css({
      position: 'relative',
      height: ''
    });

    $items.each(function(){
      var $item = $(this);

      $item.css({
        position: 'absolute',
        display: 'block'
      });

      var shortest = 0;
      for(var i=1;i<cols;i++){
        if(heights[i] < heights[shortest]) shortest = i;
      }

      var itemHeight = Math.ceil($item.outerHeight(true) || $item[0].getBoundingClientRect().height || 0);
      if(itemHeight <= 0) itemHeight = 1;

      var left = leftOffset + (shortest * colWidth);
      var top = heights[shortest];

      $item.css({
        left: left + 'px',
        top: top + 'px'
      });

      heights[shortest] += itemHeight;
    });

    var maxHeight = 0;
    for(var j=0;j<heights.length;j++){
      if(heights[j] > maxHeight) maxHeight = heights[j];
    }

    $container.css('height', Math.ceil(maxHeight) + 'px');

    if(forceReveal){
      revealPostsAfterLayout($items);
    }

    manualLayoutActive = false;
    return true;
  }

  function hardRelayout(forceManual, shouldReveal){
    if(shouldReveal === undefined) shouldReveal = true;

    if($.fn.masonry && !manualLayoutActive && !forceManual){
      safe(function(){
        ensureMasonry();
        $container.masonry('reloadItems');
        $container.masonry('layout');
      });
      if(shouldReveal) revealPostsAfterLayout($container.children('.posts'));
    } else {
      manualLayoutPosts(shouldReveal);
    }
  }

  function relayoutAndRestore(){
    hardRelayout(false);
    scheduleRestore();
  }

  function watchHeights($items){
    if(!$items || !$items.length) $items = $container.find('.posts');

    $items.find('img').each(function(){
      var img = this;
      if(img.complete) return;
      if(img._acHoverWatchBound) return;
      img._acHoverWatchBound = true;

      img.addEventListener('load', relayoutAndRestore, { once:false });
      img.addEventListener('error', relayoutAndRestore, { once:false });
    });

    $items.find('iframe').each(function(){
      var frame = this;
      if(frame._acHoverWatchBound) return;
      frame._acHoverWatchBound = true;

      frame.addEventListener('load', relayoutAndRestore, { once:false });
    });

    if(window.ResizeObserver){
      if(!resizeObserver){
        resizeObserver = new ResizeObserver(throttle(function(){
          hardRelayout(manualLayoutActive, true);
          if(!hoverIsPaused()) scheduleRestore();
        }, 120));
      }

      $items.each(function(){
        if(this._acHoverROBound) return;
        this._acHoverROBound = true;
        try{ resizeObserver.observe(this); }catch(e){}
      });
    } else {
      setTimeout(relayoutAndRestore, 300);
      setTimeout(relayoutAndRestore, 800);
      setTimeout(relayoutAndRestore, 1500);
      setTimeout(relayoutAndRestore, 2400);
    }
  }

  function waitForPostMedia($scope, callback){
    $scope = $scope && $scope.length ? $scope : $container;

    var called = false;
    var fallback = setTimeout(done, 3600);

    function done(){
      if(called) return;
      called = true;
      clearTimeout(fallback);
      callback();
    }

    forceEager($scope);

    if($.fn.imagesLoaded){
      try{
        var loader = $scope.imagesLoaded();

        if(loader && loader.progress){
          loader.progress(function(){
            hardRelayout(false, true);
            if(!hoverIsPaused()) scheduleRestore();
          });
        }

        if(loader && loader.always){
          loader.always(done);
        } else {
          $scope.imagesLoaded(function(){
            done();
          });
        }
      }catch(e){
        done();
      }
    } else if(window.imagesLoaded){
      try{
        imagesLoaded($scope.get(), function(){
          done();
        });
      }catch(e2){
        done();
      }
    } else {
      var pending = 0;

      $scope.find('img').each(function(){
        if(this.complete) return;
        pending++;
        $(this).one('load error', function(){
          pending--;
          hardRelayout(false, true);
          if(!hoverIsPaused()) scheduleRestore();
          if(pending <= 0) done();
        });
      });

      if(!pending) done();
    }
  }

  function runSettledLayouts($scope, done){
    var delays = [0, 120, 300, 650, 1100, 1800, 2600];
    var remaining = delays.length;

    function onePass(){
      processUnprocessedPosts();
      rebuildUnstablePosts($scope && $scope.length ? $scope : $container);
      hardRelayout(manualLayoutActive, true);
      if(!hoverIsPaused()) scheduleRestore();

      remaining--;
      if(remaining <= 0 && typeof done === 'function') done();
    }

    for(var i=0;i<delays.length;i++){
      setTimeout(onePass, delays[i]);
    }
  }

  function bindHoverEvents(){
    $doc.off('.acHoverFix');
    $win.off('.acHoverFixWin');

    $doc.on('mousemove.acHoverFix', function(e){
      lastMouse.x = e.clientX;
      lastMouse.y = e.clientY;
      allowHoverFromPointer();

      if(hoverIsPaused()) return;

      var $root = getHoverRootUnderPointer();

      if($root.length){
        activateHoverForRoot($root);
      } else {
        clearActiveHover();
      }
    });

    $doc.on('mouseenter.acHoverFix', '.ac-hover-root', function(){
      allowHoverFromPointer();
      if(!hoverIsPaused()) activateHoverForRoot($(this));
    });

    $doc.on('mouseleave.acHoverFix', '.ac-hover-root', function(e){
      var rel = e.relatedTarget;

      if(rel && $(rel).closest('.notsi').length) return;
      if(rel && $(rel).closest('.ac-hover-root').length) return;

      $(this).removeClass('ac-hover-on');

      var $post = $(this).closest('.posts');
      if($post.length) $post.removeClass('ac-hover-on');

      if(activeRoot === this){
        activePost = null;
        activeRoot = null;
      }
    });

    $doc.on('mouseenter.acHoverFix', '.notsi', function(){
      allowHoverFromPointer();
      if(!hoverIsPaused()){
        var $root = $(this).parent('.ac-hover-root');
        if($root.length){
          activateHoverForRoot($root);
        }
      }
    });

    $doc.on('mouseleave.acHoverFix', '.notsi', function(e){
      var $root = $(this).parent('.ac-hover-root');
      var rel = e.relatedTarget;

      if($root.length && rel && $root[0].contains(rel)) return;
      if(rel && $(rel).closest('.ac-hover-root').length) return;

      if($root.length){
        $root.removeClass('ac-hover-on');

        var $post = $root.closest('.posts');
        if($post.length) $post.removeClass('ac-hover-on');

        if(activeRoot === $root[0]){
          activePost = null;
          activeRoot = null;
        }
      }
    });

    $doc.on('click.acHoverFix', '.notsi .npf-lightbox, .notsi [data-ac-lightbox]', function(e){
      e.preventDefault();
      e.stopPropagation();

      var $post = $(this).closest('.posts');
      if(!$post.length){
        $post = $(this).closest('.ac-hover-root').closest('.posts');
      }
      if(!$post.length) return;

      var $target = getFirstLightboxTarget($post);
      if(!$target.length) return;

      $target[0].dispatchEvent(new MouseEvent('click', {
        bubbles: true,
        cancelable: true,
        view: window
      }));

      setTimeout(function(){
        if($target.closest('.pxu-photo').length){
          var wrap = $target.closest('.pxu-photo')[0];
          if(wrap){
            wrap.dispatchEvent(new MouseEvent('click', {
              bubbles: true,
              cancelable: true,
              view: window
            }));
          }
        }

        if($target.closest('.photo-data').length){
          var pdata = $target.closest('.photo-data')[0];
          if(pdata){
            pdata.dispatchEvent(new MouseEvent('click', {
              bubbles: true,
              cancelable: true,
              view: window
            }));
          }
        }

        if($target.closest('.npf_image, figure.tmblr-full, .tmblr-full').length){
          var npfWrap = $target.closest('.npf_image, figure.tmblr-full, .tmblr-full')[0];
          if(npfWrap){
            npfWrap.dispatchEvent(new MouseEvent('click', {
              bubbles: true,
              cancelable: true,
              view: window
            }));
          }
        }
      }, 0);
    });

    $win.on('scroll.acHoverFixWin', function(){
      if(hoverIsPaused()) return;
      stopScrollGhostHover();
    });

    $doc.on('wheel.acHoverFix', function(){
      if(hoverIsPaused()) return;
      stopScrollGhostHover();
    });

    $win.on('resize.acHoverFixWin', throttle(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      hardRelayout(manualLayoutActive, true);
      if(!hoverIsPaused()) scheduleRestore();
    }, 160));

    $doc.on('mouseleave.acHoverFix', function(e){
      if(e.target === document || e.target === document.documentElement || e.target === document.body){
        clearActiveHover();
      }
    });

    $win.on('blur.acHoverFixWin', function(){
      hoverRestoreAllowed = false;
      clearActiveHover();
    });

    document.addEventListener('visibilitychange', function(){
      if(document.hidden){
        hoverRestoreAllowed = false;
        clearActiveHover();
      }
    }, { passive:true });

    document.addEventListener('touchstart', function(){
      hoverRestoreAllowed = false;
      clearActiveHover();
    }, { passive:true });

    document.addEventListener('pointercancel', function(){
      clearActiveHover();
    }, { passive:true });
  }

  function initMasonryIfPresent(){
    $container.css('position','relative');

    var $initialPosts = $container.find('.posts');
    hidePostsUntilLayout($initialPosts);

    if($.fn.masonry){
      ensureMasonry();
    }

    processUnprocessedPosts();
    rebuildUnstablePosts($container);

    hardRelayout(false, false);

    setTimeout(function(){
      revealPostsAfterLayout($container.find('.posts'));
      hardRelayout(false, true);
    }, 50);

    waitForPostMedia($container, function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      revealPostsAfterLayout($container.find('.posts'));
      hardRelayout(false, true);
      runSettledLayouts($container);
    });

    $win.on('resize.acMasonryFix', throttle(function(){
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      runSettledLayouts($container);
    }, 260));
  }

  function initInfiniteScrollIfPresent(){
    if(!$.fn.infinitescroll) return;
    if(!document.getElementById('next')) return;
    if(!document.getElementById('pagination')) return;

    $container.infinitescroll({
      navSelector:   '#pagination',
      nextSelector:  '#next',
      itemSelector:  '.posts',
      loading: { selector:'#infscr-loading', img:'', msgText:'', finishedMsg:'' },
      bufferPx: 1200,
      appendCallback: false
    }, function(newElements){
      var $new = $(newElements).filter('.posts');
      if(!$new.length) $new = $(newElements).find('.posts');
      if(!$new.length) return;

      isLoadingMore = true;
      layoutSettling = true;

      /*
        Do not pause/clear hover here.
        Existing posts should keep working while the next infinite-scroll batch is loading.
      */

      $new
        .removeClass('is-ready')
        .css({
          visibility: 'hidden',
          opacity: 0,
          display: 'block'
        });

      $container.append($new);

      forceEager($new);
      processPosts($new);
      processUnprocessedPosts();
      rebuildUnstablePosts($new);

      hardRelayout(true, false);

      waitForPostMedia($new, function(){
        processPosts($new);
        processUnprocessedPosts();
        rebuildUnstablePosts($new);

        hardRelayout(true, true);
        revealPostsAfterLayout($new);

        setTimeout(function(){
          hardRelayout(true, true);

          isLoadingMore = false;

          runSettledLayouts($container, function(){
            layoutSettling = false;
            resumeHoverWhenStable(80);
            scheduleRestore();
          });
        }, 180);
      });

      setTimeout(function(){
        revealPostsAfterLayout($new);
        hardRelayout(true, true);
        isLoadingMore = false;
        layoutSettling = false;
        resumeHoverWhenStable(80);
        scheduleRestore();
      }, 4000);
    });
  }

  $(document).ready(function(){
    processPosts($(document));
    processUnprocessedPosts();
    rebuildUnstablePosts($container);
    bindHoverEvents();

    initMasonryIfPresent();
    initInfiniteScrollIfPresent();

    setTimeout(function(){
      revealPostsAfterLayout($container.find('.posts'));
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();
    }, 700);

    setTimeout(function(){
      revealPostsAfterLayout($container.find('.posts'));
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();
    }, 1500);

    setTimeout(function(){
      revealPostsAfterLayout($container.find('.posts'));
      processUnprocessedPosts();
      rebuildUnstablePosts($container);
      relayoutAndRestore();
    }, 2600);
  });

})(window.jQuery);
</script>
