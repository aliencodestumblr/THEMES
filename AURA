:root{
  --ac-bg: #000000;

  --ac-width: 140px;
  --ac-gap: 20px;
  --layout-gutter: 30px;
  --layout-shift: 35px;

  --layout-space: calc(100vw - (var(--layout-gutter) * 2));
  --posts-wrap: min(1080px, calc(var(--layout-space) - var(--ac-width) - var(--ac-gap)));

  --ac-text: rgba(255,255,255,0.95);
  --ac-soft: rgba(255,255,255,0.72);
  --ac-faint: rgba(255,255,255,0.34);
  --ac-line: rgba(255,255,255,0.075);

  --ac-chip-bg: #0f0f0f;
  --ac-chip-border: rgba(255,255,255,0.06);
}

body{
  margin:0;
  background:#000000;
  box-sizing:border-box;
}

#ac-sidebar-shell{
  position:fixed;
  top:0;
  bottom:0;
  left:calc(50% - ((var(--posts-wrap) + var(--ac-width) + var(--ac-gap)) / 2) + var(--layout-shift));
  width:var(--ac-width);
  height:100vh;
  z-index:999999;
}

#ac-sidebar{
  position:relative;
  width:100%;
  height:100%;
  background:#000000;
  border-left:1px solid var(--ac-line);
  border-right:1px solid var(--ac-line);
  overflow:hidden;
  box-sizing:border-box;
  padding:0 11px;
}

#ac-sidebar::before{
  content:"";
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:120px;
  background:linear-gradient(180deg, rgba(255,255,255,0.022), transparent);
  pointer-events:none;
}

.ac-top{
  position:absolute;
  top:34px;
  left:11px;
  right:11px;

  display:flex;
  flex-direction:column;
  align-items:center;
  gap:9px;
}

.ac-avatar-wrap{
  position:relative;
  width:76px;
  height:76px;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:4px;
}

.ac-avatar-wrap::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:50%;
  padding:2px;
  background:
    conic-gradient(
      from 0deg,
      rgba(255,255,255,0.02),
      rgba(255,255,255,0.26),
      rgba(255,255,255,0.04),
      rgba(255,255,255,0.20),
      rgba(255,255,255,0.02)
    );
  -webkit-mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  -webkit-mask-composite:xor;
  mask:
    linear-gradient(#fff 0 0) content-box,
    linear-gradient(#fff 0 0);
  mask-composite:exclude;
  animation:acSpinRing 8s linear infinite;
  pointer-events:none;
  opacity:.72;
}

.ac-avatar-wrap::after{
  content:"";
  position:absolute;
  inset:7px;
  border-radius:50%;
  border:1px solid rgba(255,255,255,0.075);
  pointer-events:none;
}

@keyframes acSpinRing{
  to{ transform:rotate(360deg); }
}

.ac-avatar{
  width:66px;
  height:66px;
  border-radius:50%;
  display:block;
  object-fit:cover;
  border:1px solid rgba(255,255,255,0.10);
  background:#000;
  position:relative;
  z-index:2;
}

.ac-title-wrap{
  width:100%;
  display:flex;
  justify-content:center;
  align-items:center;
}

.ac-title{
  position:relative;
  max-width:100%;
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;

  font-family:"Orbitron", sans-serif;
  font-size:9px;
  line-height:1;
  letter-spacing:4.2px;
  text-transform:uppercase;
  color:var(--ac-text);
  text-align:center;
}

.ac-title::before,
.ac-title::after{
  content:attr(data-text);
  position:absolute;
  inset:0;
  pointer-events:none;
  opacity:0;
}

.ac-title::before{
  color:rgba(0,190,255,0.11);
  animation:acGlitchA 6s infinite ease-in-out;
}

.ac-title::after{
  color:rgba(255,255,255,0.08);
  animation:acGlitchB 6s infinite ease-in-out;
}

@keyframes acGlitchA{
  0%, 86%, 100%{
    opacity:0;
    transform:translate(0,0);
    clip-path:inset(0 0 0 0);
  }
  87%{
    opacity:.36;
    transform:translate(1px,-1px);
    clip-path:inset(12% 0 56% 0);
  }
  88.5%{
    opacity:.12;
    transform:translate(-1px,0);
    clip-path:inset(58% 0 14% 0);
  }
}

@keyframes acGlitchB{
  0%, 88%, 100%{
    opacity:0;
    transform:translate(0,0);
    clip-path:inset(0 0 0 0);
  }
  88.5%{
    opacity:.18;
    transform:translate(-1px,1px);
    clip-path:inset(48% 0 20% 0);
  }
  89.5%{
    opacity:.08;
    transform:translate(1px,0);
    clip-path:inset(16% 0 60% 0);
  }
}

.ac-name-row{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:5px;
  max-width:100%;
  margin-top:3px;
}

.ac-name{
