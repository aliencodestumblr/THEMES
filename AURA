<script>
document.addEventListener("DOMContentLoaded", function() {
    const playerWrap = document.querySelector('.hd-player');
    const audio = document.getElementById('audio');
    const playBtn = document.querySelector('.sb-play');
    const pauseBtn = document.querySelector('.sb-pause');

    if (playerWrap && audio) {
        // Play function
        playBtn.addEventListener('click', () => {
            audio.play();
            playerWrap.classList.add('is-playing');
        });

        // Pause function
        pauseBtn.addEventListener('click', () => {
            audio.pause();
            playerWrap.classList.remove('is-playing');
        });

        // Reset if audio ends
        audio.onended = () => {
            playerWrap.classList.remove('is-playing');
        };
    }
});
</script>

