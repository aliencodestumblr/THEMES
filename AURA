<script>
(function () {
  const onlineEl = document.getElementById('hd-online-count');
  const playerEl = document.getElementById('hd-player');
  const audio = document.getElementById('audio');
  const toggleBtn = document.getElementById('music-toggle');
  const nextBtn = document.getElementById('music-next');
  const trackNameEl = document.getElementById('track-name');
  const trackArtistEl = document.getElementById('track-artist');
  const freqBars = document.getElementById('freq-bars');
  const playlistDataEl = document.getElementById('playlist-data');

  if (!audio || !toggleBtn || !playlistDataEl) return;

  let playlist = [];
  try {
    playlist = JSON.parse(playlistDataEl.textContent).filter(track => track.src && track.src.trim() !== '');
  } catch (e) {
    playlist = [];
  }

  if (!playlist.length) {
    if (nextBtn) nextBtn.style.display = 'none';
    return;
  }

  let currentIndex = 0;

  function loadTrack(index, shouldPlay) {
    const track = playlist[index];
    if (!track) return;

    audio.src = track.src;
    if (trackNameEl) trackNameEl.textContent = track.title || 'Untitled';
    if (trackArtistEl) trackArtistEl.textContent = track.artist || 'Unknown Artist';

    if (shouldPlay) {
      audio.play().catch(() => {});
    }
  }

  function setPlayingState(isPlaying) {
    if (playerEl) playerEl.classList.toggle('is-playing', isPlaying);
    if (freqBars) freqBars.classList.toggle('is-paused', !isPlaying);
  }

  toggleBtn.addEventListener('click', function () {
    if (audio.paused) {
      if (!audio.src) loadTrack(currentIndex, false);
      audio.play().catch(() => {});
    } else {
      audio.pause();
    }
  });

  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      currentIndex = (currentIndex + 1) % playlist.length;
      loadTrack(currentIndex, true);
    });
  }

  audio.addEventListener('play', function () {
    setPlayingState(true);
  });

  audio.addEventListener('pause', function () {
    setPlayingState(false);
  });

  audio.addEventListener('ended', function () {
    currentIndex = (currentIndex + 1) % playlist.length;
    loadTrack(currentIndex, true);
  });

  loadTrack(currentIndex, false);
  setPlayingState(false);
})();
</script>

