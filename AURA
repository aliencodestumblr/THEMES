#ac-theme-credit a{
  position:relative;
  display:block;
  width:30px;
  height:34px;
  text-decoration:none;
  transform:translateY(0);
  transition:transform .34s cubic-bezier(.22,1,.36,1);
}

#ac-theme-credit a::before{
  content:"A";
  position:absolute;
  left:0;
  bottom:0;
  display:block;

  font-family:"Rajdhani", sans-serif;
  font-size:34px;
  font-weight:700;
  line-height:.86;
  letter-spacing:-3px;

  background:linear-gradient(
    180deg,
    #d8d8d8 0%,
    #aaaaaa 52%,
    #696969 100%
  );
  -webkit-background-clip:text;
  background-clip:text;
  -webkit-text-fill-color:transparent;

  transform:
    skewX(-14deg)
    scaleX(.88)
    rotate(-7deg);

  transform-origin:50% 50%;
  filter:drop-shadow(0 2px 8px rgba(0,0,0,.38));
  opacity:.97;

  transition:
    transform .34s cubic-bezier(.22,1,.36,1),
    filter .28s ease,
    opacity .28s ease;
}

#ac-theme-credit a i{
  position:absolute;
  left:13px;
  top:12px;
  width:8px;
  height:2px;
  background:rgba(0,0,0,.45);
  transform:skewX(-42deg) rotate(-7deg);
  pointer-events:none;
  opacity:.5;
  filter:blur(.2px);
  transition:
    transform .34s cubic-bezier(.22,1,.36,1),
    opacity .28s ease;
}

#ac-theme-credit a::after{
  content:"@aliencodes";
  position:absolute;
  left:0;
