/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@500;600&display=swap');

.notsi{
  position:absolute;
  inset:0;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  pointer-events:none;
  z-index:10;
  border-radius:4px;
}

.notsi::before{
  content:"";
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.28);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
  opacity:0;
  transition:
    opacity .75s cubic-bezier(.19,1,.22,1);
  pointer-events:none;
  border-radius:4px;
}

.notsi .inf{
  position:relative;
  z-index:2;
  opacity:0;
  margin-bottom:10px;
  transform:translateY(12px);
  transition:
    opacity .7s cubic-bezier(.19,1,.22,1),
    transform .7s cubic-bezier(.19,1,.22,1);
  transition-delay:.08s;
  pointer-events:none;
}

.notsi .npf-time{
  font-family:"Orbitron", sans-serif;
  font-size:7px;
  font-weight:400;
  letter-spacing:2px;
  text-transform:uppercase;
  color:rgba(255,255,255,.78);
  text-align:center;
  text-shadow:0 0 10px rgba(0,0,0,.35);
}

.notsi .inf2{
  position:relative;
  z-index:2;
  opacity:0;
  display:flex;
  align-items:center;
  justify-content:center;
  gap:30px;
  transform:translateY(14px);
  transition:
    opacity .8s cubic-bezier(.19,1,.22,1),
    transform .8s cubic-bezier(.19,1,.22,1);
  transition-delay:.16s;
  pointer-events:auto;
}

.notsi .inf2 a{
  display:flex;
  align-items:center;
  justify-content:center;
  text-decoration:none;
  color:rgba(255,255,255,.72);
  font-size:10px;
  line-height:1;
  padding:0;
  background:none !important;
  border:none !important;
  box-shadow:none !important;
  opacity:.92;
  transition:
    color .3s ease,
    transform .35s ease,
    opacity .35s ease;
}

.notsi .inf2 a:hover{
  color:#fff;
  transform:translateY(-1px) scale(1.06);
  opacity:1;
}

.post:hover .notsi::before,
.ac-hover-on .notsi::before{
  opacity:1;
}

.post:hover .notsi .inf,
.ac-hover-on .notsi .inf{
  opacity:1;
  transform:translateY(0);
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2{
  opacity:1;
  transform:translateY(0);
}
{/block:IndexPage}

