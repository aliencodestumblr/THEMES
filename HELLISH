  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}

.notsi{
  position:absolute;
  inset:0;
  overflow:hidden;
  pointer-events:none;
  z-index:99;
}

/* STRONG GLASS VEIL */
.notsi::before{
  content:"";
  position:absolute;
  inset:0;

  background:
    radial-gradient(circle at 18% 18%, rgba(255,255,255,.72), transparent 42%),
    radial-gradient(circle at 85% 85%, rgba(255,255,255,.32), transparent 46%),
    linear-gradient(135deg, rgba(255,255,255,.48), rgba(255,255,255,.18));

  backdrop-filter:blur(18px) saturate(220%);
  -webkit-backdrop-filter:blur(18px) saturate(220%);

  opacity:0;
  transition:opacity .65s cubic-bezier(.22,1,.36,1);
  pointer-events:none;
}

.notsi .inf{
  display:none!important;
}

.notsi .npf-box{
  position:absolute;
  left:12px;
  right:12px;
  bottom:12px;
  z-index:5;
  pointer-events:none;
}

/* MAIN FLOATING CAPSULE */
.notsi .inf2{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:7px;

  width:100%;
  box-sizing:border-box;

  padding:7px;

  border-radius:9px;

  background:rgba(255,255,255,.92);

  backdrop-filter:blur(18px) saturate(180%);
  -webkit-backdrop-filter:blur(18px) saturate(180%);

  border:1px solid rgba(255,255,255,.9);

  box-shadow:
    0 18px 38px rgba(0,0,0,.16),
    0 3px 10px rgba(0,0,0,.08),
    inset 0 1px 0 rgba(255,255,255,.95);

  opacity:0;
  transform:translateY(12px) scale(.985);

  transition:
    opacity .45s cubic-bezier(.22,1,.36,1),
    transform .45s cubic-bezier(.22,1,.36,1);

  pointer-events:auto;
}

/* LINKS */
.notsi .inf2 a{
  position:relative;

  flex:1;
  min-width:0;
  height:28px;

  display:flex;
  align-items:center;
  justify-content:center;
  gap:5px;

  border-radius:6px;

  background:rgba(0,0,0,.035);

  color:rgba(0,0,0,.62);
  text-decoration:none;

  font-family:Inter, Arial, sans-serif;
  font-size:7px;
  font-weight:700;
  letter-spacing:.9px;
  text-transform:uppercase;

  opacity:0;
  transform:translateY(6px);

  transition:
    opacity .35s ease,
    transform .35s cubic-bezier(.22,1,.36,1),
    background .24s ease,
    color .24s ease,
    box-shadow .24s ease;
}

.notsi .inf2 a::before,
.notsi .inf2 a::after,
.notsi .inf2::before,
.notsi .inf2::after{
  display:none!important;
}

.notsi .inf2 i{
  font-size:11px;
  line-height:1;
}

.notsi .inf2 .rb-icon{
  width:11px;
  height:11px;
  flex:0 0 auto;
}

.notsi .inf2 .rb-icon path{
  fill:none;
  stroke:currentColor;
  stroke-width:1.65;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.notsi .ac-label{
  display:block;
  line-height:1;
  white-space:nowrap;
}

/* BUTTON HOVER */
.notsi .inf2 a:hover{
  background:#fff;
  color:#000;

  box-shadow:
    0 7px 18px rgba(0,0,0,.12),
    inset 0 0 0 1px rgba(0,0,0,.045);

  transform:translateY(-2px);
}

/* STAGGER */
.notsi .inf2 a:nth-child(1){
  transition-delay:.04s;
}

.notsi .inf2 a:nth-child(2){
  transition-delay:.09s;
}

.notsi .inf2 a:nth-child(3){
  transition-delay:.14s;
}

/* ACTIVE */
.post:hover .notsi::before,
.ac-hover-on .notsi::before{
  opacity:1;
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2{
  opacity:1;
  transform:translateY(0) scale(1);
}

.post:hover .notsi .inf2 a,
.ac-hover-on .notsi .inf2 a{
  opacity:1;
  transform:translateY(0);
}

{/block:IndexPage}

