<script>
document.addEventListener("DOMContentLoaded", function() {
  // 1. CLICK NAVIGATION SETUP
  const menuToggle = document.getElementById("customNavToggle");
  const popMenu = document.getElementById("customNavMenu");

  if(menuToggle && popMenu) {
    menuToggle.addEventListener("click", function(e) {
      e.stopPropagation();
      menuToggle.classList.toggle("is-active");
      popMenu.classList.toggle("is-open");
    });

    // Close menu when clicking outside of the active sidebar module
    document.addEventListener("click", function(e) {
      if (!popMenu.contains(e.target) && !menuToggle.contains(e.target)) {
        menuToggle.classList.remove("is-active");
        popMenu.classList.remove("is-open");
      }
    });
  }

  // 2. AUDIO PLAYBACK WITH REWORKED INTERACTIVE STATES
  const audioEl = document.getElementById("acMiniAudio");
  const playPauseBtn = document.getElementById("acMiniToggle");
  const iconState = document.getElementById("acMiniIcon");
  const vinylAccent = document.getElementById("sbVinylAccent");
  const progressBar = document.getElementById("sbPlayerProgress");
  
  if (audioEl && playPauseBtn) {
    // Dynamic integration mapping to ensure spin & progress match playback exactly
    audioEl.addEventListener("play", function() {
      iconState.className = "player-shape-icon pause-state";
      if(vinylAccent) vinylAccent.classList.add("is-playing");
    });

    audioEl.addEventListener("pause", function() {
      iconState.className = "player-shape-icon play-state";
      if(vinylAccent) vinylAccent.classList.remove("is-playing");
    });

    audioEl.addEventListener("timeupdate", function() {
      if(progressBar && audioEl.duration) {
        const pct = (audioEl.currentTime / audioEl.duration) * 100;
        progressBar.style.width = pct + "%";
      }
    });

    audioEl.addEventListener("ended", function() {
      if(progressBar) progressBar.style.width = "0%";
      // If a next-track function exists globally on your theme, fire it here:
      const nextBtn = document.getElementById("sbNext");
      if(nextBtn) nextBtn.click();
    });
  }
});
</script>

