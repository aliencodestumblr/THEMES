/* ---------------- PERMALINK DO POST (INFERIOR) ---------------- */
{block:IndexPage}
.post-footer {
  width: 100%;
  height: 48px;
  margin: 0 !important;
  padding: 0 16px !important;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.8) !important;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(17, 17, 17, 0.06) !important;
  box-sizing: border-box;
}

.pf-left, .pf-right {
  display: flex;
  align-items: center;
  height: 100%;
}

.pf-notes {
  display: flex;
  align-items: center;
  gap: 6px;
  text-decoration: none !important;
  color: #111111 !important;
  font-family: "Plus Jakarta Sans", sans-serif;
  transition: opacity 0.2s ease;
}

.pf-notes:hover {
  opacity: 0.6;
}

.pf-num {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: -0.2px;
}

.pf-lab {
  font-size: 9px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1px;
  opacity: 0.4;
}

.pf-right {
  gap: 8px;
}

.pf-btn {
  position: relative;
  height: 32px;
  width: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111111 !important;
  background: transparent;
  border-radius: 6px;
  transition: background 0.2s ease, transform 0.1s ease;
}

.pf-btn svg {
  width: 14px;
  height: 14px;
  opacity: 0.7;
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.pf-btn::after {
  content: attr(data-tooltip);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%) translateY(-4px) scale(0.9);
  padding: 4px 8px;
  background: #111111;
  color: #ffffff;
  font-family: "Plus Jakarta Sans", sans-serif;
  font-size: 9px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  border-radius: 4px;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.15s ease, transform 0.15s ease;
  white-space: nowrap;
}

.pf-btn:hover {
  background: rgba(17, 17, 17, 0.05);
}

.pf-btn:hover svg {
  opacity: 1;
  transform: scale(1.05);
}

.pf-btn:hover::after {
  opacity: 1;
  transform: translateX(-50%) translateY(-8px) scale(1);
}

.pf-btn:active {
  transform: scale(0.95);
}

.post-footer *, .post-footer *::before, .post-footer *::after {
  box-sizing: border-box;
}
{/block:IndexPage}

