<script>
(function($){
  if(!window.jQuery) return;

  var $win = $(window);
  var $doc = $(document);
  var $container = $('#posts');
  if(!$container.length) return;

  if($container.data('acMasonryTopPermalinkDone') === 1) return;
  $container.data('acMasonryTopPermalinkDone',1);

  var acProcessing = false;
  var layoutTimer = null;
  var scanTimer = null;
  var mutationObserver = null;

  $('#ac-hover-script-safety,#ac-single-script-safety,#ac-clean-top-permalink-style,#ac-final-single-style,#ac-masonry-top-style').remove();

  $('<style id="ac-masonry-top-style">' +
    '#posts{position:relative!important;}' +
    '#posts>.posts{position:absolute;z-index:1;box-sizing:border-box;display:block;}' +
    '#posts>.posts.ac-prep{visibility:hidden!important;opacity:0!important;pointer-events:none!important;z-index:-1!important;}' +
    '#posts>.posts.is-ready{visibility:visible!important;opacity:1!important;pointer-events:auto!important;}' +

    '.notsi,[data-ac-hover-root],.ac-hover-root{display:none!important;}' +

    '.ac-media-post>.post-top{display:none!important;}' +
    '.ac-media-post .post-top{display:none!important;}' +

    '.ac-media-post .caption .tumblr_blog,' +
    '.ac-media-post .caption .tumblr_avatar,' +
    '.ac-media-post .caption .reblog-header,' +
    '.ac-media-post .caption .reblog-list-header,' +
    '.ac-media-post .caption .tmblr-attribution,' +
    '.ac-media-post .caption .npf_username,' +
    '.ac-media-post .caption .npf_blog,' +
    '.ac-media-post .caption header{display:none!important;}' +

    '.ac-media-post .caption p:empty,' +
    '.ac-media-post .caption div:empty{display:none!important;}' +
  '</style>').appendTo('head');

  function safe(fn){
    try{ fn(); }catch(e){}
  }

  function throttle(fn, wait){
    var t = null;
    return function(){
      if(t) return;
      t = setTimeout(function(){
        t = null;
        fn();
      }, wait);
    };
  }

  function scopePosts($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    return $scope.filter('.posts').add($scope.find('.posts'));
  }

  function removeHoverStuff($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);

    $scope.find('.notsi,[data-ac-hover-root]').remove();

    $scope.find('.ac-hover-root,.ac-hover-on,.ac-npf-media,.ac-hover-root--npf-wide')
      .removeClass('ac-hover-root ac-hover-on ac-npf-media ac-hover-root--npf-wide')
      .css({
        position:'',
        inset:'',
        top:'',
        left:'',
        right:'',
        bottom:'',
        width:'',
        height:'',
        zIndex:''
      });

    $('#npf-hover-template').remove();
  }

  function hasMedia($post){
    if(!$post || !$post.length) return false;

    if($post.find(
      '.photo-slideshow,' +
      '.photoset-static,' +
      '.photoset-item,' +
      '.media-wrap,' +
      '.npf_photoset,' +
      '.npf_grid,' +
      '.npf_container,' +
      '.npf_group,' +
      '.npf_row,' +
      '.npf_col,' +
      '.npf_image,' +
      '.tmblr-full,' +
      'figure.tmblr-full,' +
      '.npf_video_container,' +
      '.npf_video,' +
      'video,' +
      '.video'
    ).length){
      return true;
    }

    return $post.find('img,iframe').filter(function(){
      var $el = $(this);

      if($el.closest('#sidebar,#topbar,.cc,#ltop,.sb-card,.brand-icon,.tab-permalink-row,.post-top').length) return false;

      var src = (
        $el.attr('src') ||
        $el.attr('srcset') ||
        $el.attr('data-src') ||
        ''
      ).toLowerCase();

      return (
        src.indexOf('media.tumblr.com') !== -1 ||
        src.indexOf('64.media.tumblr.com') !== -1 ||
        src.indexOf('va.media.tumblr.com') !== -1 ||
        src.indexOf('tumblr.com/video') !== -1 ||
        src.indexOf('youtube.com') !== -1 ||
        src.indexOf('vimeo.com') !== -1 ||
        src.indexOf('spotify.com') !== -1 ||
        src.indexOf('soundcloud.com') !== -1
      );
    }).length > 0;
  }

  function classifyPosts($scope){
    scopePosts($scope).each(function(){
      var $post = $(this);
      var media = hasMedia($post);

      $post
        .toggleClass('ac-media-post', media)
        .toggleClass('ac-text-post', !media);

      if(media){
        $post.children('.post-top').remove();
      }
    });
  }

  function initPhotosets($scope){
    if(!$.fn.pxuPhotoset) return;

    $scope.find('.photo-slideshow').each(function(){
      if(this._acPXUInited) return;
      this._acPXUInited = true;

      $(this).pxuPhotoset({
        lightbox:true,
        rounded:false,
        gutter:'1px',
        photoset:'.photo-slideshow',
        photoWrap:'.photo-data',
        photo:'.pxu-photo'
      });
    });
  }

  function initUnnest($scope){
    if(!$.fn.unnest) return;

    scopePosts($scope).each(function(){
      var $post = $(this);

      if($post.data('acUnnestDone') === 1) return;
      $post.data('acUnnestDone',1);

      $post.unnest({
        yourCaption:".caption",
        wrapName:".tumblr_parent",
        newCaptionUsername:false,
        originalPostCaptionUsername:false,
        tumblrAvatars:false,
        tumblrAvatarsName:".tumblr_avatar",
        usernameColon:false
      });
    });
  }

  function stripMediaUsernames($scope){
    scopePosts($scope).filter('.ac-media-post').each(function(){
      var $post = $(this);

      $post.children('.post-top').remove();

      $post.find('.caption').each(function(){
        var $cap = $(this);

        $cap.find(
          '.tumblr_avatar,' +
          '.reblog-header,' +
          '.reblog-list-header,' +
          '.tmblr-attribution,' +
          '.npf_username,' +
          '.npf_blog,' +
          'header'
        ).remove();

        $cap.find('a.tumblr_blog').each(function(){
          var $a = $(this);
          var $parent = $a.parent();

          $a.remove();

          if($parent.length && $.trim($parent.text()) === '' && !$parent.find('img,video,iframe,figure,.tmblr-full').length){
            $parent.remove();
          }
        });

        $cap.find('.tumblr_parent').each(function(){
          var $wrap = $(this);

          $wrap.find('.tumblr_avatar,.tumblr_blog').remove();

          if($.trim($wrap.text()) === '' && !$wrap.find('img,video,iframe,figure,.tmblr-full').length){
            $wrap.remove();
          }
        });

        $cap.find('p,div').each(function(){
          var $el = $(this);

          if($.trim($el.text()) === '' && !$el.find('img,video,iframe,figure,.tmblr-full').length){
            $el.remove();
          }
        });
      });
    });
  }

  function cleanupNPFMediaUrls($scope){
    $scope.find('a[href]').each(function(){
      var $a = $(this);
      var hrefRaw = $a.attr('href') || '';
      var href = hrefRaw.toLowerCase();
      var txt = $.trim($a.text() || '');

      var isMedia =
        href.indexOf('64.media.tumblr.com/') !== -1 ||
        href.indexOf('va.media.tumblr.com/') !== -1 ||
        href.indexOf('media.tumblr.com/') !== -1;

      if(!isMedia) return;

      if(txt && ($.trim(hrefRaw) === txt || $.trim(href) === txt.toLowerCase()) && $a.children().length === 0){
        var $p = $a.closest('p');

        if($p.length && $.trim($p.text()) === txt){
          $p.remove();
        } else {
          $a.remove();
        }
      }
    });
  }

  function firstRealChild($post){
    return $post.children().filter(function(){
      var $el = $(this);

      if($el.is('script,style,template,.notsi,[data-ac-hover-root]')) return false;

      return true;
    }).first();
  }

  function firstContentChild($post){
    return $post.children().filter(function(){
      var $el = $(this);

      if($el.is('script,style,template,.tab-permalink-row,.post-footer,.notsi,[data-ac-hover-root]')) return false;

      return true;
    }).first();
  }

  function moveTopPermalinkToTop($scope){
    scopePosts($scope).each(function(){
      var $post = $(this);
      var $bar = $post.children('.tab-permalink-row,.post-footer').first();

      if(!$bar.length){
        $bar = $post.find('.tab-permalink-row,.post-footer').first();
      }

      if(!$bar.length) return;

      $bar.addClass('ac-top-permalink-ready');

      var $first = firstRealChild($post);

      if($first.length && $first[0] === $bar[0]){
        return;
      }

      var $target = firstContentChild($post);

      if($target.length){
        $bar.insertBefore($target);
      } else {
        $post.prepend($bar);
      }
    });
  }

  function forceEager($scope){
    $scope.find('img[loading="lazy"]').each(function(){
      try{ this.loading = 'eager'; }catch(e){}
      $(this).attr('loading','eager');
    });

    $scope.find('iframe[loading="lazy"]').attr('loading','eager');
  }

  function processPosts($scope){
    if(acProcessing) return;

    acProcessing = true;

    var $posts = scopePosts($scope);

    if(!$posts.length){
      acProcessing = false;
      return;
    }

    safe(function(){ removeHoverStuff($posts); });
    safe(function(){ forceEager($posts); });
    safe(function(){ initPhotosets($posts); });

    safe(function(){ classifyPosts($posts); });
    safe(function(){ initUnnest($posts); });
    safe(function(){ classifyPosts($posts); });

    safe(function(){ cleanupNPFMediaUrls($posts); });
    safe(function(){ stripMediaUsernames($posts); });
    safe(function(){ moveTopPermalinkToTop($posts); });
    safe(function(){ stripMediaUsernames($posts); });

    watchMediaLoads($posts);

    acProcessing = false;
  }

  function getPostWidth(){
    var w = 0;

    $container.children('.posts').each(function(){
      var $p = $(this);
      if($p.hasClass('ac-prep')) return;

      var ow = Math.ceil($p.outerWidth(true) || 0);
      if(ow > w) w = ow;
    });

    if(w <= 0){
      $container.children('.posts').each(function(){
        var ow = Math.ceil($(this).outerWidth(true) || 0);
        if(ow > w) w = ow;
      });
    }

    if(w <= 0) w = 340;

    return w;
  }

  function getColumnCount(containerWidth, itemWidth){
    var cols = Math.max(1, Math.floor(containerWidth / itemWidth));

    if(cols > 4) cols = 4;

    return cols;
  }

  function layoutPosts(){
    var $items = $container.children('.posts');
    if(!$items.length) return;

    var containerWidth =
      Math.round($container.width()) ||
      Math.round($container.parent().width()) ||
      Math.round($win.width());

    var itemWidth = getPostWidth();
    var cols = getColumnCount(containerWidth, itemWidth);

    var usedWidth = cols * itemWidth;
    var leftOffset = Math.max(0, Math.floor((containerWidth - usedWidth) / 2));
    var heights = [];

    for(var i = 0; i < cols; i++){
      heights[i] = 0;
    }

    $container.css({
      position:'relative',
      height:''
    });

    $items.each(function(){
      var $item = $(this);

      $item.css({
        position:'absolute',
        display:'block'
      });

      var shortest = 0;

      for(var c = 1; c < cols; c++){
        if(heights[c] < heights[shortest]){
          shortest = c;
        }
      }

      var itemHeight =
        Math.ceil($item.outerHeight(true)) ||
        Math.ceil(this.getBoundingClientRect().height) ||
        1;

      var left = leftOffset + shortest * itemWidth;
      var top = heights[shortest];

      $item.css({
        left:left + 'px',
        top:top + 'px',
        right:'',
        bottom:'',
        zIndex:1,
        visibility:'visible',
        opacity:1,
        pointerEvents:'auto'
      });

      heights[shortest] += itemHeight;
    });

    var maxHeight = 0;

    for(var j = 0; j < heights.length; j++){
      if(heights[j] > maxHeight){
        maxHeight = heights[j];
      }
    }

    $container.css('height', Math.ceil(maxHeight) + 'px');
  }

  function requestLayout(){
    if(layoutTimer) clearTimeout(layoutTimer);

    layoutTimer = setTimeout(function(){
      layoutTimer = null;
      layoutPosts();
    }, 90);
  }

  function hidePosts($posts){
    if(!$posts || !$posts.length) return;

    $posts
      .removeClass('is-ready')
      .addClass('ac-prep')
      .css({
        visibility:'hidden',
        opacity:0,
        pointerEvents:'none',
        display:'block',
        position:'absolute',
        left:'-99999px',
        top:'0',
        zIndex:-1
      });
  }

  function showPosts($posts){
    if(!$posts || !$posts.length) return;

    $posts
      .removeClass('ac-prep')
      .addClass('is-ready')
      .css({
        visibility:'visible',
        opacity:1,
        pointerEvents:'auto',
        zIndex:1
      });
  }

  function layoutAndReveal($posts){
    processPosts($posts);

    function reveal(){
      showPosts($posts);
      layoutPosts();

      setTimeout(layoutPosts,180);
      setTimeout(layoutPosts,700);
      setTimeout(layoutPosts,1400);
    }

    if($.fn.imagesLoaded){
      $posts.imagesLoaded(function(){
        reveal();
      });
    } else {
      reveal();
    }
  }

  function watchMediaLoads($items){
    if(!$items || !$items.length) return;

    $items.find('img').each(function(){
      if(this._acMasonryWatchBound) return;
      this._acMasonryWatchBound = true;

      this.addEventListener('load', requestLayout, false);
      this.addEventListener('error', requestLayout, false);
    });

    $items.find('iframe').each(function(){
      if(this._acMasonryWatchBound) return;
      this._acMasonryWatchBound = true;

      this.addEventListener('load', requestLayout, false);
    });
  }

  function runSettledLayouts($scope){
    var delays = [180,500,1000,1800,2800];

    for(var i = 0; i < delays.length; i++){
      setTimeout(function(){
        if($scope && $scope.length){
          processPosts($scope);
        }

        layoutPosts();
      }, delays[i]);
    }
  }

  function scanForNewPosts(){
    if(scanTimer) clearTimeout(scanTimer);

    scanTimer = setTimeout(function(){
      scanTimer = null;

      var $new = $container.children('.posts').filter(function(){
        return !$(this).data('acScanned');
      });

      if(!$new.length) return;

      $new.each(function(){
        $(this).data('acScanned',1);
      });

      hidePosts($new);
      layoutAndReveal($new);
      runSettledLayouts($new);
    },90);
  }

  function initMutationObserver(){
    if(!window.MutationObserver) return;

    if(mutationObserver){
      try{ mutationObserver.disconnect(); }catch(e){}
    }

    mutationObserver = new MutationObserver(function(mutations){
      var found = false;

      for(var i = 0; i < mutations.length; i++){
        if(mutations[i].addedNodes && mutations[i].addedNodes.length){
          found = true;
          break;
        }
      }

      if(found){
        scanForNewPosts();
      }
    });

    try{
      mutationObserver.observe($container[0],{
        childList:true,
        subtree:false
      });
    }catch(e){}
  }

  function initInfiniteScroll(){
    if(!$.fn.infinitescroll) return;
    if(!document.getElementById('next')) return;
    if(!document.getElementById('pagination')) return;

    if($container.data('acInfiniteReady') === 1) return;
    $container.data('acInfiniteReady',1);

    $container.infinitescroll({
      navSelector:'#pagination',
      nextSelector:'#next',
      itemSelector:'.posts',
      loading:{
        selector:'#infscr-loading',
        img:'',
        msgText:'',
        finishedMsg:''
      },
      bufferPx:1200,
      appendCallback:false
    }, function(newElements){
      var $new = $(newElements).filter('.posts');

      if(!$new.length){
        $new = $(newElements).find('.posts');
      }

      if(!$new.length) return;

      $new.each(function(){
        $(this).data('acScanned',1);
      });

      hidePosts($new);
      $container.append($new);

      forceEager($new);
      layoutAndReveal($new);
      runSettledLayouts($new);
    });
  }

  $(document).ready(function(){
    var $initial = $container.children('.posts');

    $initial.each(function(){
      $(this).data('acScanned',1);
    });

    hidePosts($initial);

    initMutationObserver();

    forceEager($initial);
    layoutAndReveal($initial);
    initInfiniteScroll();
    runSettledLayouts($initial);

    $win.on('load.acMasonryTop resize.acMasonryTop', throttle(function(){
      processPosts($container.children('.posts'));
      requestLayout();
    },220));

    $win.on('scroll.acMasonryTop', throttle(function(){
      scanForNewPosts();
    },180));

    setTimeout(function(){
      processPosts($container.children('.posts'));
      showPosts($container.children('.posts'));
      layoutPosts();
    },800);

    setTimeout(function(){
      processPosts($container.children('.posts'));
      showPosts($container.children('.posts'));
      layoutPosts();
    },1800);

    setTimeout(function(){
      processPosts($container.children('.posts'));
      showPosts($container.children('.posts'));
      layoutPosts();
    },3000);
  });

})(window.jQuery);
</script>
