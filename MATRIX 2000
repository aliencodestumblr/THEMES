<script>
(function(){
  // 1. DOM Element Mapping matching your HTML
  var playerMain = document.getElementById('scmPlayerMain');
  var audio      = document.getElementById('acMiniAudio');
  var playBtn    = document.getElementById('acMiniToggle');
  var playIcon   = document.getElementById('acMiniIcon');
  var nextBtn    = document.getElementById('sbNext');
  var nameEl     = document.getElementById('sbTrackName');
  var artistEl   = document.getElementById('sbTrackArtist');
  
  // Drawer / Playlist Elements
  var playlistToggle = document.getElementById('scmPlaylistToggle');
  var playlistDrawer = document.getElementById('sbPlaylist');
  var songButtons    = document.querySelectorAll('.scm-playlist-list .sb-song');

  if (!audio || !playBtn || !nameEl || !artistEl) return;

  var currentIndex = 0;
  var tracks = [];

  // 2. Build the playlist array dynamically from your Tumblr HTML markup
  songButtons.forEach(function(btn, idx) {
    tracks.push({
      src: btn.getAttribute('data-src') || '',
      title: btn.getAttribute('data-title') || 'Unknown Title',
      artist: btn.getAttribute('data-artist') || 'Unknown Artist',
      element: btn
    });

    // Make track buttons clickable inside the drawer
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      loadTrack(idx, true);
    });
  });

  if (!tracks.length) return;

  // 3. Track Loading System
  function loadTrack(index, autoplay) {
    if (index < 0 || index >= tracks.length) index = 0;
    currentIndex = index;
    var track = tracks[currentIndex];

    // Set Audio Source & Meta data
    audio.src = track.src;
    nameEl.textContent = track.title;
    artistEl.textContent = track.artist;

    // Update active visual states in drawer index
    songButtons.forEach(function(btn) { btn.classList.remove('is-active'); });
    track.element.classList.add('is-active');

    if (autoplay) {
      audio.play().catch(function(err) { console.log("Playback blocked:", err); });
    } else {
      audio.load();
      updateUIState(false);
    }
  }

  // 4. Interface State Management (Classes match your CSS rules)
  function updateUIState(isPlaying) {
    if (isPlaying) {
      playerMain.classList.add('is-playing');
      if (playIcon) {
        playIcon.classList.remove('play-state');
        playIcon.classList.add('pause-state');
      }
    } else {
      playerMain.classList.remove('is-playing');
      if (playIcon) {
        playIcon.classList.remove('pause-state');
        playIcon.classList.add('play-state');
      }
    }
  }

  // 5. Control Logic Functions
  function togglePlay() {
    if (audio.paused) {
      audio.play().catch(function(err) { console.log("Playback blocked:", err); });
    } else {
      audio.pause();
    }
  }

  function nextTrack() {
    var nextIndex = (currentIndex + 1) % tracks.length;
    loadTrack(nextIndex, true);
  }

  // 6. Event Listeners
  playBtn.addEventListener('click', function(e) {
    e.preventDefault();
    togglePlay();
  });

  if (nextBtn) {
    nextBtn.addEventListener('click', function(e) {
      e.preventDefault();
      nextTrack();
    });
  }

  // Syncing interface state to native audio events
  audio.addEventListener('play', function() { updateUIState(true); });
  audio.addEventListener('pause', function() { updateUIState(false); });
  audio.addEventListener('ended', function() { nextTrack(); });

  // 7. Playlist Drawer Toggle & Outside Click Logic (Fixed Conflict)
  if (playlistToggle && playlistDrawer) {
    
    function openDrawer() {
      playlistDrawer.classList.add('is-open');
      playerMain.classList.add('drawer-active');
      playlistDrawer.style.display = 'flex';
    }

    function closeDrawer() {
      playlistDrawer.classList.remove('is-open');
      playerMain.classList.remove('drawer-active');
      playlistDrawer.style.display = 'none';
    }

    // Explicit toggle check
    playlistToggle.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation(); // Stop click from bubbling up immediately
      
      if (playlistDrawer.classList.contains('is-open')) {
        closeDrawer();
      } else {
        openDrawer();
      }
    });

    // Close only if clicking outside the player bar completely
    document.addEventListener('click', function(e) {
      if (!playerMain.contains(e.target)) {
        closeDrawer();
      }
    });
  }

  // Initialize player with first track index without firing auto play rules
  loadTrack(0, false);
})();
</script>

