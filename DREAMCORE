<style type="text/css">
/* ANTI-SCROLL LATERAL */
html { scrollbar-gutter: stable both-edges; }
body { overflow-y: scroll; }


/* ---------------- PLAYER DO SPOTIFY ---------------- */
:root{
  --sp-scale: 0.80;
  --sp-base-height: 80px;
}

article iframe[src*="spotify.com"],
iframe.spotify_audio_player {
  aspect-ratio: auto !important;
  width: calc(100% / var(--sp-scale)) !important;
  height: var(--sp-base-height) !important;
  transform: scale(var(--sp-scale)) !important;
  transform-origin: top left !important;
  display: block;
  border: 0;
  margin-bottom: calc(var(--sp-base-height) * (var(--sp-scale) - 1)) !important;
}

figure iframe.spotify_audio_player {
  max-height: none !important;
  width: calc(100% / var(--sp-scale)) !important;
}

@keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-moz-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-webkit-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-o-keyframes fadein {from {opacity:0;} to {opacity:1;}}

html, body, a, a:hover{cursor:crosshair;}

/* ---------------- CONTROLES ---------------- */
.cc {
    z-index: 100;
    position: fixed;
    top: 20px;
    right: 20px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 1s;
    padding: 0;
}

.cc svg {
    display: block;
    width: 11px;
    height: 11px;
    overflow: visible;
    color: {color:accent};
}

.cc svg path,
.cc svg circle,
.cc svg line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
}
     
iframe.tmblr-iframe {
    z-index: 999;
    right: 22px;
    top: 27px;
    opacity: 0;
    position: fixed;

    width: 0;

    {block:IfDarkTumblrControl}
    filter: invert(1);
    {/block:IfDarkTumblrControl}

    padding-right: 90px; /* smaller hover area */

    transform: scale(0.38);
    -webkit-transform: scale(0.38);

    transform-origin: 100% 0;
    -webkit-transform-origin: 100% 0;

    transition: opacity 0.35s ease;
    -webkit-transition: opacity 0.35s ease;
}

.tmblr-iframe:hover {
    opacity: 0.5 !important;
}
/* ---------------- IMAGENS EXPANDIDAS ---------------- */
.vignette, #vignette { opacity:0; }

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999;
  box-shadow:none !important;
  border-radius:2px !important;
  max-width:none;
}

.tmblr-lightbox, #tumblr_lightbox {
    z-index: 999999999;
  background-color:rgba({RGBcolor:background},.7) !important;
}

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999; 
  border:5px solid {color:background}; !important;
  box-shadow: 1px 1px 2px rgba(0,0,0,.1);
  -moz-box-sizing:border-box;
  box-sizing:border-box;
}

/* ---------------- ESTILO DE LINKS + MÍDIA ---------------- */
pre, code {
  overflow-x:auto;
  user-select:all;
  font-family:monospace;
  padding:4px 6px;
  line-height:14px;
  background:rgba(0,0,0,.04);
  margin:10px 0;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  cursor:crosshair; 
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  cursor:crosshair;
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
   cursor:crosshair; 
  width:calc(100% - 0);
  height:auto;
}
blockquote video {
  cursor:crosshair; 
  border-radius:4px;
  width:100%;
}

img {
  cursor:crosshair; 
  border:0;
  width:calc(100% - 0);
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
}

.npf_video,
.npf_video_container,
.tmblr-full,
figure.tmblr-full,
figure,
.npf_inst{
  margin:0 !important;
  padding:0 !important;
  line-height:1 !important;
}

.npf_video::after,
.npf_video_container::after,
figure::after,
.tmblr-full::after{
  content:none !important;
  display:none !important;
  height:0 !important;
}

/* ---------------- BODY ---------------- */
body {
  color:{color:text};
  background-color:{color:background};
  font:400 10.5px "Rajdhani", sans-serif;
  transition:1.3s;
  letter-spacing:0.5px;
  text-align:justify;
  line-height:15px;
  word-wrap:break-word;
  -webkit-animation-name:fadeIn; animation-name:fadeIn;
}


/* ------------ TÍTULOS DE CABEÇALHO DE POSTS DE TEXTO ------------ */
.caption h1,
.caption h2,
.caption h3,
.caption h4,
.caption h5,
.caption h6{
  margin:0 0 10px 0!important;

  font-family:'Work Sans', sans-serif!important;
  font-weight:700!important;

  color:{color:text}!important;

  text-align:left!important;
  text-transform:uppercase;

  letter-spacing:.8px;
  line-height:1.05!important;
}

.caption h1{
  font-size:20px!important;
}

.caption h2{
  font-size:18px!important;
}

.caption h3{
  font-size:16px!important;
}

.caption h4{
  font-size:14px!important;
}

.caption h5{
  font-size:13px!important;
}

.caption h6{
  font-size:12px!important;
}

.caption h1 + p,
.caption h2 + p,
.caption h3 + p,
.caption h4 + p,
.caption h5 + p,
.caption h6 + p{
  margin-top:6px!important;
}


/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */
.entry{
  width:630px;
  height:auto;
  margin: 0 auto !important;

  {block:PermalinkPage}
  width:450px;
  margin: 0 auto !important;
  {/block:PermalinkPage}
}

#posts{
  width:630px;
  margin: 20px auto 50px auto !important;

  transform: translateX(100px);
  

/* permitir transições, mas NÃO no transform — NÃO REMOVA */
  transition-property: opacity, filter;
  transition-duration: .0s;

  {block:PermalinkPage}
  width:450px;
  margin:35px auto 0 auto !important;
  transform: translateX(25px);
  {/block:PermalinkPage}
}

.posts{
  width:285px;
  margin:15px;
  margin-bottom:15px;
  
  background:{color:post background};
  padding:10px;

  border:1px solid {color:Borders};

  box-sizing:border-box;

  overflow:visible;
  opacity:1;
  transition:1s;

  {block:PermalinkPage}
  width:450px;
  margin:25px auto 0 auto;
  {/block:PermalinkPage}
}


/* ------------- LINHA DO USUÁRIO NO TOPO DO POST ------------- */
.post-top{
  margin: 0 0 8px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:0px;

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  letter-spacing:1.6px;
  text-transform:uppercase;

  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ------------- HOVER DO PERMALINK EM FOTO/VÍDEO ------------- */
{block:IndexPage}

.notsi{
  position:absolute;
  inset:0;

  display:flex;

  align-items:flex-start;
  justify-content:flex-start;

  padding-top:10px;
  padding-left:10px;

  overflow:hidden!important;
  pointer-events:none;

  z-index:999;
}

.notsi::before{
  content:"";
  position:absolute;
  inset:0;

  background:
    radial-gradient(
      circle at top left,
      rgba(255,255,255,.05),
      transparent 34%
    ),
    linear-gradient(
      135deg,
      rgba(0,0,0,.22),
      rgba(0,0,0,.03) 38%,
      transparent 72%
    );

  backdrop-filter:blur(4px);
  -webkit-backdrop-filter:blur(4px);

  opacity:0;

  transition:opacity .48s cubic-bezier(.22,1,.36,1);
}

.notsi .npf-box{
  position:relative;
  z-index:3;

  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:5px;

  pointer-events:none;

  opacity:1;
}

.notsi .inf2{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:5px;

  pointer-events:auto;
}

.notsi .inf2 a{
  position:relative;

  width:22px;
  height:22px;

  display:flex;
  align-items:center;
  justify-content:center;

  text-decoration:none;

  background:rgba(0,0,0,.84);

  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);

  border:1px solid rgba(255,255,255,.09);
  border-radius:2px;

  box-shadow:
    0 8px 18px rgba(0,0,0,.2),
    inset 0 1px 0 rgba(255,255,255,.04);

  color:rgba(255,255,255,.68);

  opacity:0;

  transform:
    translateX(-10px)
    translateY(-3px)
    scale(.94);

  transition:
    opacity .48s cubic-bezier(.22,1,.36,1),
    transform .52s cubic-bezier(.22,1,.36,1),
    background .22s ease,
    color .22s ease,
    border-color .22s ease;
}

.notsi .inf2 a::before{
  content:"";
  position:absolute;
  top:0;
  left:0;

  width:100%;
  height:1px;

  background:rgba(255,255,255,.08);
}

.notsi .inf2 a:hover{
  background:rgba(255,255,255,.96);
  color:#000;

  border-color:rgba(0,0,0,.14);

  transform:
    translateX(0)
    translateY(-1px)
    scale(1);
}

.notsi .inf2 i{
  font-size:9px;
  line-height:1;
}

.notsi .inf2 .rb-icon{
  width:9px;
  height:9px;
  display:block;
}

.notsi .inf2 .rb-icon path{
  fill:none;
  stroke:currentColor;
  stroke-width:1.4;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.notsi .inf2 a:nth-child(1){
  transition-delay:.04s;
}

.notsi .inf2 a:nth-child(2){
  transition-delay:.1s;
}

.notsi .inf2 a:nth-child(3){
  transition-delay:.16s;
}

.post:hover .notsi::before,
.ac-hover-on .notsi::before{
  opacity:1;
}

.post:hover .notsi .inf2 a,
.ac-hover-on .notsi .inf2 a{
  opacity:1;

  transform:
    translateX(0)
    translateY(0)
    scale(1);
}

{/block:IndexPage}

/* --------- TAMANHOS DE IMAGEM + VÍDEO / NÃO ALTERAR --------- */
.posts img{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
  transition:1s;
}

.video{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
}

.vsanna{ display:none; }


/* ---------------- ROLAGEM INFINITA ---------------- */
#infscr-loading{
  position:absolute;
  bottom:0;
  margin-left:50%;
  left:0px;
  text-align:center;
}

#infscr-loading img{
  display:none;
  width:20px;
  height:20px;
}


/* EFEITO DE CARREGAMENTO SUAVE */
{block:IndexPage}
.posts{
  transition: opacity .75s ease, transform .75s ease;
}
.posts:not(.is-ready){
  opacity:0;
  transform: translateY(10px);
}
.posts.is-ready{
  opacity:1;
  transform: translateY(0);
}
{/block:IndexPage}
/* FIM DO EFEITO DE CARREGAMENTO SUAVE */


/* ---------------- BARRA DE ROLAGEM ---------------- */
::-webkit-scrollbar{ width:8px; } ::-webkit-scrollbar-track{ background: transparent; } ::-webkit-scrollbar-thumb{ background: transparent; border-radius: 3px; } .is-scrolling ::-webkit-scrollbar-thumb{ background: {color:Accent}; } .is-scrolling ::-webkit-scrollbar-thumb:hover{ box-shadow: 0 0 6px rgba({RGBcolor:Accent}, .45); } *{ scrollbar-width: thin; scrollbar-color: transparent transparent; } .is-scrolling{ scrollbar-color: {color:Accent} transparent; }


/* ---------------- PAGINAÇÃO ---------------- */
.page-nav{
  width:min(700px, calc(100% - 40px));
  margin:50px auto 80px!important;

  display:flex;
  align-items:center;
