    var randomIndex = Math.floor(Math.random() * counts.length);
    var newCount = counts[randomIndex];
    el.textContent = newCount;
  }

  // Set the initial value
  updateCounter();

  // Update at random intervals between 3000ms and 7000ms (3–7 seconds)
  function scheduleUpdate() {
    var interval = Math.floor(Math.random() * 4000) + 3000; // 3000–7000 ms
    setTimeout(function() {
      updateCounter();
      scheduleUpdate(); // Schedule the next update
    }, interval);
  }

  scheduleUpdate();
})();
