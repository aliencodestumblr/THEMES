<script>
(function(){
  var bubble = document.querySelector('.cc');
  if(!bubble) return;

  var topPos = 22;
  var rightPos = 22;
  var size = 44;

  document.addEventListener('mousemove', function(e){
    var withinX = e.clientX >= (window.innerWidth - rightPos - size) &&
                  e.clientX <= (window.innerWidth - rightPos);

    var withinY = e.clientY >= topPos &&
                  e.clientY <= (topPos + size);

    if(withinX && withinY){
      bubble.classList.add('is-hover');
    } else {
      bubble.classList.remove('is-hover');
    }
  });

  document.addEventListener('mouseleave', function(){
    bubble.classList.remove('is-hover');
  });
})();
</script>

