<script>
(function(){
  if(window.__sbEnginesRunning) return;
  window.__sbEnginesRunning = true;

  var lastClockText = "";
  var currentUsers = Math.floor(Math.random() * 19) + 14;
  var clockTimer = null;
  var counterTimer = null;

  function pad(num){
    return String(num).padStart(2, "0");
  }

  function updateClock(){
    var clock = document.getElementById("sb-clock-val");
    if(!clock) return;

    var time = new Date().toLocaleTimeString("en-US", {
      timeZone: "America/Chicago",
      hour: "numeric",
      minute: "2-digit",
      hour12: true
    });

    if(time !== lastClockText){
      clock.textContent = time;
      lastClockText = time;
    }
  }

  function scheduleClock(){
    updateClock();

    clearTimeout(clockTimer);

    var now = new Date();
    var msUntilNextMinute =
      (60 - now.getSeconds()) * 1000 - now.getMilliseconds();

    clockTimer = setTimeout(scheduleClock, msUntilNextMinute + 50);
  }

  function updateCounter(){
    var counter = document.getElementById("sb-counter-val");
    if(!counter) return;

    counter.textContent = pad(currentUsers);
  }

  function scheduleCounter(){
    var change = Math.floor(Math.random() * 3) - 1;
    currentUsers += change;

    if(currentUsers < 10) currentUsers = 12;
    if(currentUsers > 45) currentUsers = 28;

    updateCounter();

    clearTimeout(counterTimer);
    counterTimer = setTimeout(
      scheduleCounter,
      Math.floor(Math.random() * 4000) + 5000
    );
  }

  function startSidebarEngines(){
    scheduleClock();
    updateCounter();

    clearTimeout(counterTimer);
    counterTimer = setTimeout(scheduleCounter, 3000);
  }

  if(document.readyState === "loading"){
    document.addEventListener("DOMContentLoaded", startSidebarEngines, { once:true });
  }else{
    startSidebarEngines();
  }
})();
</script>

