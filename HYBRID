<script>
(function($){
  if(!window.jQuery) return;

  var $win = $(window);
  var $container = $('#posts');
  if(!$container.length) return;

  // Clear older script injector remnants
  $('#ac-hover-script-safety,#ac-single-script-safety,#ac-clean-top-permalink-style,#ac-final-single-style,#ac-masonry-layout-style').remove();

  // Inject essential styles with explicit click safety rules (pointer-events & z-index)
  $('<style id="ac-masonry-layout-style">' +
    '#posts{position:relative!important; z-index:5!important;}' +
    '#posts>.posts{position:absolute;box-sizing:border-box;visibility:visible!important;opacity:1!important;display:block!important;pointer-events:auto!important;z-index:10!important;}' +
    '.notsi,[data-ac-hover-root],.ac-hover-root{display:none!important;}' +
    '.ac-media-post>.post-top{display:none!important;}' +
    '#pagination, .pagination, footer{position:relative!important; z-index:20!important; pointer-events:auto!important;}' +
  '</style>').appendTo('head');

  var layoutTimer = null;

  function safe(fn){ try{ fn(); }catch(e){} }

  function scopePosts($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);
    return $scope.filter('.posts').add($scope.find('.posts'));
  }

  function hasMedia($post){
    if(!$post || !$post.length) return false;

    if($post.find('.photo-slideshow,.media-wrap,.npf_photoset,.npf_grid,.npf_container,.npf_group,.npf_row,.npf_col,.npf_image,.tmblr-full,figure.tmblr-full,.npf_video_container,.npf_video,video').length){
      return true;
    }

    return $post.find('img,iframe').filter(function(){
      var $el = $(this);
      if($el.closest('#sidebar,#topbar,.cc,#ltop,.sb-card,.brand-icon').length) return false;

      var src = (
        $el.attr('src') ||
        $el.attr('srcset') ||
        $el.attr('data-src') ||
        ''
      ).toLowerCase();

      return (
        src.indexOf('media.tumblr.com') !== -1 ||
        src.indexOf('64.media.tumblr.com') !== -1 ||
        src.indexOf('va.media.tumblr.com') !== -1 ||
        src.indexOf('tumblr.com/video') !== -1 ||
        src.indexOf('youtube.com') !== -1 ||
        src.indexOf('vimeo.com') !== -1
      );
    }).length > 0;
  }

  function initPhotosets($scope){
    if(!$.fn.pxuPhotoset) return;

    $scope.find('.photo-slideshow').each(function(){
      if(this._acPXUInited) return;
      this._acPXUInited = true;

      $(this).pxuPhotoset({
        lightbox:true,
        rounded:false,
        gutter:'1px',
        photoset:'.photo-slideshow',
        photoWrap:'.photo-data',
        photo:'.pxu-photo'
      });
    });
  }

  function initUnnest($scope){
    if(!$.fn.unnest) return;

    scopePosts($scope).each(function(){
      var $post = $(this);
      if($post.data('acUnnestDone') === 1) return;

      $post.data('acUnnestDone',1);

      $post.unnest({
        yourCaption:".caption",
        wrapName:".tumblr_parent",
        newCaptionUsername:false,
        originalPostCaptionUsername:false,
        tumblrAvatars:false,
        tumblrAvatarsName:".tumblr_avatar",
        usernameColon:false
      });
    });
  }

  function cleanupNPFMediaUrls($scope){
    $scope.find('a[href]').each(function(){
      var $a = $(this);
      var hrefRaw = $a.attr('href') || '';
      var href = hrefRaw.toLowerCase();
      var txt = $.trim($a.text() || '');

      var isMedia =
        href.indexOf('64.media.tumblr.com/') !== -1 ||
        href.indexOf('va.media.tumblr.com/') !== -1 ||
        href.indexOf('media.tumblr.com/') !== -1;

      if(!isMedia) return;

      if(txt && ($.trim(hrefRaw) === txt || $.trim(href) === txt.toLowerCase()) && $a.children().length === 0){
        var $p = $a.closest('p');
        if($p.length && $.trim($p.text()) === txt) $p.remove();
        else $a.remove();
      }
    });
  }

  function moveFooterToTop($scope){
    scopePosts($scope).each(function(){
      var $post = $(this);
      var $footer = $post.find('.post-footer').first();

      if(!$footer.length) return;

      var media = hasMedia($post);

      $post
        .toggleClass('ac-media-post',media)
        .toggleClass('ac-text-post',!media);

      $footer.detach();

      var $target = $post.children().filter(function(){
        var $el = $(this);
        if($el.is('script,style,template,.post-footer,.notsi,[data-ac-hover-root]')) return false;
        return true;
      }).first();

      if($target.length) $footer.insertBefore($target);
      else $post.prepend($footer);
    });
  }

  function forceEager($scope){
    $scope.find('img[loading="lazy"]').each(function(){
      try{ this.loading = 'eager'; }catch(e){}
      $(this).attr('loading','eager');
    });
    $scope.find('iframe[loading="lazy"]').attr('loading','eager');
  }

  /* --- MASONRY GRID ENGINE --- */

  function getPostWidth(){
    var w = 0;
    $container.children('.posts').each(function(){
      var $p = $(this);
      var ow = Math.ceil($p.outerWidth(true) || 0);
      if(ow > w) w = ow;
    });

    if(w <= 0){
      $container.children('.posts').each(function(){
        var ow = Math.ceil($(this).outerWidth(true) || 0);
        if(ow > w) w = ow;
      });
    }
    return w > 0 ? w : 350;
  }

  function getColumnCount(containerWidth, itemWidth){
    var cols = Math.max(1, Math.floor(containerWidth / itemWidth));
    if(cols > 3) cols = 3; 
    return cols;
  }

  function layoutPosts(){
    var $items = $container.children('.posts');
    if(!$items.length) return;

    var containerWidth = Math.round($container.width()) || Math.round($win.width());
    var itemWidth = getPostWidth();
    var cols = getColumnCount(containerWidth, itemWidth);

    var usedWidth = cols * itemWidth;
    var leftOffset = Math.max(0, Math.floor((containerWidth - usedWidth) / 2));
    var heights = [];

    for(var i = 0; i < cols; i++) heights[i] = 0;

    $items.each(function(){
      var $item = $(this);

      var shortest = 0;
      for(var c = 1; c < cols; c++){
        if(heights[c] < heights[shortest]) shortest = c;
      }

      var itemHeight = Math.ceil($item.outerHeight(true)) || 1;
      var left = leftOffset + (shortest * itemWidth);
      var top = heights[shortest];

      $item.css({
        left: left + 'px',
        top: top + 'px'
      });

      heights[shortest] += itemHeight;
    });

    var maxHeight = 0;
    for(var j = 0; j < heights.length; j++){
      if(heights[j] > maxHeight) maxHeight = heights[j];
    }
    $container.css('height', Math.ceil(maxHeight) + 'px');
  }

  function requestLayout(){
    if(layoutTimer) clearTimeout(layoutTimer);
    layoutTimer = setTimeout(function(){
      layoutTimer = null;
      layoutPosts();
    }, 50);
  }

  function processPosts($scope){
    var $posts = scopePosts($scope);
    if(!$posts.length) return;

    safe(function(){ forceEager($posts); });
    safe(function(){ initPhotosets($posts); });
    safe(function(){ initUnnest($posts); });
    safe(function(){ cleanupNPFMediaUrls($posts); });
    safe(function(){ moveFooterToTop($posts); });
    
    $posts.find('img, iframe').one('load error', function(){
      requestLayout();
    });
  }

  function processAll(){
    processPosts($container.children('.posts'));
    layoutPosts();
  }

  $(document).ready(function(){
    processAll();

    if(window.MutationObserver){
      var observer = new MutationObserver(function(){
        clearTimeout(window.acMasonryTimer);
        window.acMasonryTimer = setTimeout(processAll, 100);
      });

      try{
        observer.observe($container[0],{
          childList:true,
          subtree:false
        });
      }catch(e){}
    }

    $win.on('load resize orientationchange', function(){
      clearTimeout(window.acMasonryTimer2);
      window.acMasonryTimer2 = setTimeout(layoutPosts, 100);
    });

    // Cascaded calculations as images load natively
    setTimeout(processAll,300);
    setTimeout(processAll,1000);
    setTimeout(processAll,2500);
  });

})(window.jQuery);
</script>
{/block:IndexPage}

<script>
document.addEventListener("DOMContentLoaded", function(){

  var audio = document.getElementById("acMiniAudio");
  var toggle = document.getElementById("acMiniToggle");
  var icon = document.getElementById("acMiniIcon");
  var next = document.getElementById("sbNext");
  var title = document.getElementById("sbTrackName");
  var artist = document.getElementById("sbTrackArtist");
  var songs = [].slice.call(document.querySelectorAll("#sbPlaylist .sb-song"));

  if(!audio || !toggle || !icon || !songs.length) return;

  var index = 0;

  function loadSong(i){
    index = i;
    var song = songs[index];

    audio.src = song.dataset.src;

    if(title) title.innerHTML = song.dataset.title || "Untitled";
    if(artist) artist.innerHTML = song.dataset.artist || "Unknown";
  }

  // Updates layout to show the dual-bar pause icon
  function showPlaying(){
    icon.classList.remove("play-state");
    icon.classList.add("pause-state");
    toggle.classList.add("is-playing");
  }

  // Updates layout to show the single play triangle
  function showPaused(){
    icon.classList.remove("pause-state");
    icon.classList.add("play-state");
    toggle.classList.remove("is-playing");
  }

  toggle.addEventListener("click", function(e){
    e.preventDefault();
    e.stopPropagation();

    if(!audio.src) loadSong(index);

    if(audio.paused){
      audio.play();
    } else {
      audio.pause();
    }
  });

  if(next){
    next.addEventListener("click", function(e){
      e.preventDefault();
      e.stopPropagation();

      index = (index + 1) % songs.length;
      loadSong(index);
      audio.play();
    });
  }

  audio.addEventListener("play", showPlaying);
  audio.addEventListener("pause", showPaused);
  audio.addEventListener("ended", function(){
    index = (index + 1) % songs.length;
    loadSong(index);
    audio.play();
  });

  // Init track data safely without fighting styles
  loadSong(0);

});
</script>

