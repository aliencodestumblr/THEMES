@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600&family=Rajdhani:wght@600;700&display=swap');

:root{
  --sb-w: 242px;
  --sb-pad: 14px;
  --sb-top-pad: 18px;
  --sb-player-space: 114px;

  --sb-text: #2b2b2b;
  --sb-muted: rgba(0,0,0,.46);
  --sb-line: rgba(0,0,0,.07);
  --sb-blur: blur(24px) saturate(180%);
  --sb-radius: 16px;
}

#sidebar,
#sidebar *{
  box-sizing:border-box;
}

#sidebar{
  position:fixed;
  top:0;
  left:0;
  width:var(--sb-w);
  height:100vh;
  z-index:999999;
  overflow:visible;
  user-select:none;
  background:
    linear-gradient(180deg, rgba(255,255,255,.84) 0%, rgba(255,255,255,.60) 100%);
  backdrop-filter:var(--sb-blur);
  -webkit-backdrop-filter:var(--sb-blur);
  border-right:1px solid rgba(0,0,0,.06);
  box-shadow:
    0 18px 38px rgba(0,0,0,.06),
    inset 0 1px 0 rgba(255,255,255,.70),
    inset 0 0 0 1px rgba(255,255,255,.08);
}

#sidebar::before{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  background:
    linear-gradient(160deg, rgba(255,255,255,.18) 0%, transparent 30%, rgba(255,255,255,.06) 58%, transparent 100%);
  opacity:.95;
}

#sidebar .sb-scroll{
  position:relative;
  z-index:3;
  height:100%;
  overflow-y:auto;
  overflow-x:hidden;
  padding:var(--sb-top-pad) var(--sb-pad);
  padding-bottom:calc(var(--sb-top-pad) + var(--sb-player-space));
  scrollbar-width:thin;
  scrollbar-color:rgba(0,0,0,.10) transparent;
}

#sidebar .sb-scroll::-webkit-scrollbar{
  width:4px;
}
#sidebar .sb-scroll::-webkit-scrollbar-track{
  background:transparent;
}
#sidebar .sb-scroll::-webkit-scrollbar-thumb{
  background:rgba(0,0,0,.10);
  border-radius:10px;
}

/* vertical title */
#sidebar .sb-mid-title{
  position:fixed;
  top:18px;
  left:calc(var(--sb-w) + 18px);
  margin:0;
  padding:0;
  writing-mode:vertical-rl;
  text-orientation:mixed;
  white-space:nowrap;
  pointer-events:none;
  z-index:100;
  font-family:"Orbitron", sans-serif;
  font-weight:400;
  font-size:18px;
  letter-spacing:10px;
  color:#000;
  opacity:.52;
  transform:rotate(180deg);
  text-shadow:
    0 0 1px rgba(0,0,0,.18),
    0 0 6px rgba(0,0,0,.08);
}

#sidebar .sb-mid-title span{
  position:relative;
  display:block;
  animation:sbTitleJitter 4.8s infinite steps(1,end);
}

#sidebar .sb-mid-title .glitch-bar{
  position:absolute;
  left:50%;
  transform:translateX(-50%);
  width:2px;
  border-radius:2px;
  background:rgba(0,0,0,.42);
  opacity:0;
  pointer-events:none;
}

#sidebar .sb-mid-title .g1{ top:8%; height:24px; animation:sbBarFlash1 4.2s infinite steps(1,end); }
#sidebar .sb-mid-title .g2{ top:32%; height:18px; animation:sbBarFlash2 5s infinite steps(1,end); }
#sidebar .sb-mid-title .g3{ top:56%; height:22px; animation:sbBarFlash3 4.6s infinite steps(1,end); }
#sidebar .sb-mid-title .g4{ top:79%; height:16px; animation:sbBarFlash4 5.4s infinite steps(1,end); }

@keyframes sbTitleJitter{
  0%,100%{ opacity:.58; transform:translate(0,0); }
  8%{ opacity:.80; }
  9%{ transform:translate(-1px,0); }
  10%{ transform:translate(1px,0); }
  11%{ transform:translate(0,0); }
  47%{ opacity:.76; transform:translate(0,1px); }
  48%{ transform:translate(0,-1px); }
  49%{ transform:translate(0,0); }
  79%{ opacity:.82; transform:translate(1px,0); }
  80%{ transform:translate(-1px,0); }
  81%{ transform:translate(0,0); }
}

@keyframes sbBarFlash1{ 0%,100%{opacity:0;} 9%{opacity:.58;} 11%{opacity:0;} }
@keyframes sbBarFlash2{ 0%,100%{opacity:0;} 29%{opacity:.4;} 30%{opacity:0;} 47%{opacity:.66;} 49%{opacity:0;} }
@keyframes sbBarFlash3{ 0%,100%{opacity:0;} 63%{opacity:.34;} 64%{opacity:0;} 79%{opacity:.72;} 81%{opacity:0;} }
@keyframes sbBarFlash4{ 0%,100%{opacity:0;} 18%{opacity:.24;} 19%{opacity:0;} 86%{opacity:.5;} 87%{opacity:0;} }

