<!-- // MUSIC PLAYER SCRIPTS // -->
<script>
(function(){
  var audio = document.getElementById('audio');
  var playBtn = document.querySelector('.sb-play');
  var nextBtn = document.querySelector('.sb-next');
  var nameEl = document.getElementById('sb-song-title');
  var artistEl = document.getElementById('sb-song-artist');
  var bars = document.getElementById('freq-bars');
  var dataEl = document.getElementById('sb-playlist-data');
  var playerWrap = document.querySelector('.hd-music-player');

  if(!audio || !playBtn || !nextBtn || !nameEl || !artistEl || !dataEl) return;

  var playlist = [];
  try {
    playlist = JSON.parse(dataEl.textContent.trim());
  } catch(e) {
    playlist = [];
  }

  playlist = playlist.filter(function(track){
    return track && track.src && track.src.trim() !== "";
  });

  if(!playlist.length) return;

  var index = 0;

  function setState(playing){
    playBtn.classList.toggle('is-playing', playing);
    if(playerWrap){
      playerWrap.classList.toggle('playing', playing);
    }
    if(bars){
      bars.classList.toggle('is-paused', !playing);
    }
  }

  function loadTrack(i, autoplay){
    if(i < 0) i = 0;
    if(i >= playlist.length) i = 0;
    index = i;

    var track = playlist[index];
    audio.src = track.src;
    nameEl.textContent = track.title || '';
    artistEl.textContent = track.artist || '';

    audio.load();

    if(autoplay){
      audio.play().catch(function(err){
        console.log('Playback blocked or failed:', err);
        setState(false);
      });
    } else {
      setState(false);
    }
  }

  function togglePlay(){
    if(audio.paused){
      audio.play().catch(function(err){
        console.log('Playback blocked or failed:', err);
        setState(false);
      });
    } else {
      audio.pause();
    }
  }

  function nextTrack(autoplay){
    index = (index + 1) % playlist.length;
    loadTrack(index, autoplay);
  }

  playBtn.addEventListener('click', function(e){
    e.preventDefault();
    togglePlay();
  });

  nextBtn.addEventListener('click', function(e){
    e.preventDefault();
    nextTrack(true);
  });

  audio.addEventListener('play', function(){
    setState(true);
  });

  audio.addEventListener('pause', function(){
    setState(false);
  });

  audio.addEventListener('ended', function(){
    nextTrack(true);
  });

  audio.addEventListener('error', function(){
    console.log('Audio failed to load:', audio.src);
    setState(false);
  });

  loadTrack(0, false);
})();
</script>

