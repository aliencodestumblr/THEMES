<style type="text/css">
/* ANTI-SCROLL LATERAL */
html { scrollbar-gutter: stable both-edges; }
body { overflow-y: scroll; }


/* ---------------- PLAYER DO SPOTIFY ---------------- */
:root{
  --sp-scale: 0.80;
  --sp-base-height: 80px;
}

article iframe[src*="spotify.com"],
iframe.spotify_audio_player {
  aspect-ratio: auto !important;
  width: calc(100% / var(--sp-scale)) !important;
  height: var(--sp-base-height) !important;
  transform: scale(var(--sp-scale)) !important;
  transform-origin: top left !important;
  display: block;
  border: 0;
  margin-bottom: calc(var(--sp-base-height) * (var(--sp-scale) - 1)) !important;
}

figure iframe.spotify_audio_player {
  max-height: none !important;
  width: calc(100% / var(--sp-scale)) !important;
}

@keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-moz-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-webkit-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-o-keyframes fadein {from {opacity:0;} to {opacity:1;}}

html {
cursor:crosshair;
}

/* ---------------- CONTROLES ---------------- */
.cc {
    z-index: 100;
    position: fixed;
    top: 20px;
    right: 20px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 1s;
    padding: 0;
}

.cc svg {
    display: block;
    width: 11px;
    height: 11px;
    overflow: visible;
    color: {color:accent};
}

.cc svg path,
.cc svg circle,
.cc svg line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
}
     
iframe.tmblr-iframe {
    z-index: 999;
    right: 22px;
    top: 27px;
    opacity: 0;
    position: fixed;

    width: 0;

    {block:IfDarkTumblrControl}
    filter: invert(1);
    {/block:IfDarkTumblrControl}

    padding-right: 90px; 

    transform: scale(0.38);
    -webkit-transform: scale(0.38);

    transform-origin: 100% 0;
    -webkit-transform-origin: 100% 0;

    transition: opacity 0.35s ease;
    -webkit-transition: opacity 0.35s ease;
}

.tmblr-iframe:hover {
    opacity: 0.5 !important;
}
/* ---------------- IMAGENS EXPANDIDAS ---------------- */
.vignette, #vignette { opacity:0; }

.lightbox-image, #tumblr_lightbox img {
  box-shadow:none !important;
  border-radius:2px !important;
  max-width:none;
}

.tmblr-lightbox, #tumblr_lightbox {
  background-color:rgba({RGBcolor:background},.7) !important;
}

.lightbox-image, #tumblr_lightbox img {
  border:5px solid {color:background}; !important;
  box-shadow: 1px 1px 2px rgba(0,0,0,.1);
  -moz-box-sizing:border-box;
  box-sizing:border-box;
}

/* ---------------- ESTILO DE LINKS + MÍDIA ---------------- */
pre, code {
  overflow-x:auto;
  user-select:all;
  font-family:monospace;
  padding:4px 6px;
  line-height:14px;
  background:rgba(0,0,0,.04);
  margin:10px 0;
  border-radius:4px;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  cursor:help;
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  cursor:help;
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
  border-radius:4px;
  width:calc(100% - 0);
  height:auto;
}
blockquote video {
  border-radius:4px;
  width:100%;
}

img {
  border-radius:4px;
  border:0;
  width:calc(100% - 0);
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
}

.npf_video,
.npf_video_container,
.tmblr-full,
figure.tmblr-full,
figure,
.npf_inst{
  margin:0 !important;
  padding:0 !important;
  line-height:1 !important;
}

.npf_video::after,
.npf_video_container::after,
figure::after,
.tmblr-full::after{
  content:none !important;
  display:none !important;
  height:0 !important;
}

/* ---------------- BODY ---------------- */
body {
  color:{color:text};
  background-color:#ffffff;
  font:400 10.5px "Rajdhani", sans-serif;
  transition:1.3s;
  letter-spacing:0.5px;
  text-align:justify;
  line-height:15px;
  word-wrap:break-word;
  -webkit-animation-name:fadeIn; animation-name:fadeIn;
}


/* ---------------- TÍTULOS DE CABEÇALHO DE POSTS DE TEXTO ---------------- */
.caption h1,
.caption h2,
.caption h3,
.caption h4,
.caption h5,
.caption h6{
  margin:0 0 10px 0!important;

  font-family:'Work Sans', sans-serif!important;
  font-weight:700!important;

  color:{color:text}!important;

  text-align:left!important;
  text-transform:uppercase;

  letter-spacing:.8px;
  line-height:1.05!important;
}

.caption h1{
  font-size:20px!important;
}

.caption h2{
  font-size:18px!important;
}

.caption h3{
  font-size:16px!important;
}

.caption h4{
  font-size:14px!important;
}

.caption h5{
  font-size:13px!important;
}

.caption h6{
  font-size:12px!important;
}

.caption h1 + p,
.caption h2 + p,
.caption h3 + p,
.caption h4 + p,
.caption h5 + p,
.caption h6 + p{
  margin-top:6px!important;
}


/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */
.entry{
  width:800px;
  height:auto;
  margin: 0 auto !important;

  {block:PermalinkPage}
  width:700px;
  margin: 0 auto !important;
  {/block:PermalinkPage}
}

#posts{
  width:800px;
  margin: -3px auto 50px auto !important;
  
  
  /* POSIÇÃO DOS POSTS
   Este valor move todos os posts horizontalmente.
   Use números negativos para mover os posts para a ESQUERDA.
   Use números positivos para mover os posts para a DIREITA.
   Ajuste esse valor se quiser alinhar os posts melhor no layout. */
  transform: translateX(0px);
  

/* permitir transições, mas NÃO no transform — NÃO REMOVA */
  transition-property: opacity, filter;
  transition-duration: .0s;

  {block:PermalinkPage}
  width:700px;
  margin:30px auto 0 auto !important;
  transform: translateX(-25px);
  {/block:PermalinkPage}
}

.posts{
  width:350px;
  margin:25px;
  margin-bottom:25px;
  padding:0;
  overflow:visible;
  opacity:1;
  transition:1s;

  {block:PermalinkPage}
  width:700px;
  margin:25px auto 0 auto;
  {/block:PermalinkPage}
}

/* ---------------- LINHA DO USUÁRIO NO TOPO DO POST ---------------- */
.post-top{
  margin: 0 0 8px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:0px;

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  letter-spacing:1.6px;
  text-transform:uppercase;

  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ---------------- HOVER DO PERMALINK EM FOTO/VÍDEO ---------------- */
{block:IndexPage}
.notsi{
  position:absolute;
  inset:0;
  display:flex;
  align-items:flex-end;
  justify-content:flex-end;
  padding:12px;
  border-radius:3px;
  overflow:hidden;
  pointer-events:none;
  z-index:10;
}

.notsi::before{
  content:"";
  position:absolute;
  inset:0;
  border-radius:3px;
  background:
    linear-gradient(
      180deg,
      rgba(255,255,255,0.045) 0%,
      rgba(255,255,255,0.02) 44%,
      rgba(0,0,0,0.11) 100%
    );
  backdrop-filter:blur(8px);
  -webkit-backdrop-filter:blur(8px);
  opacity:0;
  transition:opacity .56s cubic-bezier(.22,1,.36,1);
}

.notsi .npf-box{
  position:relative;
  z-index:2;
  display:flex;
  flex-direction:column;
  align-items:flex-end;
  gap:0;
  pointer-events:none;
}

.notsi .inf{
  position:relative;
  z-index:3;

  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:6px;

  min-height:22px;
  padding:0 9px;

  background:#000000;

  border-radius:4px 4px 0 0;

  box-shadow:
    0 8px 18px rgba(0,0,0,0.18),
    inset 0 1px 0 rgba(255,255,255,0.04);

  font-family:"Orbitron","Inter",sans-serif;
  font-size:6px;
  font-weight:600;
  letter-spacing:1.35px;
  text-transform:uppercase;
  color:rgba(255,255,255,0.88);

  margin-bottom:0px;

  opacity:0;
  transform:translateX(18px);
  transition:
    opacity .6s cubic-bezier(.22,1,.36,1),
    transform .6s cubic-bezier(.22,1,.36,1);
}

.notsi .inf::before{
  content:"";
  width:7px;
  height:1px;
  background:rgba(255,255,255,0.55);
  flex:0 0 7px;
}

.notsi .inf2{
  position:relative;
  z-index:2;

  display:flex;
  align-items:center;
  justify-content:flex-end;

  background:#000000;

  border-radius:0 0 4px 4px;

  box-shadow:
    0 12px 24px rgba(0,0,0,0.20),
    inset 0 1px 0 rgba(255,255,255,0.03);

  opacity:0;
  transform:translateX(-20px);
  transition:
    opacity .66s cubic-bezier(.22,1,.36,1),
    transform .66s cubic-bezier(.22,1,.36,1);

  pointer-events:auto;
  overflow:hidden;
}

.notsi .inf2 a{
  position:relative;
  display:flex;
  align-items:center;
  justify-content:center;
  width:31px;
  height:28px;
  text-decoration:none;
  color:rgba(255,255,255,0.82);
  transition:
    color .24s ease,
    background .24s ease,
    transform .24s ease,
    opacity .52s cubic-bezier(.22,1,.36,1);
}

.notsi .inf2 a::after{
  content:"";
  position:absolute;
  inset:6px;
  border-radius:2px;
  background:rgba(255,255,255,0.02);
  opacity:.4;
  pointer-events:none;
  transition:opacity .24s ease;
}

.notsi .inf2 i{
  font-size:11px;
  line-height:1;
}

.notsi .inf2 .rb-icon{
  width:11px;
  height:11px;
  display:block;
}

.notsi .inf2 .rb-icon path{
  fill:none;
  stroke:currentColor;
  stroke-width:1.35;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.notsi .inf2 a:hover{
  background:rgba(255,255,255,0.055);
  color:#fff;
  transform:translateY(-1px);
}

.notsi .inf2 a:hover::after{
  opacity:.7;
}

.notsi .inf2 a:nth-child(1){
  opacity:0;
  transform:translateX(-8px);
  transition-delay:.1s;
}
.notsi .inf2 a:nth-child(2){
  opacity:0;
  transform:translateX(-12px);
  transition-delay:.16s;
}
.notsi .inf2 a:nth-child(3){
  opacity:0;
  transform:translateX(-16px);
  transition-delay:.22s;
}

.post:hover .notsi::before,
.ac-hover-on .notsi::before{
  opacity:1;
}

.post:hover .notsi .inf,
.ac-hover-on .notsi .inf{
  opacity:1;
  transform:translateX(0) translateY(0);
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2{
  opacity:1;
  transform:translateX(0) translateY(0);
}

.post:hover .notsi .inf2 a,
.ac-hover-on .notsi .inf2 a{
  opacity:1;
  transform:translateX(0);
}
{/block:IndexPage}

