/* ---------------- TOOLTIP + VOLTAR AO TOPO ---------------- */
#s-m-t-tooltip{
  position:absolute;
  max-width:220px;
  padding:4px 8px;
  margin-top:10px;
  border-radius:2px;
  background: rgba(10,10,10,.96);
  font-family:"Rajdhani", sans-serif;
  font-size:8.5px;
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:2px;
  color:#fff;
  line-height:1.2;
  opacity:0;
  z-index: 999999999999;
  pointer-events:none;
  transform: translateY(4px);
  transition: opacity .16s ease, transform .16s ease;
  box-shadow:
    0 0 0 1px rgba(255,255,255,.05),
    0 6px 14px rgba(0,0,0,.35);
}
#s-m-t-tooltip.show{
  opacity:1;
  transform: translateY(0);
  box-shadow:
    0 0 0 1px rgba(255,255,255,.06),
    0 8px 18px rgba(0,0,0,.45);
}

#ltop{
  position:fixed;
  bottom:20px;
  right:20px;
  width:35px;
  height:35px;

  display:flex;
  align-items:center;
  justify-content:center;

  color:{color:accent};
  text-decoration:none;

  opacity:0;
  visibility:hidden;
  pointer-events:none;

  transition:opacity .3s ease, transform .3s ease;
  transform:translateY(6px);

  z-index:100;
}

#ltop.show{
  opacity:1;
  visibility:visible;
  pointer-events:auto;
  transform:translateY(0);
}

#ltop svg{
  display:block;
