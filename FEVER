  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(135deg, rgba(255,255,255,.14), transparent 54%),
    radial-gradient(circle at top right, rgba(255,255,255,.16), transparent 40%);
  pointer-events:none;
}

.player-top{
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  min-width: 0;
}

.player-meta{
  min-width: 0;
  flex: 1 1 auto;
  display: grid;
  grid-template-columns: 32px minmax(0,1fr);
  align-items: center;
  gap: 9px;
}

.player-disc-wrap{
  display: flex;
  align-items: center;
  justify-content: center;
}

.player-disc{
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background:
    radial-gradient(circle at center, rgba(255,255,255,.95) 0 3px, rgba(0,0,0,.14) 3px 4px, transparent 4px),
    linear-gradient(145deg, rgba(0,0,0,.14), rgba(255,255,255,.45));
  border: 1px solid rgba(0,0,0,.06);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.4),
    0 4px 10px rgba(0,0,0,.05);
  animation: spinDisc 5s linear infinite;
  animation-play-state: paused;
}

.hd-music-player.playing .player-disc{
  animation-play-state: running;
}

@keyframes spinDisc{
  from{ transform: rotate(0deg); }
  to{ transform: rotate(360deg); }
}

.track-details{
  min-width: 0;
  max-width: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  font-family: "Orbitron", sans-serif;
  text-transform: uppercase;
  line-height: 1.02;
}

.track-topline{
  display: block;
  margin-bottom: 3px;
  font-size: 6px;
  letter-spacing: 1.7px;
  color: rgba(0,0,0,.34);
}

.track-name{
  display: block;
  width: 100%;
  max-width: 100%;
  font-size: 8px;
  letter-spacing: 1.15px;
  color: #111;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.track-artist{
  display: block;
  width: 100%;
  max-width: 100%;
  margin-top: 3px;
  font-size: 6px;
  letter-spacing: .95px;
  color: rgba(0,0,0,.45);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.player-controls{
  position: relative;
  z-index: 3;
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 6px;
}

.single-play-btn,
.player-next-btn{
  border: none;
  cursor: pointer;
  transition: transform .2s ease, box-shadow .2s ease, opacity .2s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.single-play-btn:hover,
.player-next-btn:hover{
  transform: translateY(-1px);
}

.single-play-btn{
  width: 28px;
  height: 28px;
  border-radius: 9px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.96) 0%, rgba(255,255,255,.78) 100%);
  border: 1px solid rgba(0,0,0,.06);
  box-shadow:
    0 5px 12px rgba(0,0,0,.07),
    inset 0 1px 0 rgba(255,255,255,.75);
}

.player-next-btn{
  width: 20px;
  height: 20px;
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.88) 0%, rgba(255,255,255,.68) 100%);
  border: 1px solid rgba(0,0,0,.05);
  box-shadow:
    0 3px 8px rgba(0,0,0,.05),
    inset 0 1px 0 rgba(255,255,255,.7);
}

.single-play-btn i,
.player-next-btn i{
  color: #111;
  line-height: 1;
}

.single-play-btn i{
  font-size: 14px !important;
}

.player-next-btn i{
  font-size: 11px !important;
}

.single-play-btn i:last-child{
  display: none;
}

.single-play-btn.is-playing i:first-child{
  display: none;
}

.single-play-btn.is-playing i:last-child{
  display: block;
}

.player-wave-wrap{
  position: relative;
  z-index: 3;
  margin-top: 8px;
  width: 100%;
  height: 10px;
}

.freq-bars{
  position: relative;
  width: 100%;
  height: 10px;
  border-radius: 999px;
  overflow: hidden;
  opacity: .58;
  background:
    repeating-linear-gradient(
      90deg,
      rgba(0,0,0,.18) 0 4px,
      transparent 4px 7px
    );
  -webkit-mask-image: linear-gradient(90deg, rgba(0,0,0,.18), rgba(0,0,0,1) 12%, rgba(0,0,0,1) 88%, rgba(0,0,0,.18));
  mask-image: linear-gradient(90deg, rgba(0,0,0,.18), rgba(0,0,0,1) 12%, rgba(0,0,0,1) 88%, rgba(0,0,0,.18));
  animation: freqMove 1s ease-in-out infinite alternate;
}

@keyframes freqMove{
  0%{ transform: scaleX(.95); }
  100%{ transform: scaleX(1); }
}

.freq-bars.is-paused{
  animation: none;
  opacity: .16;
}

