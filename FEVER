}

@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600&family=Rajdhani:wght@600;700&display=swap');

:root{
  --sb-top: 74px;
  --sb-w: 268px;
  --posts-max: 930px;
  --posts-shift: 100px;
  --sidebar-gap: 27px;

  --glass-bg: rgba(255,255,255,0.58);
  --glass-bg-2: rgba(255,255,255,0.38);
  --glass-blur: blur(22px) saturate(180%);
  --sb-radius: 18px;

  --text-color: #2b2b2b;
  --muted: rgba(0,0,0,0.48);
  --line: rgba(0,0,0,0.07);
  --line-soft: rgba(255,255,255,0.66);
  --dark-soft: rgba(0,0,0,0.035);
}

#sharp-sidebar-wrap{
  position: fixed;
  top: var(--sb-top);
  left: calc(
    50% - (var(--posts-max) / 2) + var(--posts-shift) - var(--sb-w) - var(--sidebar-gap)
  );
  width: var(--sb-w);
  z-index: 99999;
  display: flex;
  flex-direction: column;
  gap: 10px;
  pointer-events: none;
  box-sizing: border-box;
}

#sharp-sidebar,
.sb-player-box{
  position: relative;
  width: 100%;
  max-width: 100%;
  pointer-events: auto;
  overflow: hidden;
  box-sizing: border-box;
  border: 1px solid rgba(0,0,0,.06);
  border-radius: var(--sb-radius);
  background:
    linear-gradient(180deg, rgba(255,255,255,.82) 0%, rgba(255,255,255,.58) 100%);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  box-shadow:
    0 16px 34px rgba(0,0,0,.06),
    inset 0 1px 0 rgba(255,255,255,.72),
    inset 0 0 0 1px rgba(255,255,255,.10);
}

#sharp-sidebar::before,
.sb-player-box::before{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  background:
    linear-gradient(155deg, rgba(255,255,255,.20) 0%, transparent 28%, rgba(255,255,255,.08) 58%, transparent 100%);
  opacity:.95;
}

.sb-shell{
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
}

/* HERO */
.sb-hero{
  position: relative;
  display: block;
  min-height: 178px;
  width: 100%;
  text-decoration: none;
  overflow: hidden;
  border-bottom: 1px solid rgba(0,0,0,.06);
  background: rgba(255,255,255,.12);
}

.sb-hero-img-wrap{
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.sb-hero-img-wrap img{
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transform: scale(1.03);
  filter: saturate(1.02) contrast(1.04);
  transition: transform .85s ease, filter .85s ease;
}

#sharp-sidebar:hover .sb-hero-img-wrap img{
  transform: scale(1.07);
  filter: saturate(1.07) contrast(1.05);
}

.sb-hero-noise{
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 20% 20%, rgba(255,255,255,.11) 0 2px, transparent 2px 100%),
    radial-gradient(circle at 80% 40%, rgba(255,255,255,.07) 0 1px, transparent 1px 100%);
  mix-blend-mode: screen;
  opacity: .30;
  pointer-events: none;
}

.sb-hero-lines{
  position: absolute;
  inset: 0;
  background:
    repeating-linear-gradient(
      0deg,
      rgba(255,255,255,.045) 0 1px,
      transparent 1px 13px
    );
  opacity: .58;
  pointer-events: none;
}

.sb-hero-orb{
  position: absolute;
  width: 120px;
  height: 120px;
  right: -26px;
  top: -18px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,.20);
  box-shadow:
    0 0 0 12px rgba(255,255,255,.04),
    0 0 0 26px rgba(255,255,255,.03);
  pointer-events: none;
}

.sb-hero::after{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(
      to top,
      rgba(8,8,8,.60) 0%,
      rgba(8,8,8,.24) 40%,
      rgba(255,255,255,.04) 100%
    );
  pointer-events:none;
}

.sb-hero-overlay{
  position: absolute;
  left: 14px;
  right: 14px;
  bottom: 11px;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 4px;
  align-items: flex-start;
}

.sb-kicker{
  display: inline-flex;
  align-items: center;
  min-height: 16px;
  padding: 0 7px;
  border-radius: 999px;
  background: rgba(255,255,255,.14);
  border: 1px solid rgba(255,255,255,.14);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.18);
  font-family: "Orbitron", sans-serif;
  font-size: 6px;
  letter-spacing: 1.6px;
  text-transform: uppercase;
  color: rgba(255,255,255,.92);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.sb-title{
  position: relative;
  width: 100%;
  max-width: 100%;
  padding-bottom: 5px;
  font-family: "Orbitron", sans-serif;
  font-size: 10px;
  line-height: 1.12;
  letter-spacing: 2.2px;
  text-transform: uppercase;
  color: #fff;
  text-shadow: 0 2px 14px rgba(0,0,0,.28);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sb-title::after{
  content:"";
  position:absolute;
  left:0;
  bottom:0;
  width:56px;
  height:1px;
  background: linear-gradient(90deg, rgba(255,255,255,.94), transparent);
}

/* META */
.sb-top-meta{
  display: grid;
  grid-template-columns: minmax(0,1fr) auto;
  gap: 7px;
  padding: 10px 10px 0;
  align-items: center;
}

.sb-profile-pill,
.sb-online-pill{
  min-width: 0;
  min-height: 28px;
  display: inline-flex;
  align-items: center;
  border-radius: 10px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.56) 0%, rgba(255,255,255,.28) 100%);
  border: 1px solid rgba(0,0,0,.05);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.58);
  transition: transform .22s ease, background .22s ease, box-shadow .22s ease;
}

.sb-profile-pill{
  padding: 0 10px;
  gap: 6px;
  overflow: hidden;
}

.sb-online-pill{
  padding: 0 9px;
  gap: 5px;
  white-space: nowrap;
}

.sb-profile-pill:hover,
.sb-online-pill:hover{
  transform: translateY(-1px);
  background:
    linear-gradient(180deg, rgba(255,255,255,.72) 0%, rgba(255,255,255,.34) 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.68),
    0 7px 14px rgba(0,0,0,.04);
}

.hd-name-text{
  min-width: 0;
  font-family: "Orbitron", sans-serif;
  font-size: 7px;
  letter-spacing: 1.15px;
  text-transform: uppercase;
  color: var(--text-color);
  line-height: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hd-verified-badge{
  width: 13px;
  height: 13px;
  flex: 0 0 13px;
  border-radius: 4px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,.95);
  border: 1px solid rgba(0,0,0,.05);
}

.hd-verified-badge svg{
  width: 8px;
  height: 8px;
  fill: none;
  stroke: #555;
  stroke-width: 2;
}

.online-dot{
  width: 5px;
  height: 5px;
  flex: 0 0 5px;
  border-radius: 50%;
  background: #8e8e8e;
  animation: sbPulse 2s ease-in-out infinite;
}

@keyframes sbPulse{
  0%,100%{ transform: scale(1); opacity: .55; box-shadow: 0 0 0 0 rgba(255,255,255,0); }
  50%{ transform: scale(1.18); opacity: 1; box-shadow: 0 0 8px 2px rgba(255,255,255,.34); }
