  function cleanupNPFMediaUrls($scope){
    $scope = ($scope && $scope.length) ? $scope : $(document);

    $scope.find('a[href]').each(function(){
      var $a = $(this);
      var hrefRaw = $a.attr('href') || '';
      var href = hrefRaw.toLowerCase();
      var txt = $.trim($a.text() || '');

      var isMedia =
        href.indexOf('64.media.tumblr.com/') !== -1 ||
        href.indexOf('va.media.tumblr.com/') !== -1 ||
        href.indexOf('media.tumblr.com/') !== -1;

      if(!isMedia) return;

      if(txt && ($.trim(hrefRaw) === txt || $.trim(href) === txt.toLowerCase()) && $a.children().length === 0){
        var $p = $a.closest('p');
        if($p.length && $.trim($p.text()) === txt) $p.remove();
        else $a.remove();
