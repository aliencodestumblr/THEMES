<style type="text/css">
/* ANTI-SCROLL LATERAL */
html { scrollbar-gutter: stable both-edges; }
body { overflow-y: scroll; }


/* ---------------- PLAYER DO SPOTIFY ---------------- */
:root{
  --sp-scale: 0.80;
  --sp-base-height: 80px;
}

article iframe[src*="spotify.com"],
iframe.spotify_audio_player {
  aspect-ratio: auto !important;
  width: calc(100% / var(--sp-scale)) !important;
  height: var(--sp-base-height) !important;
  transform: scale(var(--sp-scale)) !important;
  transform-origin: top left !important;
  display: block;
  border: 0;
  margin-bottom: calc(var(--sp-base-height) * (var(--sp-scale) - 1)) !important;
}

figure iframe.spotify_audio_player {
  max-height: none !important;
  width: calc(100% / var(--sp-scale)) !important;
}

@keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-moz-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-webkit-keyframes fadein {from {opacity:0;} to {opacity:1;}}
@-o-keyframes fadein {from {opacity:0;} to {opacity:1;}}

html, body, a, a:hover{cursor:crosshair;}

/* ---------------- CONTROLES ---------------- */
.cc {
    z-index: 100;
    position: fixed;
    top: 20px;
    right: 20px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 1s;
    padding: 0;
}

.cc svg {
    display: block;
    width: 11px;
    height: 11px;
    overflow: visible;
    color: {color:accent};
}

.cc svg path,
.cc svg circle,
.cc svg line {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.55;
    stroke-linecap: round;
    stroke-linejoin: round;
}
     
iframe.tmblr-iframe {
    z-index: 999;
    right: 22px;
    top: 27px;
    opacity: 0;
    position: fixed;

    width: 0;

    {block:IfDarkTumblrControl}
    filter: invert(1);
    {/block:IfDarkTumblrControl}

    padding-right: 90px; 

    transform: scale(0.38);
    -webkit-transform: scale(0.38);

    transform-origin: 100% 0;
    -webkit-transform-origin: 100% 0;

    transition: opacity 0.35s ease;
    -webkit-transition: opacity 0.35s ease;
}

.tmblr-iframe:hover {
    opacity: 0.5 !important;
}
/* ---------------- IMAGENS EXPANDIDAS ---------------- */
.vignette, #vignette { opacity:0; }

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999;
  box-shadow:none !important;
  border-radius:2px !important;
  max-width:none;
}

.tmblr-lightbox, #tumblr_lightbox {
    z-index: 999999999;
  background-color:rgba({RGBcolor:background},.7) !important;
}

.lightbox-image, #tumblr_lightbox img {
  z-index: 999999999; 
  border:5px solid {color:background}; !important;
  box-shadow: 1px 1px 2px rgba(0,0,0,.1);
  -moz-box-sizing:border-box;
  box-sizing:border-box;
}

/* ---------------- ESTILO DE LINKS + MÍDIA ---------------- */
pre, code {
  overflow-x:auto;
  user-select:all;
  font-family:monospace;
  padding:4px 6px;
  line-height:14px;
  background:rgba(0,0,0,.04);
  margin:10px 0;
}

li {margin-left:-32px;}
ul {margin-left:6px;}

a, a:link, a:active, a:visited {
  cursor:crosshair; 
  color:{color:links};
  text-decoration:none;
  transition:.5s;
}

a:hover {
  cursor:crosshair;
  color:{color:links hover};
  text-decoration:none;
  transition:.5s;
}

a.read_more{
  visibility:visible;
  font-size:9px;
  text-transform:uppercase;
  font-weight:bold;
  padding-bottom:3px;
}

p a {font-weight:700;}
p {margin-top:0px;}


/* --------- BLOCKQUOTE + MÍDIA NPF (FOTO/VÍDEO) --------- */
blockquote { display:block; margin:0px; }


blockquote img {
   cursor:crosshair; 
  width:calc(100% - 0);
  height:auto;
}
blockquote video {
  cursor:crosshair; 
  width:100%;
}

img {
  cursor:crosshair; 
  border:0;
  width:calc(100% - 0);
  height:auto;
  display:block;
}

video {
  display:block;
  margin:0 auto !important;
  padding:0 !important;
}

.npf_video,
.npf_video_container,
.tmblr-full,
figure.tmblr-full,
figure,
.npf_inst{
  margin:0 !important;
  padding:0 !important;
  line-height:1 !important;
}

.npf_video::after,
.npf_video_container::after,
figure::after,
.tmblr-full::after{
  content:none !important;
  display:none !important;
  height:0 !important;
}

/* ---------------- BODY ---------------- */
body {
  color:{color:text};
  background-color:#000000;
  font:400 10.5px "Rajdhani", sans-serif;
  transition:1.3s;
  letter-spacing:0.5px;
  text-align:justify;
  line-height:15px;
  word-wrap:break-word;
  -webkit-animation-name:fadeIn; animation-name:fadeIn;
}


/* ------------ TÍTULOS DE CABEÇALHO DE POSTS DE TEXTO ------------ */
.caption h1,
.caption h2,
.caption h3,
.caption h4,
.caption h5,
.caption h6{
  margin:0 0 10px 0!important;

  font-family:'Work Sans', sans-serif!important;
  font-weight:700!important;

  color:{color:text}!important;

  text-align:left!important;
  text-transform:uppercase;

  letter-spacing:.8px;
  line-height:1.05!important;
}

.caption h1{
  font-size:20px!important;
}

.caption h2{
  font-size:18px!important;
}

.caption h3{
  font-size:16px!important;
}

.caption h4{
  font-size:14px!important;
}

.caption h5{
  font-size:13px!important;
}

.caption h6{
  font-size:12px!important;
}

.caption h1 + p,
.caption h2 + p,
.caption h3 + p,
.caption h4 + p,
.caption h5 + p,
.caption h6 + p{
  margin-top:6px!important;
}


/* ---------------- CONTAINER DE DESIGN DOS POSTS ---------------- */
.entry{
  width:740px;
  height:auto;
  margin: 0 auto !important;

  {block:PermalinkPage}
  width:540px;
  margin: 0 auto !important;
  {/block:PermalinkPage}
}

#posts{
  width:740px;
  margin: 20px auto 50px auto !important;

  transform: translateX(80px);
  
  transition-property: opacity, filter;
  transition-duration: .0s;

  {block:PermalinkPage}
  width:540px;
  margin:45px auto 0 auto !important;
  transform: translateX(0px);
  border:0px;
  {/block:PermalinkPage}
}

.posts{
  width:320px;
  margin:20px;
  margin-bottom:20px;

  padding:10px;

  overflow:visible;
  opacity:1;
  transition:1s;

  background:#000000;

  border:1px solid {color:Borders};

  box-shadow:
    0 12px 28px rgba(0,0,0,.65),
    inset 0 1px 0 rgba(255,255,255,.03);

  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);

  {block:PermalinkPage}
  width:540px;
  margin:25px auto 0 auto;

  background:transparent;

  border:0;

  box-shadow:none;
  {/block:PermalinkPage}
}


/* ---------------- LINHA DO USUÁRIO NO TOPO DO POST ---------------- */
.post-top{
  margin: 0 0 8px 0;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:0px;

  font-family:"Rajdhani", sans-serif;
  font-size:9px;
  letter-spacing:1.6px;
  text-transform:uppercase;

  opacity:.68;
}

.post-top a{
  color:{color:text};
  text-decoration:none;
  font-weight:800;
}

.post-top a:hover{
  opacity:.6;
}


/* ------------- HOVER DO PERMALINK EM FOTO/VÍDEO ------------- */
.notsi .npf-box{
  position:absolute;
  right:10px;
  bottom:10px;
  z-index:5;
  pointer-events:none;
}

.notsi .inf2{
  display:flex;
  align-items:center;
  gap:4px;

  opacity:0;
  transform:translateY(10px);

  transition:
    opacity .38s cubic-bezier(.16,1,.3,1),
    transform .38s cubic-bezier(.16,1,.3,1);

  pointer-events:auto;
}

.notsi .inf2 a{
  width:34px;
  height:34px;

  display:flex;
  align-items:center;
  justify-content:center;

  padding:0!important;
  margin:0!important;

  background:rgba(0,0,0,.92);

  border:1px solid rgba(255,255,255,.08);

  border-radius:3px;

  color:rgba(255,255,255,.42);

  text-decoration:none!important;

  opacity:0;
  transform:translateY(8px);

  transition:
    opacity .25s ease,
    transform .35s cubic-bezier(.16,1,.3,1),
    background .2s ease,
    color .2s ease,
    border-color .2s ease,
    box-shadow .2s ease;
}

.notsi .inf2 a::before,
.notsi .inf2 a::after{
  display:none!important;
}

.notsi .inf2 i{
  font-size:11px;
}

.notsi .inf2 .rb-icon{
  width:12px;
  height:12px;
  opacity:.7;
}

.notsi .inf2 .rb-icon path{
  fill:none;
  stroke:currentColor;
  stroke-width:1.6;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.notsi .ac-label{
  display:none!important;
}

.notsi .inf2 a:hover{
  color:#fff;

  background:rgba(255,255,255,.05);

  border-color:rgba(255,255,255,.18);

  box-shadow:
    0 0 0 1px rgba(255,255,255,.05),
    0 8px 18px rgba(0,0,0,.45);

  transform:translateY(-2px);
}

.notsi .inf2 a:nth-child(1){
  transition-delay:.03s;
}

.notsi .inf2 a:nth-child(2){
  transition-delay:.06s;
}

.notsi .inf2 a:nth-child(3){
  transition-delay:.09s;
}

.post:hover .notsi .inf2,
.ac-hover-on .notsi .inf2{
  opacity:1;
  transform:translateY(0);
}

.post:hover .notsi .inf2 a,
.ac-hover-on .notsi .inf2 a{
  opacity:1;
  transform:translateY(0);
}

/* --------- TAMANHOS DE IMAGEM + VÍDEO / NÃO ALTERAR --------- */
.posts img{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
  transition:1s;
}

.video{
  width:100%;
  {block:permalinkpage}
  width:100%;
  {/block:permalinkpage}
}

.vsanna{ display:none; }


/* ---------------- ROLAGEM INFINITA ---------------- */
#infscr-loading{
  position:absolute;
  bottom:0;
  margin-left:50%;
  left:0px;
  text-align:center;
}

#infscr-loading img{
  display:none;
  width:20px;
  height:20px;
}


/* EFEITO DE CARREGAMENTO SUAVE */
{block:IndexPage}
.posts{
  transition: opacity .75s ease, transform .75s ease;
}

.posts.is-ready{
  opacity:1;
  transform: translateY(0);
}
{/block:IndexPage}
/* FIM DO EFEITO DE CARREGAMENTO SUAVE */


/* ---------------- BARRA DE ROLAGEM ---------------- */
::-webkit-scrollbar{ width:8px; } ::-webkit-scrollbar-track{ background: transparent; } ::-webkit-scrollbar-thumb{ background: transparent; border-radius: 3px; } .is-scrolling ::-webkit-scrollbar-thumb{ background: {color:Accent}; } .is-scrolling ::-webkit-scrollbar-thumb:hover{ box-shadow: 0 0 6px rgba({RGBcolor:Accent}, .45); } *{ scrollbar-width: thin; scrollbar-color: transparent transparent; } .is-scrolling{ scrollbar-color: {color:Accent} transparent; }


/* ---------------- PAGINAÇÃO ---------------- */

.page-nav{
  width:min(700px, calc(100% - 40px));
  margin:50px auto 80px!important;

  display:flex;
  align-items:center;
  justify-content:center;
  flex-wrap:wrap;
  gap:6px;

  font-family:"Rajdhani",sans-serif;
  font-size:9px;
  font-weight:800;
  letter-spacing:1.4px;
  text-transform:uppercase;
}

.page-nav a,
.page-nav span{
  min-width:31px;
  height:30px;
  padding:0 10px;

  display:flex;
  align-items:center;
  justify-content:center;

  background:rgba(255,255,255,.04);
  border:1px solid {color:Borders};
  border-radius:2px;

  color:{color:Links};
  text-decoration:none!important;

  box-sizing:border-box;

  transition:.22s ease;
