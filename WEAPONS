      $root.addClass('ac-hover-on');
      $post.addClass('ac-hover-on');
    });

    $doc.on('mouseleave.acHoverFix', '.notsi', function(e){
      var $root = $(this).parent('.ac-hover-root');
      var rel = e.relatedTarget;

      if($root.length && rel && $root[0].contains(rel)) return;
      if(rel && $(rel).closest('.ac-hover-root').length) return;

      if($root.length){
        var $post = $root.closest('.posts');

        $root.removeClass('ac-hover-on');

        if($post.length){
