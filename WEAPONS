  function unmarkIfNoMedia($post){
    $post.removeClass('has-npf-media ac-hover-on');
    $post.removeData('acHoverDone');
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-hover-root--npf-wide');

    if(activePost === $post[0] || (activeRoot && $.contains($post[0], activeRoot))){
      clearActiveHover();
    }
  }

  function addHoverOverlay($post){
    if(!$post || !$post.length) return;

    var hasOldPhotoset = $post.find('.photo-slideshow').length > 0;

    var hasImg = $post.find('img').filter(function(){
      return looksLikeNPFImage($(this));
    }).length > 0;

    var hasVid = $post.find('.npf_video_container, .npf_video, video, iframe').filter(function(){
      return looksLikeNPFVideo($(this));
    }).length > 0;

    if(!(hasOldPhotoset || hasImg || hasVid)){
      unmarkIfNoMedia($post);
      return;
    }

    $post.addClass('has-npf-media');

    var perma = $post.attr('data-permalink') || '';
    if(!perma) return;

    var rb = $post.attr('data-reblogurl') || '#';
    var tm = $post.attr('data-time') || '';

    if($post.data('acHoverDone') === 1 && !postNeedsRebuild($post)) return;

    $post.removeClass('ac-hover-on');
    $post.find('.notsi').remove();
    $post.find('.ac-hover-root').removeClass('ac-hover-root ac-hover-on ac-hover-root--npf-wide');

    var $node = buildOverlayNode();

    $node.find('.npf-time, [data-ac-time]').first().text(tm);
    $node.find('a.npf-reblog, [data-ac-reblog]').first().attr('href', rb);
    $node.find('a.npf-permalink, [data-ac-permalink]').first().attr('href', perma);
    $node.find('a.npf-lightbox, [data-ac-lightbox]').first().attr('href', '#');

    var $target = pickHoverTarget($post);
    if(!$target.length) $target = $post;

    $target = tightenNPFHoverTarget($target);

    if(($target.css('position') || 'static') === 'static'){
      $target.css('position','relative');
    }

    if(isWideNPFRoot($target)){
      $node.css({
        top:'0',
        left:'0',
        right:'1px',
        bottom:'0',
        width:'auto'
      });

      $target.addClass('ac-hover-root--npf-wide');
    }

    $target.addClass('ac-npf-media ac-hover-root').append($node);
    $post.data('acHoverDone', 1);

    killFloatingPermalinkIcons($post, perma);
  }

  function forceEager($scope){
    $scope = $scope && $scope.length ? $scope : $(document);

    $scope.find('img[loading="lazy"]').each(function(){
      try{ this.loading = 'eager'; }catch(e){}
      $(this).attr('loading','eager');
    });

    $scope.find('iframe[loading="lazy"]').each(function(){
      $(this).attr('loading','eager');
    });
