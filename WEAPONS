    return $post.find(
      '.photo-slideshow .pxu-photo img, .photo-slideshow img, .photo-data img, ' +
      '.npf_image img, figure.tmblr-full img, .tmblr-full img, ' +
      '.npf_video_container, .npf_video, video'
    ).filter(function(){
      return !$(this).closest('.notsi').length;
    }).first();
  }

