.page-nav a:hover{
  background:{color:Links};
  border-color:{color:Links};
  color:#000;
  transform:translateY(-2px);
}

.page-nav .current_page{
  background:{color:Links};
  border-color:{color:Links};
  color:#000;
}

.page-nav .prev,
.page-nav .next{
  min-width:68px;
}

.page-nav .disabled{
  opacity:.25;
  pointer-events:none;
}


/* ---------------- PERMALINK DO POST (INFERIOR) ---------------- */
{block:IndexPage}
.post-footer{
  margin-top:10px;
  width:100%;

  display:flex;
  align-items:center;
  justify-content:space-between;

  padding:7px 8px!important;

  background:rgba(0,0,0,.72)!important;
  border:1px solid {color:Borders}!important;
  border-radius:2px!important;

  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.035),
    0 8px 18px rgba(0,0,0,.35)!important;

  box-sizing:border-box;
}

.pf-left,
.pf-right{
  display:flex;
  align-items:center;
  margin:0!important;
  padding:0!important;
}

.pf-right{
  gap:5px;
}

/* NOTES */

.pf-notes{
  display:flex;
  align-items:center;
  gap:5px;

  padding:0!important;
  margin:0!important;

  background:none!important;
  border:0!important;
  box-shadow:none!important;

  text-decoration:none!important;

  font-family:"Rajdhani","Orbitron",sans-serif;
  font-size:8px;
  font-weight:700;
